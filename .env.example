# ==================== 环境配置示例 ====================
# 复制此文件为 .env.local 或 .env.development 或 .env.production
# Vite 会根据 NODE_ENV 自动加载对应的环境变量

# ==================== CloudBase 配置 ====================

# 云开发环境 ID
VUE_APP_ENV_ID=your-env-id

# 云函数名称（支持多环境）
# 开发环境
VUE_APP_ADMIN_FUNCTION=admin-http
# 生产环境可以设置为
# VUE_APP_ADMIN_FUNCTION=admin-prod

# ==================== 其他配置 ====================

# API 基础路径
VUE_APP_API_BASE_URL=https://your-api.com

# 是否启用调试模式
VUE_APP_DEBUG=false
