# ============================================================================
# 环境变量示例文件
# 复制此文件为 .env.local 并填写实际值
# ============================================================================

# ===================
# Sentry 错误监控
# ===================
# Sentry DSN（从 Sentry 项目设置中获取）
VITE_SENTRY_DSN=

# Sentry CLI 上传配置（仅构建时使用）
SENTRY_DSN=
SENTRY_ORG=your-org
SENTRY_PROJECT=drone-training-system
SENTRY_AUTH_TOKEN=your-auth-token

# ===================
# 腾讯云短信（可选）
# ===================
TENCENT_SMS_SECRET_ID=
TENCENT_SMS_SECRET_KEY=
TENCENT_SMS_SDK_APP_ID=
TENCENT_SMS_TEMPLATE_ID=
TENCENT_SMS_SIGN_NAME=

# ===================
# 微信支付（可选）
# ===================
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_KEY=
WECHAT_PAY_CERT_PATH=
