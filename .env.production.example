# ==================== 生产环境配置 ====================
# 重要：请勿将此文件提交到版本控制系统！
# 复制 .env.production 为 .env.production.local 并填写真实配置

# ==================== CloudBase 配置 ====================
VITE_ENV_ID=rcwljy-5ghmq2ex26764978
VITE_PUBLISHABLE_KEY=your_publishable_key_here

# ==================== Sentry 监控 ====================
# 如果启用 Sentry 错误监控，请填写真实的 DSN
# VITE_SENTRY_DSN=https://example@sentry.io/1234567

# ==================== API 配置 ====================
# API 超时时间（毫秒）
VITE_API_TIMEOUT=30000

# ==================== 功能开关 ====================
# 是否启用调试模式
VITE_DEBUG_MODE=false

# 是否启用性能监控
VITE_ENABLE_ANALYTICS=true

# ==================== 构建配置 ====================
# 构建版本（自动生成，无需修改）
VITE_BUILD_VERSION=v20260507-production
