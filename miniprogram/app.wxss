/* app.wxss - 小程序全局样式 */

/* 主题色 */
page {
  --primary-color: #1890ff;
  --primary-light: #40a9ff;
  --primary-dark: #096dd9;
  --success-color: #52c41a;
  --warning-color: #faad14;
  --error-color: #ff4d4f;
  --text-primary: #262626;
  --text-secondary: #595959;
  --text-hint: #8c8c8c;
  --bg-primary: #ffffff;
  --bg-secondary: #f5f7fa;
  --border-color: #e8e8e8;
  --shadow-light: 0 2px 8px rgba(0, 0, 0, 0.06);
  --shadow-medium: 0 4px 12px rgba(0, 0, 0, 0.08);
  --radius-small: 8rpx;
  --radius-medium: 12rpx;
  --radius-large: 16rpx;

  background-color: var(--bg-secondary);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.5;
}

/* 卡片通用样式 */
.card {
  background: var(--bg-primary);
  border-radius: var(--radius-medium);
  box-shadow: var(--shadow-light);
  overflow: hidden;
}

/* 按钮通用样式 */
.btn-primary {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  color: white;
  border: none;
  border-radius: var(--radius-medium);
  padding: 20rpx 32rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  transition: all 0.3s ease;
}

.btn-primary:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* 标签通用样式 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-primary {
  background: rgba(24, 144, 255, 0.1);
  color: var(--primary-color);
}

.tag-success {
  background: rgba(82, 196, 26, 0.1);
  color: var(--success-color);
}

.tag-warning {
  background: rgba(250, 173, 20, 0.1);
  color: var(--warning-color);
}

.tag-error {
  background: rgba(255, 77, 79, 0.1);
  color: var(--error-color);
}

/* 价格样式 */
.price {
  color: #ff4d4f;
  font-weight: 600;
}

.price::before {
  content: '¥';
  font-size: 22rpx;
  margin-right: 4rpx;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: var(--text-hint);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-text {
  color: var(--text-hint);
  font-size: 28rpx;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--border-color);
  margin: 24rpx 0;
}

/* 安全区域适配 */
.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
