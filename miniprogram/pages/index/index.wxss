/* pages/index/index.wxss */

.page {
  background-color: #f6f6f6;
}

/* 搜索栏 */
.search-bar {
  padding: 12px 16px;
  background: #1890ff;
}

.search-input {
  background: #fff;
  border-radius: 20px;
  padding: 10px 16px;
  display: flex;
  align-items: center;
}

.search-icon {
  margin-right: 8px;
}

.search-placeholder {
  color: #999;
  font-size: 14px;
}

/* 内容区域 */
.content {
  padding: 12px 16px;
}

/* 分区 */
.section {
  margin-bottom: 24px;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.section-title {
  font-size: 18px;
  font-weight: 600;
  color: #333;
}

.section-more {
  font-size: 14px;
  color: #1890ff;
}

/* 课程网格 */
.course-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
}

.course-card {
  background: #fff;
  border-radius: 8px;
  overflow: hidden;
}

.course-cover {
  width: 100%;
  height: 120px;
}

.course-info {
  padding: 8px 12px;
}

.course-title {
  font-size: 14px;
  color: #333;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.course-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 4px;
}

.sales {
  font-size: 12px;
  color: #999;
}

/* 培训班列表 */
.class-list {
  background: #fff;
  border-radius: 8px;
}

.class-card {
  padding: 12px 16px;
  border-bottom: 1px solid #f0f0f0;
}

.class-card:last-child {
  border-bottom: none;
}

.class-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.class-name {
  font-size: 16px;
  font-weight: 600;
  color: #333;
}

.class-status {
  font-size: 12px;
  padding: 4px 8px;
  border-radius: 4px;
}

.class-status.enrolling {
  background: #e6f7ff;
  color: #1890ff;
}

.class-info {
  margin-bottom: 8px;
}

.class-date,
.class-location {
  font-size: 12px;
  color: #666;
  display: block;
}

.class-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.class-students {
  font-size: 12px;
  color: #999;
}

/* 商品网格 */
.product-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
}

.product-card {
  background: #fff;
  border-radius: 8px;
  overflow: hidden;
}

.product-cover {
  width: 100%;
  height: 100px;
}

.product-info {
  padding: 8px;
}

.product-title {
  font-size: 12px;
  color: #333;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-meta {
  margin-top: 4px;
}

.product-sales {
  font-size: 10px;
  color: #999;
  display: block;
}