/* pages/index/index.wxss - 首页样式（小程序适配版） */

/* ==================== 页面基础 ==================== */
.page {
  min-height: 100vh;
  background: #f1f5f9;
}

/* ==================== Hero 区域（紧凑版） ==================== */
.hero-section {
  position: relative;
  padding: 48rpx 24rpx 36rpx;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: -16rpx;
  background: linear-gradient(135deg, #2563eb 0%, #4f46e5 100%);
  border-radius: 0 0 32rpx 32rpx;
}

.hero-content {
  position: relative;
  z-index: 1;
}

/* Logo */
.hero-logo {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.logo-box {
  width: 56rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-icon {
  font-size: 28rpx;
}

.logo-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
}

/* 标题 */
.hero-title {
  margin-bottom: 16rpx;
}

.title-main {
  font-size: 44rpx;
  font-weight: 800;
  color: #fff;
  line-height: 1.2;
  display: block;
}

.title-sub {
  font-size: 44rpx;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.2;
  display: block;
}

/* 描述 */
.hero-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.5;
  margin-bottom: 24rpx;
  display: block;
}

/* 按钮 */
.hero-actions {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 28rpx;
  background: #fff;
  color: #2563eb;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
  font-weight: 600;
}

.btn-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 28rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  color: #fff;
  border-radius: 12rpx;
  font-weight: 500;
}

.btn-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.btn-text {
  font-size: 24rpx;
}

/* 信任标签 */
.hero-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.badge-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.badge-icon {
  color: #34d399;
  font-size: 22rpx;
}

.badge-text {
  color: rgba(255, 255, 255, 0.7);
  font-size: 22rpx;
}

/* ==================== 内容区域 ==================== */
.content {
  padding: 16rpx 24rpx;
}

/* ==================== 分区通用样式 ==================== */
.section {
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-icon-box {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.section-icon-box.green {
  background: linear-gradient(135deg, #10b981, #14b8a6);
}

.section-icon-box.blue {
  background: linear-gradient(135deg, #2563eb, #3b82f6);
}

.section-icon-box.amber {
  background: linear-gradient(135deg, #f59e0b, #f97316);
}

.section-icon-box.purple {
  background: linear-gradient(135deg, #8b5cf6, #a855f7);
}

.section-icon-box.red {
  background: linear-gradient(135deg, #ef4444, #f97316);
}

.section-icon {
  font-size: 26rpx;
}

.section-title-wrap {
  flex: 1;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1e293b;
  display: block;
}

.section-subtitle {
  font-size: 20rpx;
  color: #64748b;
  display: block;
}

.section-more {
  display: flex;
  align-items: center;
  color: #2563eb;
  font-size: 22rpx;
}

.arrow {
  font-size: 28rpx;
  margin-left: 4rpx;
}

/* ==================== 横向滑动容器 ==================== */
.scroll-x {
  width: 100%;
  white-space: nowrap;
}

.paths-scroll,
.course-scroll,
.class-scroll,
.features-scroll,
.product-scroll {
  display: inline-flex;
  gap: 12rpx;
  padding-right: 24rpx;
}

/* ==================== 学习路径卡片 ==================== */
.path-card {
  width: 160rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 16rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.path-icon-box {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 12rpx;
}

.path-icon-box.blue {
  background: linear-gradient(135deg, #dbeafe, #bfdbfe);
}

.path-icon-box.amber {
  background: linear-gradient(135deg, #fef3c7, #fde68a);
}

.path-icon-box.purple {
  background: linear-gradient(135deg, #e9d5ff, #d8b4fe);
}

.path-icon-box.red {
  background: linear-gradient(135deg, #fecaca, #fca5a5);
}

.path-icon {
  font-size: 24rpx;
}

.path-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #1e293b;
  display: block;
  margin-bottom: 6rpx;
}

.path-desc {
  font-size: 20rpx;
  color: #64748b;
}

/* ==================== 课程卡片（横向滑动） ==================== */
.course-card {
  width: 280rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.course-cover {
  width: 100%;
  height: 160rpx;
  background: linear-gradient(135deg, #dbeafe, #e0e7ff);
}

.course-body {
  padding: 12rpx;
}

.course-level-badge {
  display: inline-block;
  padding: 4rpx 10rpx;
  background: linear-gradient(135deg, #dbeafe, #e0e7ff);
  color: #2563eb;
  font-size: 18rpx;
  border-radius: 6rpx;
  margin-bottom: 8rpx;
}

.course-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #1e293b;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.3;
  min-height: 60rpx;
}

.course-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 10rpx;
}

.course-price {
  font-size: 26rpx;
  font-weight: 700;
  color: #ef4444;
}

.course-price::before {
  content: '¥';
  font-size: 18rpx;
}

.course-sales {
  font-size: 18rpx;
  color: #94a3b8;
}

/* ==================== 培训班卡片（横向滑动） ==================== */
.class-card {
  width: 320rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.class-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.class-name {
  flex: 1;
  font-size: 24rpx;
  font-weight: 600;
  color: #1e293b;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.class-status-badge {
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
}

.class-status-badge.enrolling {
  background: rgba(37, 99, 235, 0.1);
  color: #2563eb;
}

.class-info-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 6rpx;
}

.info-icon {
  font-size: 20rpx;
}

.info-text {
  font-size: 20rpx;
  color: #64748b;
}

.class-divider {
  height: 1rpx;
  background: #e2e8f0;
  margin: 12rpx 0;
}

.class-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.class-price {
  font-size: 28rpx;
  font-weight: 700;
  color: #ef4444;
}

.class-price::before {
  content: '¥';
  font-size: 20rpx;
}

.class-count {
  font-size: 20rpx;
  color: #64748b;
}

/* ==================== 统计数据（一行横排） ==================== */
.stats-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #2563eb 0%, #4f46e5 100%);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}

.stat-item {
  text-align: center;
}

.stat-number {
  font-size: 28rpx;
  font-weight: 800;
  color: #fff;
  display: block;
}

.stat-label {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
  margin-top: 4rpx;
}

.stat-divider {
  width: 1rpx;
  height: 40rpx;
  background: rgba(255, 255, 255, 0.2);
}

/* ==================== 特色功能卡片 ==================== */
.feature-card {
  width: 160rpx;
  background: #fff;
  border-radius: 14rpx;
  padding: 16rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.feature-icon-box {
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 10rpx;
}

.feature-icon-box.blue {
  background: linear-gradient(135deg, #dbeafe, #bfdbfe);
}

.feature-icon-box.green {
  background: linear-gradient(135deg, #d1fae5, #a7f3d0);
}

.feature-icon-box.amber {
  background: linear-gradient(135deg, #fef3c7, #fde68a);
}

.feature-icon-box.purple {
  background: linear-gradient(135deg, #e9d5ff, #d8b4fe);
}

.feature-icon-box.red {
  background: linear-gradient(135deg, #fecaca, #fca5a5);
}

.feature-icon {
  font-size: 22rpx;
}

.feature-title {
  font-size: 22rpx;
  font-weight: 600;
  color: #1e293b;
  display: block;
  margin-bottom: 4rpx;
}

.feature-desc {
  font-size: 18rpx;
  color: #64748b;
}

/* ==================== 商品卡片 ==================== */
.product-card {
  width: 200rpx;
  background: #fff;
  border-radius: 14rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.product-cover {
  width: 100%;
  height: 140rpx;
  background: linear-gradient(135deg, #fef3c7, #fef9c3);
}

.product-body {
  padding: 10rpx;
}

.product-name {
  font-size: 22rpx;
  color: #1e293b;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.3;
  min-height: 56rpx;
}

.product-price-box {
  margin-top: 6rpx;
}

.product-price {
  font-size: 24rpx;
  font-weight: 700;
  color: #ef4444;
}

.product-price::before {
  content: '¥';
  font-size: 16rpx;
}

.product-sales {
  display: block;
  font-size: 18rpx;
  color: #94a3b8;
  margin-top: 4rpx;
}

/* ==================== 空状态 ==================== */
.empty-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx 32rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.empty-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
  opacity: 0.5;
}

.empty-text {
  color: #94a3b8;
  font-size: 24rpx;
}

/* ==================== 加载状态 ==================== */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-spinner {
  font-size: 48rpx;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16rpx;
  color: #94a3b8;
  font-size: 24rpx;
}

/* ==================== 底部间距 ==================== */
.footer-space {
  height: 32rpx;
}