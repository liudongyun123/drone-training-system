/* pages/index/index.wxss - 首页样式（完整复刻 Web 端） */

/* ==================== 页面基础 ==================== */
.page {
  min-height: 100vh;
  background: #f1f5f9;
}

/* ==================== Hero 区域（蓝色渐变背景） ==================== */
.hero-section {
  position: relative;
  min-height: 560rpx;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: -20rpx;
  background: linear-gradient(135deg, #2563eb 0%, #4f46e5 100%);
  border-radius: 0 0 48rpx 48rpx;
}

.hero-content {
  position: relative;
  z-index: 1;
  padding: 60rpx 40rpx 40rpx;
}

/* Logo */
.hero-logo {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.logo-box {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10rpx);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-icon {
  font-size: 40rpx;
}

.logo-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
}

/* 标题 */
.hero-title {
  margin-bottom: 24rpx;
}

.title-main {
  font-size: 52rpx;
  font-weight: 800;
  color: #fff;
  line-height: 1.2;
  display: block;
}

.title-sub {
  font-size: 52rpx;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.2;
  display: block;
}

/* 描述 */
.hero-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.6;
  margin-bottom: 32rpx;
  display: block;
  max-width: 560rpx;
}

/* 按钮 */
.hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 22rpx 36rpx;
  background: #fff;
  color: #2563eb;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  font-weight: 600;
  min-width: 180rpx;
}

.btn-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 22rpx 36rpx;
  background: transparent;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  color: #fff;
  border-radius: 16rpx;
  font-weight: 600;
  min-width: 180rpx;
}

.btn-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.btn-text {
  font-size: 26rpx;
}

/* 信任标签 */
.hero-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.badge-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.badge-icon {
  color: #34d399;
  font-size: 26rpx;
}

.badge-text {
  color: rgba(255, 255, 255, 0.7);
  font-size: 24rpx;
}

/* 向下滚动提示 */
.scroll-hint {
  position: absolute;
  bottom: 24rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 2;
}

.scroll-arrow {
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.5);
  transform: rotate(90deg);
}

/* ==================== 内容区域 ==================== */
.content {
  padding: 24rpx;
}

/* ==================== 分区通用样式 ==================== */
.section {
  margin-bottom: 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

.section-header.center {
  justify-content: center;
}

.section-icon-box {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.1);
}

.section-icon-box.green {
  background: linear-gradient(135deg, #10b981, #14b8a6);
}

.section-icon-box.blue {
  background: linear-gradient(135deg, #2563eb, #3b82f6);
}

.section-icon-box.amber {
  background: linear-gradient(135deg, #f59e0b, #f97316);
}

.section-icon-box.purple {
  background: linear-gradient(135deg, #8b5cf6, #a855f7);
}

.section-icon {
  font-size: 32rpx;
}

.section-title-wrap {
  flex: 1;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
  display: block;
}

.section-subtitle {
  font-size: 22rpx;
  color: #64748b;
  display: block;
}

.section-more {
  display: flex;
  align-items: center;
  color: #2563eb;
  font-size: 24rpx;
}

.arrow {
  font-size: 32rpx;
  margin-left: 4rpx;
}

/* ==================== 学习路径 ==================== */
.paths-section {
  background: #f8fafc;
  padding: 24rpx;
  border-radius: 24rpx;
}

.paths-grid {
  display: flex;
  gap: 16rpx;
}

.path-card {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.path-icon-box {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16rpx;
}

.path-icon-box.blue {
  background: linear-gradient(135deg, #dbeafe, #bfdbfe);
}

.path-icon-box.amber {
  background: linear-gradient(135deg, #fef3c7, #fde68a);
}

.path-icon-box.purple {
  background: linear-gradient(135deg, #e9d5ff, #d8b4fe);
}

.path-icon {
  font-size: 28rpx;
}

.path-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1e293b;
  display: block;
  margin-bottom: 8rpx;
}

.path-desc {
  font-size: 22rpx;
  color: #64748b;
}

/* ==================== 课程卡片 ==================== */
.course-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.course-card {
  width: calc(50% - 10rpx);
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.course-cover {
  width: 100%;
  height: 180rpx;
  background: linear-gradient(135deg, #dbeafe, #e0e7ff);
}

.course-body {
  padding: 16rpx;
}

.course-level-badge {
  display: inline-block;
  padding: 6rpx 14rpx;
  background: linear-gradient(135deg, #dbeafe, #e0e7ff);
  color: #2563eb;
  font-size: 20rpx;
  border-radius: 8rpx;
  margin-bottom: 10rpx;
}

.course-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1e293b;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
  min-height: 72rpx;
}

.course-desc {
  font-size: 22rpx;
  color: #64748b;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-top: 6rpx;
}

.course-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}

.course-price-box {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.course-price {
  font-size: 28rpx;
  font-weight: 700;
  color: #ef4444;
}

.course-price::before {
  content: '¥';
  font-size: 20rpx;
}

.course-original {
  font-size: 22rpx;
  color: #94a3b8;
  text-decoration: line-through;
}

.course-original::before {
  content: '¥';
}

.course-sales {
  font-size: 20rpx;
  color: #94a3b8;
}

/* ==================== 培训班卡片 ==================== */
.class-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.class-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.class-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.class-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
}

.class-status-badge {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.class-status-badge.enrolling {
  background: rgba(37, 99, 235, 0.1);
  color: #2563eb;
}

.class-info-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 8rpx;
}

.info-icon {
  font-size: 24rpx;
}

.info-text {
  font-size: 24rpx;
  color: #64748b;
}

.class-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  margin-top: 12rpx;
  border-top: 1rpx solid #e2e8f0;
}

.class-price-box {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
}

.class-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #ef4444;
}

.class-price::before {
  content: '¥';
  font-size: 24rpx;
}

.class-original {
  font-size: 24rpx;
  color: #94a3b8;
  text-decoration: line-through;
}

.class-count {
  font-size: 24rpx;
  color: #64748b;
}

/* ==================== 统计数据 ==================== */
.stats-section {
  background: linear-gradient(135deg, #2563eb 0%, #4f46e5 100%);
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.stat-card {
  text-align: center;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 20rpx 12rpx;
}

.stat-number {
  font-size: 32rpx;
  font-weight: 800;
  color: #fff;
  display: block;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
  margin-top: 8rpx;
}

/* ==================== 特色功能 ==================== */
.features-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
}

.features-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.feature-card {
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
}

.feature-icon-box {
  width: 60rpx;
  height: 60rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 12rpx;
}

.feature-icon-box.blue {
  background: linear-gradient(135deg, #dbeafe, #bfdbfe);
}

.feature-icon-box.green {
  background: linear-gradient(135deg, #d1fae5, #a7f3d0);
}

.feature-icon-box.amber {
  background: linear-gradient(135deg, #fef3c7, #fde68a);
}

.feature-icon-box.purple {
  background: linear-gradient(135deg, #e9d5ff, #d8b4fe);
}

.feature-icon {
  font-size: 28rpx;
}

.feature-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1e293b;
  display: block;
  margin-bottom: 8rpx;
}

.feature-desc {
  font-size: 22rpx;
  color: #64748b;
}

/* ==================== 商品商城 ==================== */
.shop-section {
  background: #f8fafc;
  border-radius: 24rpx;
  padding: 24rpx;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.product-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.product-cover {
  width: 100%;
  height: 160rpx;
  background: linear-gradient(135deg, #fef3c7, #fef9c3);
}

.product-body {
  padding: 12rpx;
}

.product-name {
  font-size: 24rpx;
  color: #1e293b;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.3;
  min-height: 60rpx;
}

.product-price-box {
  margin-top: 8rpx;
}

.product-price {
  font-size: 26rpx;
  font-weight: 700;
  color: #ef4444;
}

.product-price::before {
  content: '¥';
  font-size: 20rpx;
}

.product-sales {
  display: block;
  font-size: 20rpx;
  color: #94a3b8;
  margin-top: 4rpx;
}

/* ==================== 空状态 ==================== */
.empty-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  color: #94a3b8;
  font-size: 26rpx;
}

/* ==================== 加载状态 ==================== */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  font-size: 60rpx;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  color: #94a3b8;
  font-size: 26rpx;
}

/* ==================== 底部间距 ==================== */
.footer-space {
  height: 40rpx;
}