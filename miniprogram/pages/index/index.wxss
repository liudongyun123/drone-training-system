/* pages/index/index.wxss - 首页样式（小程序适配版） */

/* ==================== 页面基础 ==================== */
.page {
  min-height: 100vh;
  background: #f1f5f9;
}

/* ==================== Hero 区域（三块布局） ==================== */
.hero-section {
  background: linear-gradient(135deg, #2563eb 0%, #4f46e5 100%);
  padding: 16rpx 24rpx 16rpx 24rpx;
  box-sizing: border-box;
}

/* 顶部区域（左右分栏） */
.hero-top {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

/* 左侧文字区域 */
.hero-left {
  flex: 1;
  display: flex;
  flex-direction: column;
}

/* 底部区域 */
.hero-bottom {
  margin-top: 0;
  padding-left: 0;
  padding-right: 24rpx;
  padding-bottom: 16rpx;
}

/* 右侧轮播图区域 */
.hero-right {
  width: 52%;
}

.hero-swiper {
  width: 100%;
  height: 280rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.hero-banner-image {
  width: 100%;
  height: 280rpx;
  border-radius: 16rpx;
}

/* 底部按钮区域（横跨两栏） */
.hero-bottom {
  display: flex;
  flex-direction: column;
  margin-top: 10rpx;
}

.hero-bottom .hero-desc {
  margin-bottom: 10rpx;
}

/* 按钮和信任标签同行 */
.hero-bottom-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
}

/* Logo */
.hero-logo {
  display: flex;
  align-items: flex-start;
  justify-content: flex-start;
  margin-bottom: 0;
  margin-top: 0;
}

.logo-img {
  width: 160rpx;
  height: 80rpx;
}

/* 标题 */
.hero-title {
  margin-bottom: 20rpx;
}

.title-main {
  font-size: 52rpx;
  font-weight: 800;
  color: #fff;
  line-height: 1.2;
  display: block;
}

.title-sub {
  font-size: 52rpx;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.2;
  display: block;
}



/* 按钮 */
.hero-actions {
  display: flex;
  gap: 10rpx;
  margin-bottom: 16rpx;
}
/* 描述 */
.hero-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.6;
  margin-bottom: 28rpx;
  display: block;
}
.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 18rpx;
  background: #fff;
  color: #2563eb;
  border-radius: 6rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
  font-weight: 600;
}

.btn-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 18rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  color: #fff;
  border-radius: 6rpx;
  font-weight: 500;
}

.btn-icon {
  font-size: 20rpx;
  margin-right: 6rpx;
}

.btn-text {
  font-size: 20rpx;
}

/* 信任标签 */
.hero-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.badge-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.badge-icon {
  color: #34d399;
  font-size: 18rpx;
}

.badge-text {
  color: rgba(255, 255, 255, 0.7);
  font-size: 18rpx;
}

/* ==================== 内容区域 ==================== */
.content {
  padding: 24rpx;
  box-sizing: border-box;
}

/* ==================== 体系切换 Tab ==================== */
.source-tabs {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 0;
  margin-bottom: 8rpx;
}

.source-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  background: #fff;
  border-radius: 12rpx;
  border: 2rpx solid #e2e8f0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s ease;
}

.source-tab.active {
  background: linear-gradient(135deg, #2563eb, #4f46e5);
  border-color: #2563eb;
  box-shadow: 0 4rpx 16rpx rgba(37, 99, 235, 0.3);
}

.source-tab.active .source-icon,
.source-tab.active .source-name {
  color: #fff;
}

.source-icon {
  font-size: 28rpx;
}

.source-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1e293b;
}

/* ==================== 分区通用样式 ==================== */
.section {
  margin-bottom: 28rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 18rpx;
}

.section-icon-box {
  width: 60rpx;
  height: 60rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 14rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  flex-shrink: 0;
}

.section-icon-box.green {
  background: linear-gradient(135deg, #10b981, #14b8a6);
}

.section-icon-box.blue {
  background: linear-gradient(135deg, #2563eb, #3b82f6);
}

.section-icon-box.amber {
  background: linear-gradient(135deg, #f59e0b, #f97316);
}

.section-icon-box.purple {
  background: linear-gradient(135deg, #8b5cf6, #a855f7);
}

.section-icon-box.red {
  background: linear-gradient(135deg, #ef4444, #f97316);
}

.section-icon {
  font-size: 28rpx;
}

.section-title-wrap {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.section-subtitle {
  font-size: 22rpx;
  color: #64748b;
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.section-more {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #2563eb;
  font-size: 24rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
  white-space: nowrap;
  min-width: 80rpx;
  padding: 8rpx 12rpx;
}

.arrow {
  font-size: 30rpx;
  margin-left: 4rpx;
}

/* ==================== 横向滑动容器 ==================== */
.scroll-x {
  width: 100%;
  white-space: nowrap;
  padding-bottom: 8rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.paths-scroll,
.course-scroll,
.class-scroll,
.features-scroll,
.product-scroll {
  display: inline-flex;
  gap: 11rpx;
  padding-left: 8rpx;
  padding-right: 8rpx;
}

/* ==================== 学习路径卡片 ==================== */
.path-card {
  width: 166rpx;
  flex-shrink: 0;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 12rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
}

.path-icon-box {
  width: 60rpx;
  height: 60rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 10rpx;
}

.path-icon-box.blue {
  background: linear-gradient(135deg, #dbeafe, #bfdbfe);
}

.path-icon-box.amber {
  background: linear-gradient(135deg, #fef3c7, #fde68a);
}

.path-icon-box.purple {
  background: linear-gradient(135deg, #e9d5ff, #d8b4fe);
}

.path-icon-box.red {
  background: linear-gradient(135deg, #fecaca, #fca5a5);
}

.path-icon {
  font-size: 24rpx;
}

.path-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #1e293b;
  display: block;
  margin-bottom: 6rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.path-desc {
  font-size: 20rpx;
  color: #64748b;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ==================== 课程卡片（横向滑动） ==================== */
.course-card {
  width: 225rpx;
  flex-shrink: 0;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
}

.course-cover {
  width: 100%;
  height: 130rpx;
  background: linear-gradient(135deg, #dbeafe, #e0e7ff);
}

.course-body {
  padding: 12rpx;
  width: auto;
}

.course-level-badge,
.class-level-badge {
  display: inline-block;
  padding: 4rpx 10rpx;
  background: linear-gradient(135deg, #dbeafe, #e0e7ff);
  color: #2563eb;
  font-size: 18rpx;
  border-radius: 6rpx;
  margin-bottom: 6rpx;
}

.course-title {
  font-size: 23rpx;
  font-weight: 600;
  color: #1e293b;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  min-height: 56rpx;
}

.course-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 10rpx;
}

.course-price {
  font-size: 28rpx;
  font-weight: 700;
  color: #ef4444;
}

.course-price::before {
  content: '¥';
  font-size: 20rpx;
}

.course-sales {
  font-size: 20rpx;
  color: #94a3b8;
}

/* ==================== 培训班卡片（横向滑动） ==================== */
.class-card {
  width: 193rpx;
  flex-shrink: 0;
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.class-top {
  margin-bottom: 8rpx;
}

.class-name {
  width: 100%;
  font-size: 24rpx;
  font-weight: 600;
  color: #1e293b;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

.class-status-badge {
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  flex-shrink: 0;
}

.class-status-badge.enrolling {
  background: rgba(37, 99, 235, 0.1);
  color: #2563eb;
}

.class-info-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 6rpx;
}

.info-icon {
  font-size: 22rpx;
  flex-shrink: 0;
}

.info-text {
  font-size: 22rpx;
  color: #64748b;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.class-divider {
  height: 1rpx;
  background: #e2e8f0;
  margin: 12rpx 0;
}

.class-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.class-price {
  font-size: 30rpx;
  font-weight: 700;
  color: #ef4444;
}

.class-price::before {
  content: '¥';
  font-size: 22rpx;
}

.class-count {
  font-size: 22rpx;
  color: #64748b;
}

/* ==================== 统计数据（一行横排） ==================== */
.stats-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #2563eb 0%, #4f46e5 100%);
  border-radius: 19rpx;
  padding: 50rpx 12rpx;
  margin: 0;
  box-sizing: border-box;
}

.stat-item {
  text-align: center;
  min-width: 10;
  padding: 0 50rpx;
}

.stat-number {
  font-size: 28rpx;
  font-weight: 800;
  color: #fff;
  display: block;
  letter-spacing: -1rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.stat-label {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
  margin-top: 4rpx;
}

.stat-divider {
  width: 1rpx;
  height: 44rpx;
  background: rgba(255, 255, 255, 0.2);
  flex-shrink: 0;
}

/* ==================== 特色功能卡片 ==================== */
.feature-card {
  width: 135rpx;
  flex-shrink: 0;
  background: #fff;
  border-radius: 14rpx;
  padding: 16rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.feature-icon-box {
  width: 40rpx;
  height: 44rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 10rpx;
}

.feature-icon-box.blue {
  background: linear-gradient(135deg, #dbeafe, #bfdbfe);
}

.feature-icon-box.green {
  background: linear-gradient(135deg, #d1fae5, #a7f3d0);
}

.feature-icon-box.amber {
  background: linear-gradient(135deg, #fef3c7, #fde68a);
}

.feature-icon-box.purple {
  background: linear-gradient(135deg, #e9d5ff, #d8b4fe);
}

.feature-icon-box.red {
  background: linear-gradient(135deg, #fecaca, #fca5a5);
}

.feature-icon {
  font-size: 22rpx;
}

.feature-title {
  font-size: 22rpx;
  font-weight: 600;
  color: #1e293b;
  display: block;
  margin-bottom: 4rpx;
}

.feature-desc {
  font-size: 16rpx;
  color: #64748b;
}

/* ==================== 商品卡片 ==================== */
.product-card {
  width: 170rpx;
  flex-shrink: 0;
  background: #fff;
  border-radius: 14rpx;
  overflow: visible;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
}

.product-cover {
  width: 100%;
  height: 140rpx;
  background: linear-gradient(135deg, #fef3c7, #fef9c3);
}

.product-body {
  padding: 10rpx;
}

.product-name {
  font-size: 22rpx;
  color: #1e293b;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  min-height: 60rpx;
}

.product-price-box {
  margin-top: 6rpx;
}

.product-price {
  font-size: 24rpx;
  font-weight: 700;
  color: #ef4444;
}

.product-price::before {
  content: '¥';
  font-size: 16rpx;
}

.product-sales {
  display: block;
  font-size: 18rpx;
  color: #94a3b8;
  margin-top: 4rpx;
}

/* ==================== 空状态 ==================== */
.empty-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx 32rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.empty-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
  opacity: 0.5;
}

.empty-text {
  color: #94a3b8;
  font-size: 24rpx;
}

/* ==================== 加载状态 ==================== */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-spinner {
  font-size: 48rpx;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16rpx;
  color: #94a3b8;
  font-size: 24rpx;
}

/* ==================== 底部间距 ==================== */
.footer-space {
  height: 32rpx;
}