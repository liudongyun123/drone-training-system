/* pages/index/index.wxss - 首页样式（Web风格） */

/* 页面 */
.page {
  min-height: 100vh;
  background: #f8fafc;
}

/* ==================== Hero 区域（蓝色渐变） ==================== */
.hero {
  position: relative;
  padding: 80rpx 40rpx 60rpx;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: -40rpx;
  background: linear-gradient(135deg, #2563eb 0%, #4f46e5 100%);
  border-radius: 0 0 48rpx 48rpx;
}

/* Logo */
.hero-header {
  position: relative;
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.logo-box {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10rpx);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-icon {
  font-size: 40rpx;
}

.logo-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

/* 标题 */
.hero-title {
  position: relative;
  font-size: 56rpx;
  font-weight: 800;
  color: #fff;
  line-height: 1.2;
  margin-bottom: 12rpx;
}

.hero-title-sub {
  position: relative;
  font-size: 56rpx;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.2;
  margin-bottom: 32rpx;
}

/* 描述 */
.hero-desc {
  position: relative;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.6;
  margin-bottom: 40rpx;
  max-width: 560rpx;
}

/* 按钮 */
.hero-actions {
  position: relative;
  display: flex;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 40rpx;
  background: #fff;
  color: #2563eb;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  font-weight: 600;
  min-width: 200rpx;
  transition: all 0.2s ease;
}

.btn-primary:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.btn-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 40rpx;
  background: transparent;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  color: #fff;
  border-radius: 16rpx;
  font-weight: 600;
  min-width: 200rpx;
  transition: all 0.2s ease;
}

.btn-secondary:active {
  background: rgba(255, 255, 255, 0.1);
}

.btn-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.btn-text {
  font-size: 28rpx;
}

/* 特点标签 */
.hero-features {
  position: relative;
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.feature-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: rgba(255, 255, 255, 0.8);
  font-size: 26rpx;
}

.feature-icon {
  color: #34d399;
  font-size: 28rpx;
}

/* ==================== 内容区域 ==================== */
.content {
  padding: 32rpx;
}

/* 分区 */
.section {
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.section-icon-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.1);
}

.section-icon-box.green {
  background: linear-gradient(135deg, #10b981, #14b8a6);
}

.section-icon-box.amber {
  background: linear-gradient(135deg, #f59e0b, #f97316);
}

.section-icon-box.purple {
  background: linear-gradient(135deg, #8b5cf6, #a855f7);
}

.section-icon {
  font-size: 36rpx;
}

.section-title {
  flex: 1;
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
}

.section-more {
  display: flex;
  align-items: center;
  color: #2563eb;
  font-size: 26rpx;
}

.arrow {
  font-size: 36rpx;
  margin-left: 4rpx;
}

/* 空状态卡片 */
.empty-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  color: #94a3b8;
  font-size: 28rpx;
}

/* ==================== 课程卡片 ==================== */
.course-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.course-card {
  width: calc(50% - 12rpx);
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.course-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.course-cover {
  width: 100%;
  height: 200rpx;
  background: linear-gradient(135deg, #dbeafe, #e0e7ff);
}

.course-body {
  padding: 20rpx;
}

.course-level-badge {
  display: inline-block;
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, #dbeafe, #e0e7ff);
  color: #2563eb;
  font-size: 22rpx;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}

.course-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
  min-height: 78rpx;
}

.course-desc {
  font-size: 24rpx;
  color: #64748b;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-top: 8rpx;
  line-height: 1.4;
}

.course-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.course-price-box {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.course-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #ef4444;
}

.course-price::before {
  content: '¥';
  font-size: 24rpx;
}

.course-original {
  font-size: 24rpx;
  color: #94a3b8;
  text-decoration: line-through;
}

.course-original::before {
  content: '¥';
}

.course-sales {
  font-size: 22rpx;
  color: #94a3b8;
}

/* ==================== 培训班卡片 ==================== */
.class-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.class-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.class-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.class-name {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
}

.class-status-badge {
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
}

.class-status-badge.enrolling {
  background: rgba(37, 99, 235, 0.1);
  color: #2563eb;
}

.class-info-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.info-icon {
  font-size: 28rpx;
}

.info-text {
  font-size: 26rpx;
  color: #64748b;
}

.class-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  margin-top: 16rpx;
  border-top: 1rpx solid #e2e8f0;
}

.class-price-box {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.class-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #ef4444;
}

.class-price::before {
  content: '¥';
  font-size: 26rpx;
}

.class-original {
  font-size: 26rpx;
  color: #94a3b8;
  text-decoration: line-through;
}

.class-original::before {
  content: '¥';
}

.class-count {
  font-size: 26rpx;
  color: #64748b;
}

/* ==================== 商品卡片 ==================== */
.product-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.product-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.product-cover {
  width: 100%;
  height: 180rpx;
  background: linear-gradient(135deg, #fef3c7, #fef9c3);
}

.product-body {
  padding: 16rpx;
}

.product-name {
  font-size: 26rpx;
  color: #1e293b;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.3;
  min-height: 66rpx;
}

.product-price-box {
  margin-top: 12rpx;
}

.product-price {
  font-size: 30rpx;
  font-weight: 700;
  color: #ef4444;
}

.product-price::before {
  content: '¥';
  font-size: 22rpx;
}

.product-sales {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 6rpx;
}

/* 底部间距 */
.footer-space {
  height: 60rpx;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  font-size: 80rpx;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  color: #94a3b8;
  font-size: 28rpx;
}