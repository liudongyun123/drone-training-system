/* pages/index/index.wxss - 首页样式 */

.page {
  min-height: 100vh;
  background: #f5f7fa;
}

/* 顶部区域 */
.header {
  position: relative;
  padding-top: 0;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 320rpx;
  background: linear-gradient(135deg, #1890ff 0%, #40a9ff 100%);
  border-radius: 0 0 40rpx 40rpx;
}

.header-content {
  position: relative;
  z-index: 1;
  padding: 32rpx 24rpx 24rpx;
}

.logo-area {
  margin-bottom: 20rpx;
}

.logo-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 40rpx;
  padding: 20rpx 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-text {
  font-size: 28rpx;
  color: #8c8c8c;
}

/* 内容区域 */
.content {
  padding: 24rpx;
}

/* 分区通用样式 */
.section {
  margin-bottom: 32rpx;
  background: transparent;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

.section-title-wrap {
  display: flex;
  align-items: center;
}

.section-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #262626;
}

.section-more {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #1890ff;
}

.arrow {
  font-size: 32rpx;
  margin-left: 4rpx;
}

.empty-hint {
  text-align: center;
  padding: 60rpx 0;
  color: #8c8c8c;
  font-size: 28rpx;
  background: #fff;
  border-radius: 16rpx;
}

/* 课程横向滚动 */
.course-scroll {
  display: flex;
  overflow-x: auto;
  white-space: nowrap;
  gap: 20rpx;
  padding: 8rpx 0;
  -webkit-overflow-scrolling: touch;
}

.course-scroll::-webkit-scrollbar {
  display: none;
}

.course-card {
  flex-shrink: 0;
  width: 300rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.course-cover {
  width: 100%;
  height: 180rpx;
  background: linear-gradient(135deg, #f0f5ff, #e6f7ff);
}

.course-body {
  padding: 16rpx;
}

.course-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #262626;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: normal;
  min-height: 72rpx;
  line-height: 36rpx;
}

.course-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}

.course-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #ff4d4f;
}

.course-price::before {
  content: '¥';
  font-size: 24rpx;
}

.course-sales {
  font-size: 22rpx;
  color: #8c8c8c;
}

.course-level {
  margin-top: 12rpx;
}

.level-tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  font-size: 20rpx;
  background: linear-gradient(135deg, #f0f5ff, #e6f7ff);
  color: #1890ff;
  border-radius: 4rpx;
}

/* 培训班列表 */
.class-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.class-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.class-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.class-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #262626;
  flex: 1;
}

.class-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(24, 144, 255, 0.1);
  color: #1890ff;
}

.class-info {
  margin-bottom: 16rpx;
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.info-icon {
  font-size: 26rpx;
  margin-right: 8rpx;
}

.info-text {
  font-size: 26rpx;
  color: #595959;
}

.class-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.class-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #ff4d4f;
}

.class-price::before {
  content: '¥';
  font-size: 24rpx;
}

.class-count {
  font-size: 24rpx;
  color: #8c8c8c;
}

/* 商品网格 */
.product-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.product-card {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.product-cover {
  width: 100%;
  height: 200rpx;
  background: linear-gradient(135deg, #fff7e6, #fffbe6);
}

.product-body {
  padding: 12rpx;
}

.product-name {
  font-size: 24rpx;
  color: #262626;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  min-height: 60rpx;
}

.product-price-wrap {
  margin-top: 8rpx;
}

.product-price {
  font-size: 28rpx;
  font-weight: 700;
  color: #ff4d4f;
}

.product-price::before {
  content: '¥';
  font-size: 20rpx;
}

/* 底部间距 */
.footer-space {
  height: 40rpx;
}

/* 标签样式 */
.tag-primary {
  background: rgba(24, 144, 255, 0.1) !important;
  color: #1890ff !important;
}

.tag-success {
  background: rgba(82, 196, 26, 0.1) !important;
  color: #52c41a !important;
}

.tag-warning {
  background: rgba(250, 173, 20, 0.1) !important;
  color: #faad14 !important;
}