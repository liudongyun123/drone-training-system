<!--pages/index/index.wxml - 首页（Web风格）-->

<view class="page">
  <!-- Hero 区域（蓝色渐变背景） -->
  <view class="hero">
    <view class="hero-bg"></view>
    
    <!-- Logo 和标题 -->
    <view class="hero-header">
      <view class="logo-box">
        <text class="logo-icon">🛩️</text>
      </view>
      <text class="logo-text">无人机培训系统</text>
    </view>
    
    <view class="hero-title">专业无人机</view>
    <view class="hero-title-sub">驾驶员培训平台</view>
    
    <view class="hero-desc">
      中国航空运输协会认证培训机构，为学员提供从零基础到专业飞手的完整培训体系
    </view>
    
    <!-- 操作按钮 -->
    <view class="hero-actions">
      <view class="btn-primary" bindtap="goToCourseList">
        <text class="btn-icon">📚</text>
        <text class="btn-text">开始学习</text>
      </view>
      <view class="btn-secondary" bindtap="goToClassList">
        <text class="btn-icon">🎓</text>
        <text class="btn-text">报名培训</text>
      </view>
    </view>
    
    <!-- 特点标签 -->
    <view class="hero-features">
      <view class="feature-tag">
        <text class="feature-icon">✓</text>
        <text>官方认证</text>
      </view>
      <view class="feature-tag">
        <text class="feature-icon">✓</text>
        <text>实操为主</text>
      </view>
      <view class="feature-tag">
        <text class="feature-icon">✓</text>
        <text>推荐就业</text>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <text class="loading-spinner">⏳</text>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 内容区域 -->
  <scroll-view wx:else class="content" scroll-y enable-back-to-top>
    
    <!-- 热门课程 -->
    <view class="section">
      <view class="section-header">
        <view class="section-icon-box green">
          <text class="section-icon">📚</text>
        </view>
        <text class="section-title">热门课程</text>
        <view class="section-more" bindtap="goToCourseList">
          <text>更多</text>
          <text class="arrow">›</text>
        </view>
      </view>
      
      <view wx:if="{{hotCourses.length === 0}}" class="empty-card">
        <text class="empty-icon">📭</text>
        <text class="empty-text">暂无课程，敬请期待</text>
      </view>
      
      <view wx:else class="course-grid">
        <view 
          class="course-card" 
          wx:for="{{hotCourses}}" 
          wx:key="_id"
          bindtap="goToCourse"
          data-id="{{item._id}}"
        >
          <image 
            class="course-cover" 
            src="{{item.coverImage}}" 
            mode="aspectFill"
          />
          <view class="course-body">
            <view class="course-level-badge" wx:if="{{item.level}}">
              <text>{{item.level}}</text>
            </view>
            <text class="course-title">{{item.title}}</text>
            <text class="course-desc">{{item.description}}</text>
            <view class="course-meta">
              <view class="course-price-box">
                <text class="course-price">{{item.price}}</text>
                <text class="course-original" wx:if="{{item.originalPrice}}">{{item.originalPrice}}</text>
              </view>
              <text class="course-sales">{{item.salesCount || 0}}人已学</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 培训班报名 -->
    <view class="section">
      <view class="section-header">
        <view class="section-icon-box amber">
          <text class="section-icon">🎓</text>
        </view>
        <text class="section-title">培训班报名</text>
        <view class="section-more" bindtap="goToClassList">
          <text>更多</text>
          <text class="arrow">›</text>
        </view>
      </view>
      
      <view wx:if="{{enrollingClasses.length === 0}}" class="empty-card">
        <text class="empty-icon">📭</text>
        <text class="empty-text">暂无培训班，敬请期待</text>
      </view>
      
      <view wx:else class="class-list">
        <view 
          class="class-card" 
          wx:for="{{enrollingClasses}}" 
          wx:key="_id"
          bindtap="goToClass"
          data-id="{{item._id}}"
        >
          <view class="class-header">
            <text class="class-name">{{item.name}}</text>
            <view class="class-status-badge enrolling">
              <text>招生中</text>
            </view>
          </view>
          <view class="class-info-row">
            <text class="info-icon">📅</text>
            <text class="info-text">{{item.startDate}} - {{item.endDate}}</text>
          </view>
          <view class="class-info-row" wx:if="{{item.location}}">
            <text class="info-icon">📍</text>
            <text class="info-text">{{item.location}}</text>
          </view>
          <view class="class-footer">
            <view class="class-price-box">
              <text class="class-price">{{item.price}}</text>
              <text class="class-original" wx:if="{{item.originalPrice}}">{{item.originalPrice}}</text>
            </view>
            <text class="class-count">{{item.enrolledCount || 0}}/{{item.maxStudents}}人</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 配件商城 -->
    <view class="section">
      <view class="section-header">
        <view class="section-icon-box purple">
          <text class="section-icon">🛒</text>
        </view>
        <text class="section-title">配件商城</text>
        <view class="section-more" bindtap="goToShop">
          <text>更多</text>
          <text class="arrow">›</text>
        </view>
      </view>
      
      <view wx:if="{{featuredProducts.length === 0}}" class="empty-card">
        <text class="empty-icon">📭</text>
        <text class="empty-text">暂无商品，敬请期待</text>
      </view>
      
      <view wx:else class="product-grid">
        <view 
          class="product-card" 
          wx:for="{{featuredProducts}}" 
          wx:key="_id"
          bindtap="goToProduct"
          data-id="{{item._id}}"
        >
          <image 
            class="product-cover" 
            src="{{item.coverImage}}" 
            mode="aspectFill"
          />
          <view class="product-body">
            <text class="product-name">{{item.name}}</text>
            <view class="product-price-box">
              <text class="product-price">{{item.price}}</text>
            </view>
            <text class="product-sales">{{item.salesCount || 0}}人购买</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 底部间距 -->
    <view class="footer-space"></view>
  </scroll-view>
</view>