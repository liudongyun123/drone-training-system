<!--pages/index/index.wxml - 首页（小程序适配版）-->

<view class="page">
  <!-- ==================== Hero 区域（三块布局） ==================== -->
  <view class="hero-section">
    <!-- 顶部左侧：文字内容 -->
    <view class="hero-top">
      <!-- 左侧：文字 -->
      <view class="hero-left">
        <!-- Logo -->
        <view class="hero-logo">
          <image class="logo-img" src="../../assets/icons/logo.png" mode="aspectFit"/>
        </view>
        
        <!-- 标题 -->
        <view class="hero-title">
          <text class="title-main">翱翔蓝天</text>
          <text class="title-sub">成就飞行梦想</text>
        </view>
        
        <!-- 按钮 -->
        <view class="hero-actions">
          <view class="btn-primary" bindtap="goToCourseList">
            <text class="btn-icon">📚</text>
            <text class="btn-text">查看课程</text>
          </view>
          <view class="btn-secondary" bindtap="goToClassList">
            <text class="btn-icon">▶️</text>
            <text class="btn-text">预约试听</text>
          </view>
        </view>
        
        <!-- 信任标签 -->
        <view class="hero-badges">
          <view class="badge-item">
            <text class="badge-icon">✓</text>
            <text class="badge-text">官方认证</text>
          </view>
          <view class="badge-item">
            <text class="badge-icon">✓</text>
            <text class="badge-text">实操为主</text>
          </view>
          <view class="badge-item">
            <text class="badge-icon">✓</text>
            <text class="badge-text">推荐就业</text>
          </view>
        </view>
      </view>
      
      <!-- 右侧：轮播图 -->
      <view class="hero-right">
        <swiper 
          class="hero-swiper" 
          indicator-dots="{{heroBanners.length > 1}}"
          autoplay="{{heroBanners.length > 1}}" 
          interval="5000" 
          circular
          indicator-active-color="#ffffff"
          wx:if="{{heroBanners.length > 0}}"
        >
          <swiper-item wx:for="{{heroBanners}}" wx:key="_id">
            <image 
              class="hero-banner-image" 
              src="{{item.image}}" 
              mode="aspectFill"
              bindtap="onBannerTap"
              data-banner="{{item}}"
            />
          </swiper-item>
        </swiper>
        <!-- 默认占位图 -->
        <image 
          wx:if="{{heroBanners.length === 0}}"
          class="hero-banner-image" 
          src="https://picsum.photos/400/300?random=1" 
          mode="aspectFill"
        />
      </view>
    </view>
    
    <!-- 底部：描述 -->
    <view class="hero-bottom">
      <text class="hero-desc">零基础到专业飞手的完整培训体系，涵盖植保，航拍，巡检等</text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <text class="loading-spinner">⏳</text>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 内容区域 -->
  <scroll-view wx:else class="content" scroll-y enable-back-to-top>
    
    <!-- ==================== 体系切换 Tab（动态渲染） ==================== -->
    <view class="source-tabs">
      <view 
        class="source-tab {{currentSource === item.key ? 'active' : ''}}"
        wx:for="{{sourceList}}"
        wx:key="key"
        bindtap="switchSource"
        data-source="{{item.key}}"
      >
        <text class="source-icon">{{item.icon}}</text>
        <text class="source-name">{{item.name}}</text>
      </view>
    </view>

    <!-- ==================== 学习路径（横向滑动） ==================== -->
    <view class="section">
      <view class="section-header">
        <view class="section-icon-box green">
          <text class="section-icon">🗺️</text>
        </view>
        <view class="section-title-wrap">
          <text class="section-title">学习路径</text>
          <text class="section-subtitle">系统化学习体验</text>
        </view>
      </view>

      <view wx:if="{{learningPaths.length === 0}}" class="empty-card">
        <text class="empty-icon">📭</text>
        <text class="empty-text">暂无学习路径</text>
      </view>

      <scroll-view wx:else class="scroll-x" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="paths-scroll">
          <view
            class="path-card"
            wx:for="{{learningPaths}}"
            wx:key="_id"
            catchtap="goToPath"
            data-path="{{item}}"
          >
            <view class="path-icon-box blue">
              <text class="path-icon">{{item.icon}}</text>
            </view>
            <text class="path-name">{{item.name}}</text>
            <text class="path-desc">{{learningPathLevelCount}}级进阶体系</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- ==================== 热门课程（横向滑动卡片） ==================== -->
    <view class="section">
      <view class="section-header">
        <view class="section-icon-box blue">
          <text class="section-icon">📚</text>
        </view>
        <view class="section-title-wrap">
          <text class="section-title">热门课程</text>
          <text class="section-subtitle">精选优质内容</text>
        </view>
        <view class="section-more" catchtap="goToCourseList">
          <text>更多</text>
          <text class="arrow">›</text>
        </view>
      </view>
      
      <view wx:if="{{hotCourses.length === 0}}" class="empty-card">
        <text class="empty-icon">📭</text>
        <text class="empty-text">暂无课程，敬请期待</text>
      </view>
      
      <scroll-view wx:else class="scroll-x" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="course-scroll">
          <view 
            class="course-card" 
            wx:for="{{hotCourses}}" 
            wx:key="_id"
            bindtap="goToCourse"
            data-id="{{item._id}}"
          >
            <image 
              class="course-cover"
              src="{{item.coverImage || item.cover}}" 
              mode="aspectFill"
            />
            <view class="course-body">
              <view class="course-level-badge" wx:if="{{item.levelText}}">
                <text>{{item.levelText}}</text>
              </view>
              <text class="course-title">{{item.title}}</text>
              <view class="course-meta">
                <text class="course-price">{{item.price}}</text>
                <text class="course-sales">{{item.salesCount || 0}}人已学</text>
              </view>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- ==================== 培训班报名（竖向滑动卡片） ==================== -->
    <view class="section">
      <view class="section-header">
        <view class="section-icon-box amber">
          <text class="section-icon">🎓</text>
        </view>
        <view class="section-title-wrap">
          <text class="section-title">培训班报名</text>
          <text class="section-subtitle">线下实操培训</text>
        </view>
        <view class="section-more" bindtap="goToClassList">
          <text>更多</text>
          <text class="arrow">›</text>
        </view>
      </view>
      
      <view wx:if="{{enrollingClasses.length === 0}}" class="empty-card">
        <text class="empty-icon">📭</text>
        <text class="empty-text">暂无培训班，敬请期待</text>
      </view>
      
      <scroll-view wx:else class="scroll-x" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="class-scroll">
          <view 
            class="class-card" 
            wx:for="{{enrollingClasses}}" 
            wx:key="_id"
            bindtap="goToClass"
            data-id="{{item._id}}"
          >
            <view class="class-top">
              <text class="class-level-badge" wx:if="{{item.levelText}}">{{item.levelText}}</text>
              <text class="class-name">{{item.name}}</text>
            </view>
            <view class="class-status-badge enrolling">
              <text>招生中</text>
            </view>
            <view class="class-info-row">
              <text class="info-icon">📅</text>
              <text class="info-text">{{item.startDate}}</text>
            </view>
            <view class="class-info-row" wx:if="{{item.location}}">
              <text class="info-icon">📍</text>
              <text class="info-text">{{item.location}}</text>
            </view>
            <view class="class-divider"></view>
            <view class="class-bottom">
              <text class="class-price">{{item.price || '待定'}}</text>
              <text class="class-count">{{item.enrolledStudents || 0}}/{{item.maxStudents}}人</text>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- ==================== 统计数据 ==================== -->
    <view class="section">
      <view class="stats-bar">
        <view class="stat-item">
          <text class="stat-number">500+</text>
          <text class="stat-label">培训学员</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-number">98%</text>
          <text class="stat-label">通过率</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-number">50+</text>
          <text class="stat-label">合作企业</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-number">10年</text>
          <text class="stat-label">培训经验</text>
        </view>
      </view>
    </view>

    <!-- ==================== 特色功能（横向滑动） ==================== -->
    <view class="section">
      <view class="section-header">
        <view class="section-icon-box blue">
          <text class="section-icon">⭐</text>
        </view>
        <text class="section-title">为什么选择我们</text>
      </view>
      
      <scroll-view class="scroll-x" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="features-scroll">
          <view class="feature-card">
            <view class="feature-icon-box blue">
              <text class="feature-icon">🏆</text>
            </view>
            <text class="feature-title">官方认证</text>
            <text class="feature-desc">航空协会认证培训机构</text>
          </view>
          <view class="feature-card">
            <view class="feature-icon-box green">
              <text class="feature-icon">👨‍🏫</text>
            </view>
            <text class="feature-title">资深教官</text>
            <text class="feature-desc">AOPA认证，10年经验</text>
          </view>
          <view class="feature-card">
            <view class="feature-icon-box amber">
              <text class="feature-icon">✈️</text>
            </view>
            <text class="feature-title">实操为主</text>
            <text class="feature-desc">70%实操训练</text>
          </view>
          <view class="feature-card">
            <view class="feature-icon-box purple">
              <text class="feature-icon">💼</text>
            </view>
            <text class="feature-title">推荐就业</text>
            <text class="feature-desc">合作企业优先录用</text>
          </view>
          <view class="feature-card">
            <view class="feature-icon-box red">
              <text class="feature-icon">📱</text>
            </view>
            <text class="feature-title">线上学习</text>
            <text class="feature-desc">随时随地学理论</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- ==================== 配件商城（横向滑动） ==================== -->
    <view class="section">
      <view class="section-header">
        <view class="section-icon-box purple">
          <text class="section-icon">🛒</text>
        </view>
        <view class="section-title-wrap">
          <text class="section-title">配件商城</text>
          <text class="section-subtitle">正品保障</text>
        </view>
        <view class="section-more" catchtap="goToShop">
          <text>更多</text>
          <text class="arrow">›</text>
        </view>
      </view>
      
      <view wx:if="{{featuredProducts.length === 0}}" class="empty-card">
        <text class="empty-icon">📭</text>
        <text class="empty-text">暂无商品，敬请期待</text>
      </view>
      
      <scroll-view wx:else class="scroll-x" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="product-scroll">
          <view 
            class="product-card" 
            wx:for="{{featuredProducts}}" 
            wx:key="_id"
            bindtap="goToProduct"
            data-id="{{item._id}}"
          >
            <image 
              class="product-cover"
              src="{{item.coverImage || item.cover}}" 
              mode="aspectFill"
            />
            <view class="product-body">
              <text class="product-name">{{item.name}}</text>
              <view class="product-price-box">
                <text class="product-price">{{item.price}}</text>
              </view>
              <text class="product-sales">{{item.salesCount || 0}}人购买</text>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 底部间距 -->
    <view class="footer-space"></view>
  </scroll-view>
</view>