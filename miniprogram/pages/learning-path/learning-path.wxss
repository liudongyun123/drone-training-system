/* pages/learning-path/learning-path.wxss */

.page {
  min-height: 100vh;
  background: #f5f5f5;
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  font-size: 60rpx;
  animation: rotate 1s linear infinite;
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #999;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 学习路径头部 */
.path-header {
  display: flex;
  align-items: center;
  padding: 40rpx 30rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  color: white;
}

.path-icon-large {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.icon-text {
  font-size: 50rpx;
}

.path-info {
  flex: 1;
}

.path-title {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
}

.path-subtitle {
  font-size: 24rpx;
  opacity: 0.9;
  margin-top: 8rpx;
  display: block;
}

/* 等级进度指示器 */
.level-progress {
  background: white;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.progress-track {
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  padding: 0 20rpx;
}

.progress-step {
  display: flex;
  align-items: center;
  position: relative;
  z-index: 1;
}

.step-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #ddd;
  border: 4rpx solid #fff;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.1);
}

.progress-step.active .step-dot {
  background: #4CAF50;
  border-color: #4CAF50;
}

.step-line {
  position: absolute;
  top: 12rpx;
  left: 24rpx;
  width: calc(100% - 24rpx);
  height: 4rpx;
  background: #ddd;
}

.progress-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 16rpx;
  padding: 0 10rpx;
}

.progress-label {
  font-size: 22rpx;
  color: #666;
  text-align: center;
  flex: 1;
}

/* 学习阶段列表 */
.stages-container {
  padding: 0 20rpx 40rpx;
}

.stage-section {
  background: white;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.stage-header {
  display: flex;
  align-items: center;
  padding: 24rpx 24rpx 16rpx;
}

.stage-level-badge {
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: bold;
  color: white;
}

.stage-level-badge.level-0 { background: linear-gradient(135deg, #4CAF50, #66BB6A); }
.stage-level-badge.level-1 { background: linear-gradient(135deg, #2196F3, #42A5F5); }
.stage-level-badge.level-2 { background: linear-gradient(135deg, #FF9800, #FFB74D); }
.stage-level-badge.level-3 { background: linear-gradient(135deg, #F44336, #EF5350); }
.stage-level-badge.level-4 { background: linear-gradient(135deg, #9C27B0, #BA68C8); }

.stage-divider {
  flex: 1;
  height: 2rpx;
  background: #eee;
  margin-left: 20rpx;
}

/* 子区域标题 */
.section-sub {
  padding: 0 24rpx 24rpx;
}

.sub-header {
  margin-bottom: 16rpx;
}

.sub-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

/* 课程列表 */
.course-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.course-item {
  display: flex;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 16rpx;
  gap: 16rpx;
}

.course-cover {
  width: 160rpx;
  height: 100rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.course-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.course-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.course-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 8rpx;
}

.course-price {
  font-size: 28rpx;
  color: #ff6b6b;
  font-weight: bold;
}

.course-sales {
  font-size: 22rpx;
  color: #999;
}

/* 培训班列表 */
.class-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.class-item {
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx;
  border-left: 6rpx solid #4CAF50;
}

.class-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.class-level-badge {
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  color: white;
  background: #4CAF50;
}

.class-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.class-status-badge.enrolling {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  color: white;
  background: #ff9800;
  margin-bottom: 12rpx;
}

.class-details {
  margin-bottom: 12rpx;
}

.detail-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 6rpx;
}

.detail-icon {
  font-size: 24rpx;
}

.detail-text {
  font-size: 24rpx;
  color: #666;
}

.class-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1rpx solid #eee;
  padding-top: 12rpx;
}

.class-price {
  font-size: 30rpx;
  color: #ff6b6b;
  font-weight: bold;
}

.class-count {
  font-size: 24rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}