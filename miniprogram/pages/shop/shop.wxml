<!--pages/shop/shop.wxml-->
<view class="page">
  <!-- 分类栏 -->
  <scroll-view class="category-bar" scroll-x>
    <view 
      class="category-item {{currentCategory === item._id ? 'active' : ''}}"
      wx:for="{{categories}}"
      wx:key="_id"
      bindtap="switchCategory"
      data-id="{{item._id}}"
    >
      {{item.name}}
    </view>
  </scroll-view>

  <!-- 商品网格 -->
  <view class="product-grid">
    <view 
      class="product-card" 
      wx:for="{{products}}" 
      wx:key="_id"
      bindtap="goToDetail"
      data-id="{{item._id}}"
    >
      <image class="product-cover" src="{{item.coverImage}}" mode="aspectFill" />
      <view class="product-info">
        <text class="product-name">{{item.name}}</text>
        <view class="product-bottom">
          <view class="product-price">
            <text class="price-symbol">¥</text>
            <text class="price-num">{{item.price}}</text>
          </view>
          <text class="product-sales">{{item.salesCount}}已售</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="load-more">
    <text wx:if="{{loading}}">加载中...</text>
    <text wx:elif="{{!hasMore && products.length > 0}}">— 没有更多了 —</text>
  </view>

  <!-- 购物车浮动按钮 -->
  <view class="cart-fab" bindtap="goToCart">
    <text class="cart-icon">🛒</text>
  </view>
</view>