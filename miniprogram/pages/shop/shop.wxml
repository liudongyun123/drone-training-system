<!--pages/shop/shop.wxml-->
<view class="page">
  <!-- 分类导航 -->
  <scroll-view class="category-bar" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="category-scroll">
      <view 
        class="category-item {{currentCategory === item._id ? 'active' : ''}}"
        wx:for="{{categories}}"
        wx:key="_id"
        bindtap="switchCategory"
        data-id="{{item._id}}"
      >
        {{item.name}}
      </view>
    </view>
  </scroll-view>

  <!-- 商品网格 -->
  <view class="product-grid">
    <view 
      class="product-card" 
      wx:for="{{products}}" 
      wx:key="_id"
    >
      <view class="product-card-inner" bindtap="goToDetail" data-id="{{item._id}}">
        <view class="product-cover"></view>
        <view class="product-info">
          <text class="product-name">{{item.name}}</text>
          <view class="product-bottom">
            <view class="product-price">
              <text class="price-symbol">¥</text>
              <text class="price-num">{{item.price}}</text>
            </view>
            <text class="product-sales">{{item.salesCount}}已售</text>
          </view>
          <button class="add-cart-btn" catchtap="addToCart" data-product="{{item}}">加入购物车</button>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="load-more">
    <text wx:if="{{loading}}">加载中...</text>
    <text wx:elif="{{!hasMore && products.length > 0}}">— 没有更多了 —</text>
    <text wx:elif="{{products.length === 0 && !loading}}">暂无商品</text>
  </view>

  <!-- 购物车浮动按钮 -->
  <view class="cart-fab" bindtap="goToCart">
    <text class="cart-icon">🛒</text>
  </view>
</view>
