/* pages/shop/shop.wxss */

.page {
  min-height: 100vh;
  background-color: #f1f5f9;
}

/* 分类导航 */
.category-bar {
  background-color: #fff;
  border-bottom: 1rpx solid #e2e8f0;
  white-space: nowrap;
}

.category-scroll {
  display: inline-flex;
  padding: 16rpx 24rpx;
}

.category-item {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  font-size: 26rpx;
  color: #64748b;
  background-color: #f1f5f9;
  border-radius: 32rpx;
  white-space: nowrap;
}

.category-item.active {
  color: #fff;
  background: linear-gradient(135deg, #2563eb, #3b82f6);
}

/* 商品网格 */
.product-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 16rpx;
}

.product-card {
  width: 50%;
  box-sizing: border-box;
  padding: 8rpx;
}

.product-card-inner {
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  height: 100%;
}

.product-cover {
  width: 100%;
  height: 320rpx;
  background: linear-gradient(135deg, #dbeafe, #e0e7ff);
}

.product-info {
  padding: 16rpx;
}

.product-name {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  font-size: 26rpx;
  color: #1e293b;
  line-height: 1.4;
}

.product-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.product-price {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 22rpx;
  color: #ef4444;
}

.price-num {
  font-size: 30rpx;
  font-weight: 700;
  color: #ef4444;
}

.product-sales {
  font-size: 20rpx;
  color: #94a3b8;
}

.add-cart-btn {
  width: 100%;
  height: 56rpx;
  margin-top: 12rpx;
  line-height: 56rpx;
  font-size: 24rpx;
  color: #fff;
  background: linear-gradient(135deg, #2563eb, #3b82f6);
  border-radius: 28rpx;
  border: none;
}

/* 加载状态 */
.load-more {
  padding: 24rpx;
  text-align: center;
  font-size: 24rpx;
  color: #94a3b8;
}

/* 底部购物车浮动按钮 */
.cart-fab {
  position: fixed;
  right: 24rpx;
  bottom: 180rpx;
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #2563eb, #3b82f6);
  border-radius: 50%;
  box-shadow: 0 4rpx 16rpx rgba(37, 99, 235, 0.4);
}

.cart-icon {
  font-size: 48rpx;
}
