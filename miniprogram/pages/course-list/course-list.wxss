/* pages/course-list/course-list.wxss */

.page {
  min-height: 100vh;
  background: #f1f5f9;
}

/* ==================== 搜索框 ==================== */
.search-box {
  padding: 16rpx 24rpx;
  background: #fff;
}

.search-input {
  display: flex;
  align-items: center;
  background: #f1f5f9;
  border-radius: 32rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-placeholder {
  font-size: 26rpx;
  color: #94a3b8;
}

/* ==================== 分类筛选 ==================== */
.category-bar {
  background: #fff;
  border-bottom: 1rpx solid #e2e8f0;
}

.category-scroll {
  display: flex;
  flex-wrap: nowrap;
  padding: 16rpx 24rpx;
  gap: 16rpx;
}

.category-item {
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  color: #64748b;
  border-radius: 32rpx;
  background: #f1f5f9;
  white-space: nowrap;
  flex-shrink: 0;
}

.category-item.active {
  background: linear-gradient(135deg, #2563eb, #3b82f6);
  color: #fff;
  font-weight: 500;
}

/* ==================== 排序选项 ==================== */
.sort-bar {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: #fff;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #e2e8f0;
}

.sort-item {
  display: flex;
  align-items: center;
  padding: 8rpx 24rpx;
  font-size: 26rpx;
  color: #64748b;
}

.sort-item.active {
  color: #2563eb;
  font-weight: 600;
}

.sort-arrow {
  font-size: 20rpx;
  margin-left: 6rpx;
}

/* ==================== 课程列表 ==================== */
.course-scroll {
  height: calc(100vh - 200rpx);
}

.course-list {
  padding: 16rpx 24rpx;
}

.course-card {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.course-cover {
  width: 200rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #dbeafe, #e0e7ff);
}

.course-info {
  flex: 1;
  padding: 12rpx 16rpx;
}

.course-level-row {
  margin-bottom: 8rpx;
}

.course-level {
  display: inline-block;
  padding: 4rpx 12rpx;
  background: linear-gradient(135deg, #dbeafe, #bfdbfe);
  color: #2563eb;
  font-size: 20rpx;
  border-radius: 6rpx;
}

.course-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1e293b;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.course-desc {
  font-size: 22rpx;
  color: #64748b;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-top: 6rpx;
}

.course-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}

.price {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 20rpx;
  color: #ef4444;
}

.price-num {
  font-size: 28rpx;
  font-weight: 700;
  color: #ef4444;
}

.students {
  font-size: 20rpx;
  color: #94a3b8;
}

/* ==================== 加载状态 ==================== */
.load-more {
  text-align: center;
  padding: 24rpx;
}

.loading-text {
  color: #94a3b8;
  font-size: 24rpx;
}

.end-text {
  color: #94a3b8;
  font-size: 22rpx;
}

/* ==================== 空状态 ==================== */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
  opacity: 0.5;
}

.empty-text {
  color: #94a3b8;
  font-size: 26rpx;
}

/* ==================== 底部间距 ==================== */
.footer-space {
  height: 32rpx;
}