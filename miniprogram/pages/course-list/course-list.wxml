<!--pages/course-list/course-list.wxml-->

<view class="page">
  <!-- 搜索框 -->
  <view class="search-box">
    <view class="search-input" bindtap="goToSearch">
      <text class="search-icon">🔍</text>
      <text class="search-placeholder">{{searchKeyword || '搜索课程...'}}</text>
    </view>
  </view>

  <!-- 体系切换 Tab（动态渲染） -->
  <view class="source-tabs">
    <view 
      class="source-tab {{currentSource === item.key ? 'active' : ''}}"
      wx:for="{{sourceList}}"
      wx:key="key"
      bindtap="switchSource"
      data-source="{{item.key}}"
    >
      <text class="source-icon">{{item.icon}}</text>
      <text class="source-name">{{item.name}}</text>
    </view>
  </view>

  <!-- 分类筛选 -->
  <scroll-view class="category-bar" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="category-scroll">
      <view 
        class="category-item {{currentCategoryId === item.id ? 'active' : ''}}"
        wx:for="{{categories}}"
        wx:key="id"
        bindtap="switchCategory"
        data-categoryid="{{item.id}}"
        data-category="{{item.name}}"
      >
        {{item.name}}
      </view>
    </view>
  </scroll-view>

  <!-- 排序选项 -->
  <view class="sort-bar">
    <view class="sort-item {{currentSort === 'newest' ? 'active' : ''}}" bindtap="switchSort" data-sort="newest">
      <text>最新</text>
      <text class="sort-arrow" wx:if="{{currentSort === 'newest'}}">↓</text>
    </view>
    <view class="sort-item {{currentSort === 'hot' ? 'active' : ''}}" bindtap="switchSort" data-sort="hot">
      <text>最热</text>
      <text class="sort-arrow" wx:if="{{currentSort === 'hot'}}">↓</text>
    </view>
    <view class="sort-item {{currentSort === 'price_asc' ? 'active' : ''}}" bindtap="switchSort" data-sort="price_asc">
      <text>价格</text>
      <text class="sort-arrow">↑</text>
    </view>
    <view class="sort-item {{currentSort === 'price_desc' ? 'active' : ''}}" bindtap="switchSort" data-sort="price_desc">
      <text>价格</text>
      <text class="sort-arrow">↓</text>
    </view>
  </view>

  <!-- 课程列表 -->
  <scroll-view class="course-scroll" scroll-y enhanced enable-back-to-top>
    <view class="course-list">
      <view 
        class="course-card" 
        wx:for="{{courses}}" 
        wx:key="_id"
        bindtap="goToDetail"
        data-id="{{item._id}}"
      >
        <image 
          class="course-cover" 
          src="{{item.coverImage || item.cover}}" 
          mode="aspectFill"
          binderror="onImageError"
          data-index="{{index}}"
        />
        <view class="course-info">
          <view class="course-level-row" wx:if="{{item.levelText}}">
            <text class="course-level">{{item.levelText}}</text>
          </view>
          <text class="course-title">{{item.title}}</text>
          <text class="course-desc">{{item.description}}</text>
          <view class="course-footer">
            <view class="price">
              <text class="price-symbol">¥</text>
              <text class="price-num">{{item.price}}</text>
            </view>
            <text class="students">{{item.salesCount || 0}}人已学</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 加载状态 -->
    <view class="load-more">
      <text wx:if="{{loading}}" class="loading-text">加载中...</text>
      <text wx:elif="{{!hasMore && courses.length > 0}}" class="end-text">— 没有更多了 —</text>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{!loading && courses.length === 0}}" class="empty-container">
      <text class="empty-icon">📭</text>
      <text class="empty-text">暂无相关课程</text>
    </view>

    <!-- 底部间距 -->
    <view class="footer-space"></view>
  </scroll-view>
</view>