/* pages/transfer-request/transfer-request.wxss */
/* 调课申请页面样式 */

.page {
  min-height: 100vh;
  background: #f5f6fa;
}

/* 未登录状态 */
.login-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
}

.prompt-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.prompt-icon {
  font-size: 80rpx;
}

.prompt-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 16rpx;
}

.prompt-desc {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  margin-bottom: 60rpx;
}

.prompt-btn {
  padding: 24rpx 80rpx;
  background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
  color: #fff;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 500;
}

/* 顶部标题栏 */
.header-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.header-left {
  display: flex;
  align-items: center;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 28rpx;
  background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
  color: #fff;
  border-radius: 40rpx;
  font-size: 26rpx;
}

.add-icon {
  font-size: 32rpx;
  font-weight: bold;
}

/* Tab 栏 */
.tab-bar {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  position: relative;
}

.tab-name {
  font-size: 30rpx;
  color: #999;
}

.tab-item.active .tab-name {
  color: #2563eb;
  font-weight: 600;
}

.tab-line {
  position: absolute;
  bottom: 0;
  width: 60rpx;
  height: 6rpx;
  background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
  border-radius: 3rpx;
}

/* 统计卡片 */
.stats-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 24rpx;
  padding: 32rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #eee;
}

/* 列表滚动区域 */
.list-scroll {
  height: calc(100vh - 300rpx);
  padding: 0 24rpx;
}

/* 申请卡片 */
.request-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.type-tag {
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-tag {
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.card-time {
  font-size: 24rpx;
  color: #999;
}

/* 课程区域 */
.course-section {
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.course-section.original {
  background: #fef2f2;
}

.course-section.target {
  background: #f0fdf4;
}

.section-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.section-label text::before {
  content: '● ';
  color: #ccc;
}

.course-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.course-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.course-detail {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 8rpx;
}

.detail-item {
  font-size: 26rpx;
  color: #666;
}

/* 原因区域 */
.reason-section {
  padding: 20rpx;
  background: #f9fafb;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.reason-label {
  font-size: 26rpx;
  color: #999;
}

.reason-text {
  font-size: 28rpx;
  color: #333;
}

/* 回复区域 */
.reply-section {
  padding: 20rpx;
  background: #fffbeb;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.reply-label {
  font-size: 26rpx;
  color: #b45309;
}

.reply-text {
  font-size: 28rpx;
  color: #333;
  margin-top: 8rpx;
  display: block;
}

/* 卡片底部按钮 */
.card-footer {
  display: flex;
  gap: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.btn-detail {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  background: #f3f4f6;
  color: #666;
  border-radius: 16rpx;
  font-size: 28rpx;
}

.btn-cancel {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  background: #fee2e2;
  color: #ef4444;
  border-radius: 16rpx;
  font-size: 28rpx;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  font-size: 64rpx;
  animation: spin 1s linear infinite;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
  margin-top: 20rpx;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 空状态 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  background: #f3f4f6;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.empty-btn {
  padding: 24rpx 60rpx;
  background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
  color: #fff;
  border-radius: 50rpx;
  font-size: 28rpx;
}

.list-footer {
  text-align: center;
  padding: 40rpx 0;
  font-size: 26rpx;
  color: #999;
}

/* 步骤指示器 */
.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 32rpx;
  background: #fff;
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-dot {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #e5e7eb;
  color: #999;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.step-item.active .step-dot {
  background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
  color: #fff;
}

.step-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

.step-item.active .step-label {
  color: #2563eb;
  font-weight: 500;
}

.step-line {
  width: 100rpx;
  height: 4rpx;
  background: #e5e7eb;
  margin: 0 20rpx;
  margin-bottom: 40rpx;
}

.step-line.active {
  background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
}

/* 步骤内容 */
.step-content {
  padding: 0 32rpx;
}

.step-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 24rpx;
}

.step-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 32rpx;
  line-height: 1.6;
}

/* 表单区块 */
.form-section {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}

.required {
  color: #ef4444;
}

/* 类型选择网格 */
.type-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.type-item {
  padding: 24rpx;
  text-align: center;
  background: #f3f4f6;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #666;
}

/* 文本域 */
.form-textarea {
  width: 100%;
  padding: 24rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  min-height: 200rpx;
}

.form-textarea.short {
  min-height: 120rpx;
}

/* 空卡片 */
.empty-card {
  padding: 60rpx 40rpx;
  background: #fff;
  border-radius: 24rpx;
  text-align: center;
  margin-bottom: 32rpx;
}

.empty-card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}

.empty-card-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 32rpx;
}

.btn-retry {
  padding: 20rpx 48rpx;
  background: #f3f4f6;
  color: #666;
  border-radius: 40rpx;
  font-size: 28rpx;
  display: inline-block;
}

/* 排课列表 */
.schedule-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.schedule-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx;
  background: #fff;
  border-radius: 20rpx;
  border: 2rpx solid transparent;
}

.schedule-card.selected {
  border-color: #2563eb;
  background: #eff6ff;
}

.schedule-main {
  flex: 1;
}

.schedule-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  display: block;
  margin-bottom: 12rpx;
}

.schedule-detail {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.schedule-arrow {
  font-size: 40rpx;
  color: #ccc;
  margin-left: 20rpx;
}

.schedule-check {
  width: 48rpx;
  height: 48rpx;
  background: #2563eb;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

/* 目标选项 */
.target-option {
  padding: 32rpx;
  text-align: center;
  background: #fff;
  border: 2rpx solid #e5e7eb;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 24rpx;
}

.target-option.active {
  border-color: #2563eb;
  background: #eff6ff;
  color: #2563eb;
  font-weight: 500;
}

.target-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  max-height: 600rpx;
  overflow-y: auto;
}

/* 表单操作按钮 */
.form-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 40rpx;
}

.btn-prev {
  flex: 1;
  padding: 28rpx;
  text-align: center;
  background: #f3f4f6;
  color: #666;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.btn-next {
  flex: 1;
  padding: 28rpx;
  text-align: center;
  background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
  color: #fff;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.btn-submit {
  flex: 1;
  padding: 28rpx;
  text-align: center;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: #fff;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.btn-submit.loading {
  opacity: 0.7;
}

.btn-cancel-form {
  text-align: center;
  padding: 32rpx;
  color: #999;
  font-size: 28rpx;
}

/* 详情弹窗 */
.detail-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  width: 100%;
  max-height: 85vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  background: #f3f4f6;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #666;
}

.modal-body {
  flex: 1;
  padding: 32rpx;
  overflow-y: auto;
}

.modal-tags {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.detail-section {
  margin-bottom: 28rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #999;
  margin-bottom: 16rpx;
  display: block;
}

.detail-card {
  padding: 24rpx;
  background: #f9fafb;
  border-radius: 16rpx;
}

.detail-card.original {
  background: #fef2f2;
}

.detail-card.target {
  background: #f0fdf4;
}

.detail-course-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  display: block;
  margin-bottom: 16rpx;
}

.detail-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  font-size: 26rpx;
  color: #666;
}

.detail-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.review-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.review-time {
  font-size: 24rpx;
  color: #999;
}

.review-reply {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-top: 8rpx;
}

.detail-time {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.modal-footer {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #eee;
}

.btn-modal-close {
  width: 100%;
  padding: 28rpx;
  text-align: center;
  background: #f3f4f6;
  color: #333;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 500;
}
