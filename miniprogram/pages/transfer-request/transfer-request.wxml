<!--pages/transfer-request/transfer-request.wxml-->
<!-- 调课申请页面 -->

<view class="page">
  <!-- 未登录状态 -->
  <view wx:if="{{!isLoggedIn}}" class="login-prompt">
    <view class="prompt-icon-wrap">
      <text class="prompt-icon">🔄</text>
    </view>
    <text class="prompt-title">登录后使用调课服务</text>
    <text class="prompt-desc">灵活调整课程时间，让学习更自由</text>
    <view class="prompt-btn" bindtap="goToLogin">
      <text>立即登录</text>
    </view>
  </view>

  <block wx:else>
    <!-- 顶部标题栏 -->
    <view class="header-bar">
      <view class="header-left">
        <text class="header-title">调课申请</text>
      </view>
      <view class="header-right" bindtap="switchTab" data-tab="create">
        <text class="add-icon">+</text>
        <text>新建申请</text>
      </view>
    </view>

    <!-- Tab 切换 -->
    <view class="tab-bar">
      <view 
        class="tab-item {{activeTab === 'list' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="list"
      >
        <text class="tab-name">我的申请</text>
        <view class="tab-line" wx:if="{{activeTab === 'list'}}"></view>
      </view>
      <view 
        class="tab-item {{activeTab === 'create' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="create"
      >
        <text class="tab-name">新建申请</text>
        <view class="tab-line" wx:if="{{activeTab === 'create'}}"></view>
      </view>
    </view>

    <!-- 列表视图 -->
    <block wx:if="{{activeTab === 'list'}}">
      <!-- 统计卡片 -->
      <view wx:if="{{stats}}" class="stats-card">
        <view class="stat-item">
          <text class="stat-num" style="color: #f59e0b">{{stats.pending || 0}}</text>
          <text class="stat-label">待审核</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-num" style="color: #10b981">{{stats.approved || 0}}</text>
          <text class="stat-label">已通过</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-num" style="color: #ef4444">{{stats.rejected || 0}}</text>
          <text class="stat-label">已拒绝</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-num" style="color: #2563eb">{{stats.approvalRate || 0}}%</text>
          <text class="stat-label">通过率</text>
        </view>
      </view>

      <!-- 加载中 -->
      <view wx:if="{{loading}}" class="loading-container">
        <text class="loading-spinner">⏳</text>
        <text class="loading-text">加载中...</text>
      </view>

      <!-- 申请列表 -->
      <scroll-view wx:if="{{!loading}}" class="list-scroll" scroll-y enhanced refresher-enabled bindrefresherrefresh="onRefresh">
        <view class="request-list" wx:if="{{requests.length > 0}}">
          <view 
            class="request-card"
            wx:for="{{requests}}"
            wx:key="_id"
            bindtap="viewDetail"
            data-index="{{index}}"
          >
            <!-- 卡片头部 -->
            <view class="card-header">
              <view class="header-left">
                <view class="type-tag" style="background: {{item.typeConfig.color}}20; color: {{item.typeConfig.color}}">
                  <text>{{item.typeConfig.label}}</text>
                </view>
                <view class="status-tag" style="background: {{item.statusConfig.bg}}; color: {{item.statusConfig.color}}">
                  <text>{{item.statusConfig.label}}</text>
                </view>
              </view>
              <text class="card-time">{{formatDate(item.createdAt)}}</text>
            </view>

            <!-- 原课程信息 -->
            <view class="course-section original">
              <view class="section-label">
                <text>原课程</text>
              </view>
              <view class="course-info">
                <text class="course-name">{{item.originalCourseName}}</text>
                <view class="course-detail">
                  <text class="detail-item">📅 {{item.originalDate}}</text>
                  <text class="detail-item">⏰ {{item.originalTime}}</text>
                </view>
              </view>
            </view>

            <!-- 目标课程信息 -->
            <view wx:if="{{item.targetScheduleId}}" class="course-section target">
              <view class="section-label">
                <text>目标课程</text>
              </view>
              <view class="course-info">
                <text class="course-name">{{item.targetCourseName || '待安排'}}</text>
                <view class="course-detail" wx:if="{{item.targetDate}}">
                  <text class="detail-item">📅 {{item.targetDate}}</text>
                  <text class="detail-item">⏰ {{item.targetTime}}</text>
                </view>
              </view>
            </view>

            <!-- 调课原因 -->
            <view class="reason-section">
              <text class="reason-label">原因：</text>
              <text class="reason-text">{{item.reason}}</text>
            </view>

            <!-- 管理员回复 -->
            <view wx:if="{{item.adminReply}}" class="reply-section">
              <text class="reply-label">管理员回复：</text>
              <text class="reply-text">{{item.adminReply}}</text>
            </view>

            <!-- 操作按钮 -->
            <view class="card-footer" catchtap="viewDetail" data-index="{{index}}">
              <view class="btn-detail">
                <text>查看详情</text>
              </view>
              <view 
                wx:if="{{item.status === 'pending'}}"
                class="btn-cancel"
                catchtap="cancelRequest"
                data-index="{{index}}"
              >
                <text>取消申请</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 空状态 -->
        <view wx:if="{{!loading && requests.length === 0}}" class="empty-container">
          <view class="empty-icon-wrap">
            <text class="empty-icon">📋</text>
          </view>
          <text class="empty-title">暂无调课记录</text>
          <text class="empty-desc">如有需要，可以提交调课申请</text>
          <view class="empty-btn" bindtap="switchTab" data-tab="create">
            <text>新建申请</text>
          </view>
        </view>

        <view class="list-footer" wx:if="{{requests.length > 0}}">
          <text>— 没有更多了 —</text>
        </view>
      </scroll-view>
    </block>

    <!-- 新建申请视图 -->
    <block wx:if="{{activeTab === 'create'}}">
      <!-- 步骤指示器 -->
      <view class="step-indicator">
        <view class="step-item {{step >= 1 ? 'active' : ''}}">
          <view class="step-dot">1</view>
          <text class="step-label">选择原课程</text>
        </view>
        <view class="step-line {{step > 1 ? 'active' : ''}}"></view>
        <view class="step-item {{step >= 2 ? 'active' : ''}}">
          <view class="step-dot">2</view>
          <text class="step-label">填写原因</text>
        </view>
        <view class="step-line {{step > 2 ? 'active' : ''}}"></view>
        <view class="step-item {{step >= 3 ? 'active' : ''}}">
          <view class="step-dot">3</view>
          <text class="step-label">选择目标</text>
        </view>
      </view>

      <!-- 步骤1：选择原排课 -->
      <view wx:if="{{step === 1}}" class="step-content">
        <view class="step-title">
          <text>请选择您要调课的排课</text>
        </view>

        <!-- 加载中 -->
        <view wx:if="{{loadingSchedules}}" class="loading-container">
          <text class="loading-spinner">⏳</text>
          <text class="loading-text">加载中...</text>
        </view>

        <!-- 无排课 -->
        <view wx:elif="{{mySchedules.length === 0}}" class="empty-card">
          <text class="empty-card-title">暂无可调课的排课记录</text>
          <text class="empty-card-desc">您还没有加入任何班级，或班级的排课已结束</text>
          <view class="btn-retry" bindtap="loadMySchedules">
            <text>重新加载</text>
          </view>
        </view>

        <!-- 排课列表 -->
        <view wx:else class="schedule-list">
          <view 
            class="schedule-card"
            wx:for="{{mySchedules}}"
            wx:key="_id"
            bindtap="handleSelectOriginal"
            data-index="{{index}}"
          >
            <view class="schedule-main">
              <text class="schedule-name">{{item.courseName}}</text>
              <view class="schedule-detail">
                <text class="detail-item">📅 {{item.date}}</text>
                <text class="detail-item">⏰ {{item.startTime}} - {{item.endTime}}</text>
                <text class="detail-item">👨‍🏫 {{item.teacherName || '待分配'}}</text>
                <text class="detail-item">📍 {{item.location || '-'}}</text>
              </view>
            </view>
            <text class="schedule-arrow">›</text>
          </view>
        </view>
      </view>

      <!-- 步骤2：填写原因 -->
      <view wx:if="{{step === 2}}" class="step-content">
        <view class="step-title">
          <text>已选课程：{{selectedSchedule.courseName}}</text>
        </view>

        <!-- 调课类型 -->
        <view class="form-section">
          <text class="form-label">调课类型 <text class="required">*</text></text>
          <view class="type-grid">
            <view 
              wx:for="{{['time', 'teacher', 'location', 'course', 'leave']}}"
              wx:for-item="type"
              wx:key="type"
              class="type-item {{transferType === type ? 'active' : ''}}"
              style="{{transferType === type ? 'background: #2563eb; color: #fff;' : ''}}"
              bindtap="setTransferType"
              data-type="{{type}}"
            >
              <text>{{item === 'time' ? '时间调整' : item === 'teacher' ? '更换老师' : item === 'location' ? '更换场地' : item === 'course' ? '更换课程' : '请假补课'}}</text>
            </view>
          </view>
        </view>

        <!-- 调课原因 -->
        <view class="form-section">
          <text class="form-label">调课原因 <text class="required">*</text></text>
          <textarea 
            class="form-textarea"
            placeholder="请详细说明调课原因（至少5个字）..."
            value="{{reason}}"
            bindinput="setReason"
            maxlength="500"
          />
        </view>

        <!-- 备注 -->
        <view class="form-section">
          <text class="form-label">备注（选填）</text>
          <textarea 
            class="form-textarea short"
            placeholder="其他补充说明..."
            value="{{remark}}"
            bindinput="setRemark"
            maxlength="200"
          />
        </view>

        <!-- 操作按钮 -->
        <view class="form-actions">
          <view class="btn-prev" bindtap="prevStep">
            <text>上一步</text>
          </view>
          <view class="btn-next" bindtap="nextStep">
            <text>下一步</text>
          </view>
        </view>
      </view>

      <!-- 步骤3：选择目标 -->
      <view wx:if="{{step === 3}}" class="step-content">
        <view class="step-title">
          <text>请选择目标排课（可选）</text>
        </view>
        <text class="step-desc">如果您已经有想要调到的具体时间/班级，请选择；如暂不确定，可留空让管理员帮您安排。</text>

        <!-- 暂不指定 -->
        <view 
          class="target-option {{!selectedTarget ? 'active' : ''}}"
          bindtap="selectTarget"
          data-index="-1"
        >
          <text>暂不指定，由管理员安排</text>
        </view>

        <!-- 目标列表 -->
        <view wx:if="{{targetSchedules.length > 0}}" class="target-list">
          <view 
            wx:for="{{targetSchedules}}"
            wx:key="_id"
            class="schedule-card {{selectedTarget && (selectedTarget._id === item._id || selectedTarget.id === item.id) ? 'selected' : ''}}"
            bindtap="selectTarget"
            data-index="{{index}}"
          >
            <view class="schedule-main">
              <text class="schedule-name">{{item.courseName}}</text>
              <view class="schedule-detail">
                <text class="detail-item">📅 {{item.date}}</text>
                <text class="detail-item">⏰ {{item.startTime}}</text>
                <text class="detail-item">👨‍🏫 {{item.teacherName || '待分配'}}</text>
              </view>
            </view>
            <view class="schedule-check" wx:if="{{selectedTarget && (selectedTarget._id === item._id || selectedTarget.id === item.id)}}">✓</view>
          </view>
        </view>

        <!-- 操作按钮 -->
        <view class="form-actions">
          <view class="btn-prev" bindtap="prevStep">
            <text>上一步</text>
          </view>
          <view class="btn-submit {{submitting ? 'loading' : ''}}" bindtap="submitRequest">
            <text wx:if="{{!submitting}}">提交申请</text>
            <text wx:else>提交中...</text>
          </view>
        </view>
      </view>

      <!-- 取消按钮 -->
      <view class="btn-cancel-form" bindtap="prevStep">
        <text>取消</text>
      </view>
    </block>
  </block>

  <!-- 详情弹窗 -->
  <view wx:if="{{showDetail && selectedRequest}}" class="detail-modal">
    <view class="modal-mask" bindtap="closeDetail"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">调课详情</text>
        <view class="modal-close" bindtap="closeDetail">×</view>
      </view>

      <scroll-view class="modal-body" scroll-y>
        <!-- 状态标签 -->
        <view class="modal-tags">
          <view class="type-tag" style="background: {{selectedRequest.typeConfig.color}}20; color: {{selectedRequest.typeConfig.color}}">
            <text>{{selectedRequest.typeConfig.label}}</text>
          </view>
          <view class="status-tag" style="background: {{selectedRequest.statusConfig.bg}}; color: {{selectedRequest.statusConfig.color}}">
            <text>{{selectedRequest.statusConfig.label}}</text>
          </view>
        </view>

        <!-- 原排课 -->
        <view class="detail-section">
          <text class="section-title">原排课信息</text>
          <view class="detail-card original">
            <text class="detail-course-name">{{selectedRequest.originalCourseName}}</text>
            <view class="detail-grid">
              <text>📅 {{selectedRequest.originalDate}}</text>
              <text>⏰ {{selectedRequest.originalTime}}</text>
              <text>👨‍🏫 {{selectedRequest.originalTeacher || '待分配'}}</text>
              <text>📍 {{selectedRequest.originalLocation || '-'}}</text>
            </view>
          </view>
        </view>

        <!-- 目标排课 -->
        <view wx:if="{{selectedRequest.targetScheduleId}}" class="detail-section">
          <text class="section-title">目标排课</text>
          <view class="detail-card target">
            <text class="detail-course-name">{{selectedRequest.targetCourseName || '待安排'}}</text>
            <view class="detail-grid" wx:if="{{selectedRequest.targetDate}}">
              <text>📅 {{selectedRequest.targetDate}}</text>
              <text>⏰ {{selectedRequest.targetTime}}</text>
              <text wx:if="{{selectedRequest.targetTeacher}}">👨‍🏫 {{selectedRequest.targetTeacher}}</text>
              <text wx:if="{{selectedRequest.targetLocation}}">📍 {{selectedRequest.targetLocation}}</text>
            </view>
          </view>
        </view>

        <!-- 调课原因 -->
        <view class="detail-section">
          <text class="section-title">调课原因</text>
          <view class="detail-card">
            <text class="detail-text">{{selectedRequest.reason}}</text>
          </view>
        </view>

        <!-- 备注 -->
        <view wx:if="{{selectedRequest.remark}}" class="detail-section">
          <text class="section-title">备注</text>
          <view class="detail-card">
            <text class="detail-text">{{selectedRequest.remark}}</text>
          </view>
        </view>

        <!-- 审核信息 -->
        <view wx:if="{{selectedRequest.reviewedAt}}" class="detail-section">
          <text class="section-title">审核结果</text>
          <view class="detail-card">
            <view class="review-header">
              <text style="color: {{selectedRequest.statusConfig.color}}">{{selectedRequest.statusConfig.label}}</text>
              <text class="review-time">{{selectedRequest.adminName || '管理员'}}</text>
            </view>
            <text wx:if="{{selectedRequest.adminReply}}" class="review-reply">{{selectedRequest.adminReply}}</text>
          </view>
        </view>

        <!-- 时间信息 -->
        <view class="detail-time">
          <text>申请时间：{{formatDate(selectedRequest.createdAt)}}</text>
        </view>
      </scroll-view>

      <view class="modal-footer">
        <view class="btn-modal-close" bindtap="closeDetail">
          <text>关闭</text>
        </view>
      </view>
    </view>
  </view>
</view>
