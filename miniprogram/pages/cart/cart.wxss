/* pages/cart/cart.wxss */

.page {
  background: var(--bg-color);
  min-height: 100vh;
  padding-bottom: 60px;
}

/* 空状态 */
.empty-container .go-shopping-btn {
  margin-top: 24px;
  background: var(--primary-color);
  color: #fff;
  border-radius: 20px;
  font-size: 14px;
  padding: 10px 32px;
}

/* 购物车列表 */
.cart-list {
  padding: 12px 16px;
}

.cart-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 8px;
  padding: 12px;
  margin-bottom: 12px;
  position: relative;
}

/* 选择框 */
.checkbox {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  border: 1px solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12px;
  flex-shrink: 0;
  font-size: 12px;
  color: #fff;
}

.checkbox.checked {
  background: var(--primary-color);
  border-color: var(--primary-color);
}

/* 商品内容 */
.item-content {
  flex: 1;
  display: flex;
  overflow: hidden;
}

.item-image {
  width: 80px;
  height: 80px;
  border-radius: 8px;
  flex-shrink: 0;
  margin-right: 12px;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
}

.item-title {
  font-size: 14px;
  color: var(--text-color);
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-spec {
  font-size: 12px;
  color: var(--text-placeholder);
  margin-top: 4px;
}

.item-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.item-price {
  color: var(--error-color);
  font-size: 16px;
  font-weight: 600;
}

/* 数量控制 */
.quantity-control {
  display: flex;
  align-items: center;
}

.qty-btn {
  width: 24px;
  height: 24px;
  font-size: 14px;
  line-height: 24px;
  padding: 0;
  margin: 0;
  border: 1px solid var(--border-color);
  background: #fff;
  border-radius: 4px;
  text-align: center;
}

.qty-num {
  width: 32px;
  text-align: center;
  font-size: 14px;
}

/* 删除按钮 */
.delete-btn {
  position: absolute;
  right: 12px;
  top: 0;
  font-size: 20px;
  color: var(--text-placeholder);
  padding: 4px 8px;
}

/* 底部结算栏 */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  background: #fff;
  padding: 8px 16px;
  box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.08);
}

.select-all {
  display: flex;
  align-items: center;
  font-size: 14px;
  color: var(--text-color);
}

.select-all .checkbox {
  margin-right: 8px;
}

.checkout-info {
  flex: 1;
  text-align: right;
  margin-right: 12px;
}

.total-label {
  font-size: 14px;
  color: var(--text-color);
}

.total-price {
  font-size: 18px;
  font-weight: 600;
  color: var(--error-color);
}

.total-qty {
  font-size: 12px;
  color: var(--text-placeholder);
}

.checkout-btn {
  background: var(--error-color);
  color: #fff;
  border: none;
  border-radius: 20px;
  font-size: 14px;
  padding: 10px 20px;
}