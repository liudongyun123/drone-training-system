<view class="page">
  <!-- 顶部导航 -->
  <view class="nav-bar">
    <view class="nav-left" bindtap="onBack">
      <text class="back-icon">←</text>
    </view>
    <text class="nav-title">购物车</text>
    <view class="nav-right">
      <text wx:if="{{cartList.length > 0}}" class="clear-btn" bindtap="onClearCart">清空</text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <text>加载中...</text>
  </view>

  <!-- 购物车列表 -->
  <block wx:if="{{cartList.length > 0 && !loading}}">
    <scroll-view 
      class="cart-list" 
      scroll-y 
      enhanced 
      show-scrollbar="{{false}}"
    >
      <!-- 店铺/商品信息 -->
      <view class="cart-item" wx:for="{{cartList}}" wx:key="_id">
        <!-- 选择框 -->
        <view 
          class="checkbox {{item.selected ? 'checked' : ''}}" 
          bindtap="onSelectItem" 
          data-index="{{index}}"
        >
          <view wx:if="{{item.selected}}" class="check-inner"></view>
        </view>

        <!-- 商品图片 -->
        <image 
          class="item-image" 
          src="{{item.coverImage || item.cover || 'https://via.placeholder.com/200x200?text=商品'}}"
          mode="aspectFill"
          bindtap="onViewProduct"
          data-product-id="{{item._id}}"
        />

        <!-- 商品信息 -->
        <view class="item-content">
          <text 
            class="item-title"
            bindtap="onViewProduct"
            data-product-id="{{item._id}}"
          >{{item.name}}</text>
          
          <view class="item-bottom">
            <view class="price-wrap">
              <text class="price-symbol">¥</text>
              <text class="price-num">{{item.price}}</text>
            </view>
            
            <view class="quantity-control">
              <view class="qty-btn minus" bindtap="onDecrease" data-index="{{index}}">
                <text>-</text>
              </view>
              <text class="qty-num">{{item.quantity}}</text>
              <view class="qty-btn plus" bindtap="onIncrease" data-index="{{index}}">
                <text>+</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 删除按钮 -->
        <view class="delete-btn" bindtap="onDeleteItem" data-index="{{index}}">
          <text>×</text>
        </view>
      </view>
    </scroll-view>

    <!-- 底部操作栏 -->
    <view class="bottom-bar safe-area-bottom">
      <!-- 全选 -->
      <view class="select-all" bindtap="onSelectAll">
        <view class="checkbox {{selectedAll ? 'checked' : ''}}">
          <view wx:if="{{selectedAll}}" class="check-inner"></view>
        </view>
        <text class="select-text">全选</text>
      </view>

      <!-- 价格信息 -->
      <view class="price-info">
        <view class="price-row">
          <text class="price-label">合计：</text>
          <text class="total-price">¥{{totalPrice}}</text>
        </view>
        <text class="price-hint">共 {{selectedCount}} 件商品</text>
      </view>

      <!-- 结算按钮 -->
      <button 
        class="checkout-btn {{selectedCount === 0 ? 'disabled' : ''}}" 
        bindtap="onCheckout"
        disabled="{{selectedCount === 0}}"
      >
        去结算
      </button>
    </view>
  </block>

  <!-- 空状态 -->
  <view wx:if="{{cartList.length === 0 && !loading}}" class="empty-container">
    <view class="empty-icon-wrap">
      <text class="empty-icon">🛒</text>
    </view>
    <text class="empty-text">购物车是空的</text>
    <text class="empty-hint">快去挑选心仪的商品吧</text>
    <button class="shopping-btn" bindtap="onContinueShopping">
      逛逛商城
    </button>
  </view>
</view>
