<view class="page">
  <!-- 加载状态 -->
  <view wx:if="{{loading && !refreshing}}" class="loading-container">
    <view class="skeleton-list">
      <view class="skeleton-item" wx:for="{{5}}" wx:key="*this"></view>
    </view>
  </view>

  <!-- 列表 -->
  <view class="record-list" wx:if="{{records.length > 0}}">
    <view 
      class="record-item"
      wx:for="{{records}}"
      wx:key="_id"
      bindtap="viewDetail"
      data-record="{{item}}"
    >
      <view class="record-header">
        <view class="record-type">
          <text class="type-icon">{{item.typeIcon}}</text>
          <text class="type-text">{{item.typeText}}</text>
        </view>
        <text class="record-time">{{item.timeText}}</text>
      </view>
      
      <view class="record-body">
        <text class="record-title">{{item.targetName}}</text>
        <view class="record-stats">
          <view class="stat-item">
            <text class="stat-label">正确率</text>
            <text class="stat-value {{item.accuracy >= 60 ? 'success' : 'error'}}">{{item.accuracy}}%</text>
          </view>
          <view class="stat-item">
            <text class="stat-label">正确/总题</text>
            <text class="stat-value">{{item.correctCount}}/{{item.totalCount}}</text>
          </view>
          <view class="stat-item">
            <text class="stat-label">用时</text>
            <text class="stat-value">{{item.durationText}}</text>
          </view>
        </view>
      </view>
      
      <view class="record-action" catchtap="continuePractice" data-record="{{item}}">
        <text class="action-text">再次练习</text>
        <text class="action-arrow">></text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{!loading && records.length === 0}}" class="empty-container">
    <text class="empty-icon">📊</text>
    <text class="empty-title">暂无练习记录</text>
    <text class="empty-desc">开始练习后，这里将显示您的练习历史</text>
  </view>

  <!-- 加载更多 -->
  <view wx:if="{{loading && records.length > 0}}" class="loading-more">
    <text>加载中...</text>
  </view>
  
  <view wx:if="{{!hasMore && records.length > 0}}" class="no-more">
    <text>没有更多了</text>
  </view>
</view>
