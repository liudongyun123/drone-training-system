/* pages/wrong-questions/wrong-questions.wxss */

.page {
  min-height: 100vh;
  background: #f5f6fa;
  padding: 24rpx;
}

.loading-container {
  padding: 24rpx 0;
}

.skeleton-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.skeleton-item {
  height: 240rpx;
  background: linear-gradient(90deg, #e0e5ec 25%, #f0f0f0 50%, #e0e5ec 75%);
  background-size: 200% 100%;
  border-radius: 20rpx;
  animation: shimmer 1.5s infinite;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* 错题列表 */
.question-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.question-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.question-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.question-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #fef2f2;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
}

.badge-icon {
  font-size: 24rpx;
}

.badge-text {
  font-size: 24rpx;
  color: #ef4444;
  font-weight: 500;
}

.question-time {
  font-size: 24rpx;
  color: #94a3b8;
}

.question-content {
  margin-bottom: 20rpx;
}

.question-text {
  font-size: 30rpx;
  color: #1e293b;
  line-height: 1.6;
}

.question-answer {
  background: #f8fafc;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.answer-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.answer-row:last-child {
  margin-bottom: 0;
}

.answer-label {
  font-size: 26rpx;
  color: #64748b;
  margin-right: 16rpx;
}

.answer-value {
  font-size: 28rpx;
  font-weight: 600;
}

.answer-value.correct {
  color: #22c55e;
}

.answer-value.wrong {
  color: #ef4444;
}

.question-action {
  display: flex;
  justify-content: center;
}

.action-text {
  font-size: 28rpx;
  color: #667eea;
  font-weight: 500;
  padding: 16rpx 32rpx;
  background: #f0f1ff;
  border-radius: 16rpx;
}

/* 空状态 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 64rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #94a3b8;
  text-align: center;
}

/* 底部提示 */
.tip-bar {
  display: flex;
  justify-content: center;
  padding: 24rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #94a3b8;
}
