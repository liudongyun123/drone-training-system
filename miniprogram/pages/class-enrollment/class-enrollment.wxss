/* pages/class-enrollment/class-enrollment.wxss */

.page {
  background: var(--bg-color);
  min-height: 100vh;
  /* 为底部固定栏预留空间：按钮高度 + padding + 安全区域 */
  padding-bottom: calc(200rpx + env(safe-area-inset-bottom));
  padding-bottom: calc(200rpx + constant(safe-area-inset-bottom));
  box-sizing: border-box;
}

.section {
  background: #fff;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-color);
  margin-bottom: 32rpx;
}

/* 培训班摘要 */
.class-summary {
  display: flex;
  align-items: flex-start;
}

.class-cover {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  margin-right: 24rpx;
  background: #f5f5f5;
}

.class-detail {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.class-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-color);
  margin-bottom: 12rpx;
  line-height: 1.4;
  word-wrap: break-word;
  word-break: break-all;
}

.class-time,
.class-location {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.price-row {
  display: flex;
  align-items: baseline;
  margin-top: auto;
  padding-top: 12rpx;
}

.price-symbol {
  color: var(--danger);
  font-size: 24rpx;
  font-weight: 500;
}

.price-num {
  color: var(--danger);
  font-size: 40rpx;
  font-weight: 700;
}

/* 表单 */
.form-group {
  margin-bottom: 32rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-color);
  margin-bottom: 16rpx;
}

.form-label.required::before {
  content: '* ';
  color: var(--error-color);
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid var(--border-color);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 支付方式 */
.pay-options {
  display: flex;
  flex-direction: row;
  gap: 24rpx;
}

.pay-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 24rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 16rpx;
  position: relative;
}

.pay-option.active {
  border-color: var(--primary);
  background: rgba(37, 99, 235, 0.05);
}

.pay-radio {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  font-size: 24rpx;
  color: #fff;
}

.pay-option.active .pay-radio {
  background: var(--primary);
  border-color: var(--primary);
}

.pay-label {
  font-size: 30rpx;
  color: var(--text-color);
  font-weight: 600;
  margin-bottom: 8rpx;
}

.pay-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 费用 */
.fee-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.fee-row.total {
  padding-top: 32rpx;
  border-top: 1rpx solid var(--border-color);
}

.fee-label {
  font-size: 28rpx;
  color: var(--text-color);
}

.fee-value {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--error-color);
}

/* 底部栏 */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  padding-bottom: calc(20rpx + constant(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.12);
  z-index: 999;
  box-sizing: border-box;
}

.total-area {
  display: flex;
  align-items: center;
  flex: 1;
}

.total-text {
  font-size: 28rpx;
  color: var(--text-color);
  line-height: 1;
}

.total-price {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--danger);
  line-height: 1;
  margin-left: 8rpx;
}

.submit-btn {
  background: linear-gradient(135deg, #ef4444 0%, #f97316 100%) !important;
  color: #fff !important;
  border: none !important;
  border-radius: 40rpx !important;
  font-size: 30rpx;
  font-weight: 600;
  padding: 0 40rpx;
  line-height: 80rpx;
  margin: 0;
  min-width: 220rpx;
  height: 80rpx;
  text-align: center;
}

.submit-btn::after {
  border: none !important;
}

.submit-btn.disabled {
  opacity: 0.6;
}
