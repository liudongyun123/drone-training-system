/* pages/class-enrollment/class-enrollment.wxss */

.page {
  background: var(--bg-color);
  min-height: 100vh;
  padding-bottom: 80rpx;
}

.section {
  background: #fff;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-color);
  margin-bottom: 32rpx;
}

/* 培训班摘要 */
.class-summary {
  display: flex;
}

.class-cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.class-detail {
  flex: 1;
}

.class-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-color);
  margin-bottom: 8rpx;
}

.class-time,
.class-location {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
  margin-top: 16rpx;
}

.price-symbol {
  color: var(--error-color);
  font-size: 24rpx;
}

.price-num {
  color: var(--error-color);
  font-size: 40rpx;
  font-weight: 600;
}

/* 表单 */
.form-group {
  margin-bottom: 32rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-color);
  margin-bottom: 16rpx;
}

.form-label.required::before {
  content: '* ';
  color: var(--error-color);
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid var(--border-color);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 支付方式 */
.pay-options {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.pay-option {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border: 1rpx solid var(--border-color);
  border-radius: 16rpx;
}

.pay-option.active {
  border-color: var(--primary-color);
  background: rgba(24, 144, 255, 0.05);
}

.pay-radio {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 1rpx solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  font-size: 24rpx;
  color: #fff;
}

.pay-option.active .pay-radio {
  background: var(--primary-color);
  border-color: var(--primary-color);
}

.pay-label {
  font-size: 28rpx;
  color: var(--text-color);
  font-weight: 500;
}

.pay-desc {
  flex: 1;
  text-align: right;
  font-size: 24rpx;
  color: var(--text-placeholder);
}

/* 费用 */
.fee-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.fee-row.total {
  padding-top: 32rpx;
  border-top: 1rpx solid var(--border-color);
}

.fee-label {
  font-size: 28rpx;
  color: var(--text-color);
}

.fee-value {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--error-color);
}

/* 底部栏 */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  padding: 16rpx 32rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.total-area {
  display: flex;
  align-items: baseline;
}

.total-text {
  font-size: 28rpx;
  color: var(--text-color);
}

.total-price {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--error-color);
}

.submit-btn {
  background: var(--error-color);
  color: #fff;
  border: none;
  border-radius: 40rpx;
  font-size: 32rpx;
  padding: 24rpx 64rpx;
}

.submit-btn.disabled {
  opacity: 0.6;
}
