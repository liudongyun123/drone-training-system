/* pages/my-certificates/my-certificates.wxss */

.page {
  min-height: 100vh;
  background: #f1f5f9;
}

/* Tab 栏 */
.tab-bar {
  display: flex;
  background: #fff;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #e2e8f0;
}

.tab-item {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #64748b;
  padding-bottom: 16rpx;
  position: relative;
}

.tab-item.active {
  color: #2563eb;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #2563eb;
  border-radius: 2rpx;
}

/* 证书列表 */
.cert-list {
  padding: 24rpx 32rpx;
}

.cert-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.cert-icon {
  width: 96rpx;
  height: 96rpx;
  flex-shrink: 0;
  margin-right: 24rpx;
  background: linear-gradient(135deg, #dbeafe, #e0e7ff);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.cert-info {
  flex: 1;
  overflow: hidden;
}

.cert-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cert-meta {
  display: block;
  font-size: 24rpx;
  color: #94a3b8;
  margin-bottom: 4rpx;
}

/* 证书状态 */
.cert-status {
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.cert-status.status-verified {
  background: rgba(16, 185, 129, 0.1);
  color: #10b981;
}

.cert-status.status-pending {
  background: rgba(245, 158, 11, 0.1);
  color: #f59e0b;
}

.cert-status.status-expired {
  background: rgba(153, 153, 153, 0.1);
  color: #94a3b8;
}

/* 证书操作 */
.cert-action {
  display: flex;
  align-items: center;
}

.action-text {
  font-size: 26rpx;
  color: #2563eb;
}

.arrow {
  color: #2563eb;
  margin-left: 8rpx;
}

/* 添加按钮 */
.add-btn-container {
  padding: 32rpx;
}

.add-btn {
  width: 100%;
  background: #fff;
  color: #2563eb;
  border: 1rpx dashed #2563eb;
  border-radius: 16rpx;
  font-size: 28rpx;
  padding: 24rpx 0;
}

.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  opacity: 0.4;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #64748b;
  margin-bottom: 16rpx;
}

.empty-desc {
  display: block;
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 16rpx;
}

.add-btn-inline {
  margin-top: 32rpx;
  background: linear-gradient(135deg, #2563eb, #3b82f6);
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 20rpx 48rpx;
  border: none;
}
