/* pages/login/login.wxss */

.login-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48px 24px;
  background: linear-gradient(135deg, #1890ff 0%, #40a9ff 100%);
  min-height: 100vh;
}

/* 未登录状态 */
.login-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.logo {
  width: 120px;
  height: 120px;
  margin-bottom: 24px;
}

.title {
  font-size: 24px;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8px;
}

.desc {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 48px;
}

.btn-wx-login,
.btn-phone-login {
  width: 280px;
  height: 48px;
  border-radius: 24px;
  margin-bottom: 16px;
  font-size: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-wx-login {
  background: #fff;
  color: #1890ff;
}

.btn-phone-login {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  border: 1px solid rgba(255, 255, 255, 0.4);
}

.btn-icon {
  margin-right: 8px;
}

.tips {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 24px;
}

/* 已登录状态 */
.logged-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  padding-top: 48px;
}

.avatar {
  width: 100px;
  height: 100px;
  border-radius: 50%;
  border: 4px solid #fff;
  margin-bottom: 16px;
}

.nickname {
  font-size: 20px;
  font-weight: 600;
  color: #fff;
  margin-bottom: 48px;
}

.btn-logout {
  width: 200px;
  height: 48px;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  border-radius: 24px;
  border: 1px solid rgba(255, 255, 255, 0.4);
}