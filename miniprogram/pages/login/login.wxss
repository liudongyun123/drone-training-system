/* pages/login/login.wxss */

.login-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 96rpx 48rpx;
  background: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%);
  min-height: 100vh;
}

/* 未登录状态 */
.login-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.logo {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 48rpx;
  background: #fff;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
}

.logo-img {
  width: 160rpx;
  height: auto;
  max-height: 160rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 16rpx;
}

.desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 96rpx;
}

.btn-wx-login,
.btn-phone-login {
  width: 560rpx;
  height: 96rpx;
  border-radius: 48rpx;
  margin-bottom: 32rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-wx-login {
  background: #fff;
  color: #2563eb;
}

.btn-phone-login {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  border: 1rpx solid rgba(255, 255, 255, 0.4);
}

.btn-icon {
  margin-right: 16rpx;
}

.tips {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 48rpx;
}

/* 已登录状态 */
.logged-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  padding-top: 96rpx;
}

.avatar {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 8rpx solid #fff;
  margin-bottom: 32rpx;
  background: linear-gradient(135deg, #dbeafe, #e0e7ff);
}

.nickname {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 96rpx;
}

.btn-logout {
  width: 400rpx;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  border-radius: 48rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  font-size: 32rpx;
}
