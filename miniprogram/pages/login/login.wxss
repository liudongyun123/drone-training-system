/* pages/login/login.wxss */

.login-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx 60rpx;
  background: linear-gradient(180deg, #1e40af 0%, #3b82f6 50%, #60a5fa 100%);
  min-height: 100vh;
}

/* 未登录状态 */
.login-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 40rpx;
  background: #fff;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.2);
}

.logo-img {
  width: 120rpx;
  height: auto;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-bottom: 80rpx;
}

/* 按钮样式 */
.btn-primary,
.btn-secondary,
.btn-bind-phone {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  margin-bottom: 24rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 32rpx;
}

.btn-primary {
  background: #fff;
  color: #1e40af;
  font-weight: 600;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.15);
  color: #fff;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.btn-secondary::after {
  border: none;
}

.btn-icon {
  margin-right: 12rpx;
  font-size: 36rpx;
}

.tips {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 40rpx;
  text-align: center;
}

/* 已登录状态 */
.logged-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  padding-top: 60rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.5);
  margin-bottom: 24rpx;
  background: rgba(255, 255, 255, 0.2);
}

.nickname {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 16rpx;
}

.bind-status {
  margin-bottom: 60rpx;
}

.bind-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.bind-pending {
  margin-bottom: 0;
}

.btn-bind-phone {
  width: 320rpx;
  height: 80rpx;
  background: #fff;
  color: #1e40af;
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 40rpx;
}

.btn-bind-phone::after {
  border: none;
}

.btn-logout {
  width: 320rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.15);
  color: #fff;
  border-radius: 40rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  font-size: 28rpx;
  margin-top: auto;
}

.btn-logout::after {
  border: none;
}
