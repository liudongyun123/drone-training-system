<view class="page">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <text>加载中...</text>
  </view>

  <block wx:if="{{!loading}}">
    <!-- 题库练习 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">题库练习</text>
        <text class="section-desc">按知识点分类刷题</text>
      </view>
      <view class="bank-grid">
        <view 
          class="bank-card"
          wx:for="{{questionBanks}}"
          wx:key="_id"
          bindtap="startPractice"
          data-id="{{item._id}}"
        >
          <text class="bank-icon">{{item.icon || '📝'}}</text>
          <text class="bank-title">{{item.title}}</text>
          <text class="bank-count">{{item.questionCount}}题</text>
        </view>
      </view>
    </view>

    <!-- 模拟考试 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">模拟考试</text>
        <text class="section-desc">限时模拟真实考试</text>
      </view>
      <view class="exam-list">
        <view 
          class="exam-card"
          wx:for="{{mockExams}}"
          wx:key="_id"
          bindtap="startMockExam"
          data-id="{{item._id}}"
        >
          <view class="exam-info">
            <text class="exam-title">{{item.title}}</text>
            <text class="exam-desc">{{item.description}}</text>
            <view class="exam-meta">
              <text class="meta-item">⏱ {{item.duration}}分钟</text>
              <text class="meta-item">📝 {{item.questionCount}}题</text>
              <text class="meta-item">✅ {{item.passScore}}分及格</text>
            </view>
          </view>
          <view class="exam-action">
            <text class="start-text">开始考试</text>
            <text class="arrow">></text>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{questionBanks.length === 0 && mockExams.length === 0}}" class="empty-container">
      <text class="empty-icon">📝</text>
      <text>暂无练习内容</text>
    </view>
  </block>
</view>