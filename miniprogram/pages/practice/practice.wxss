/* pages/practice/practice.wxss */

.page {
  min-height: 100vh;
  background: #f1f5f9;
}

.section {
  padding: 32rpx;
  margin-bottom: 16rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1e293b;
}

.section-desc {
  font-size: 26rpx;
  color: #94a3b8;
}

/* 题库网格 */
.bank-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
}

.bank-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.bank-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.bank-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #1e293b;
  text-align: center;
  margin-bottom: 8rpx;
}

.bank-count {
  font-size: 24rpx;
  color: #94a3b8;
}

/* 模拟考试列表 */
.exam-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.exam-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.exam-info {
  flex: 1;
}

.exam-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 8rpx;
}

.exam-desc {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 16rpx;
}

.exam-meta {
  display: flex;
  gap: 24rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #94a3b8;
}

.exam-action {
  display: flex;
  align-items: center;
  margin-left: 24rpx;
}

.start-text {
  font-size: 28rpx;
  color: #2563eb;
  font-weight: 500;
}

.arrow {
  color: #2563eb;
  margin-left: 8rpx;
}
