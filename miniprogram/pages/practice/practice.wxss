/* pages/practice/practice.wxss */

.page {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 32rpx;
}

/* 加载骨架屏 */
.loading-container {
  padding: 32rpx;
}

.skeleton-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.skeleton-stat-card {
  height: 120rpx;
  background: linear-gradient(90deg, #e0e5ec 25%, #f0f0f0 50%, #e0e5ec 75%);
  background-size: 200% 100%;
  border-radius: 16rpx;
  animation: shimmer 1.5s infinite;
}

.skeleton-section {
  margin-bottom: 32rpx;
  padding: 32rpx;
  background: #fff;
  border-radius: 16rpx;
}

.skeleton-header {
  height: 40rpx;
  width: 200rpx;
  background: linear-gradient(90deg, #e0e5ec 25%, #f0f0f0 50%, #e0e5ec 75%);
  background-size: 200% 100%;
  border-radius: 8rpx;
  margin-bottom: 24rpx;
  animation: shimmer 1.5s infinite;
}

.skeleton-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
}

.skeleton-card {
  height: 200rpx;
  background: linear-gradient(90deg, #e0e5ec 25%, #f0f0f0 50%, #e0e5ec 75%);
  background-size: 200% 100%;
  border-radius: 16rpx;
  animation: shimmer 1.5s infinite;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* 统计区域 */
.stats-section {
  background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.stats-header {
  margin-bottom: 24rpx;
}

.stats-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.stats-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.stat-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 12rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  backdrop-filter: blur(10px);
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  text-align: center;
}

/* 快捷入口 */
.quick-actions {
  display: flex;
  gap: 24rpx;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.action-card {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 28rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.action-icon {
  font-size: 40rpx;
}

.action-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #1e293b;
}

/* 最近练习 */
.recent-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.recent-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.recent-icon {
  font-size: 40rpx;
  margin-right: 24rpx;
}

.recent-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.recent-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #1e293b;
  margin-bottom: 8rpx;
}

.recent-meta {
  font-size: 24rpx;
  color: #94a3b8;
}

.recent-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.recent-score {
  font-size: 28rpx;
  margin-bottom: 8rpx;
}

.recent-score.error {
  color: #ef4444;
}

.recent-time {
  font-size: 22rpx;
  color: #94a3b8;
}

/* 区块样式 */
.section {
  padding: 32rpx;
  margin: 0 24rpx 24rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

.section-title-group {
  display: flex;
  flex-direction: column;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 6rpx;
}

.section-desc {
  font-size: 24rpx;
  color: #94a3b8;
}

.section-more {
  font-size: 26rpx;
  color: #2563eb;
  font-weight: 500;
}

/* 题库网格 */
.bank-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.bank-card {
  background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
  border-radius: 20rpx;
  padding: 28rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.2s, box-shadow 0.2s;
}

.bank-card:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.bank-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.bank-icon {
  font-size: 44rpx;
}

.bank-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #1e293b;
  text-align: center;
  margin-bottom: 12rpx;
  lines: 1;
  text-overflow: ellipsis;
}

.bank-meta {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.bank-level {
  font-size: 22rpx;
  color: #2563eb;
  font-weight: 500;
}

.bank-count {
  font-size: 22rpx;
  color: #94a3b8;
}

/* 模拟考试列表 */
.exam-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.exam-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.2s;
}

.exam-card:active {
  transform: scale(0.98);
}

.exam-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
}

.exam-info {
  flex: 1;
}

.exam-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1e40af;
  margin-bottom: 8rpx;
}

.exam-desc {
  display: block;
  font-size: 24rpx;
  color: #2563eb;
  margin-bottom: 16rpx;
  opacity: 0.8;
}

.exam-meta {
  display: flex;
  gap: 20rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.meta-icon {
  font-size: 22rpx;
}

.meta-text {
  font-size: 22rpx;
  color: #1e40af;
  opacity: 0.8;
}

.exam-action {
  display: flex;
  align-items: center;
  margin-left: 20rpx;
  padding: 16rpx 24rpx;
  background: #2563eb;
  border-radius: 24rpx;
}

.start-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
}

.arrow {
  color: #fff;
  margin-left: 6rpx;
}

/* 空状态 */
.empty-bank,
.empty-exam {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 32rpx;
  background: #fafafa;
  border-radius: 16rpx;
  border: 2rpx dashed #e2e8f0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #94a3b8;
  text-align: center;
}

.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 128rpx 64rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #94a3b8;
  text-align: center;
}
