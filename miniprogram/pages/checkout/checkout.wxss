/* pages/checkout/checkout.wxss */

.page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
  padding-bottom: calc(160rpx + constant(safe-area-inset-bottom));
}

/* 区块 */
.section {
  margin: 20rpx;
  padding: 30rpx;
  background-color: #fff;
  border-radius: 16rpx;
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.title-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.goods-count {
  font-size: 26rpx;
  color: #999;
}

/* 收货地址表单 */
.address-form {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.form-item {
  display: flex;
  align-items: flex-start;
}

.form-label {
  width: 140rpx;
  font-size: 28rpx;
  color: #666;
  line-height: 2;
}

.form-input {
  flex: 1;
  height: 72rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
}

.form-textarea {
  flex: 1;
  min-height: 120rpx;
  padding: 20rpx;
  font-size: 28rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
}

.choose-address-btn {
  margin-top: 20rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  color: #1890ff;
  background-color: #e6f7ff;
  border: none;
  border-radius: 8rpx;
}

/* 商品列表 */
.goods-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.goods-item {
  display: flex;
  padding: 20rpx;
  background-color: #fafafa;
  border-radius: 12rpx;
}

.goods-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  background-color: #f0f0f0;
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  margin-left: 20rpx;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.goods-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 10rpx;
}

.goods-price {
  font-size: 30rpx;
  font-weight: 600;
  color: #ff4d4f;
}

.goods-quantity {
  font-size: 26rpx;
  color: #999;
}

/* 备注 */
.remark-section {
  padding: 30rpx;
}

.remark-input {
  width: 100%;
  min-height: 120rpx;
  padding: 20rpx;
  font-size: 28rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
  box-sizing: border-box;
}

/* 价格明细 */
.price-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.price-label {
  font-size: 28rpx;
  color: #666;
}

.price-value {
  font-size: 28rpx;
  color: #333;
}

.total-row {
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
  margin-top: 10rpx;
}

.total-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.total-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff4d4f;
}

/* 底部提交栏 */
.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  padding-bottom: calc(20rpx + constant(safe-area-inset-bottom));
  background-color: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  z-index: 999;
  box-sizing: border-box;
}

.submit-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.submit-label {
  font-size: 28rpx;
  color: #666;
  line-height: 1;
}

.submit-price {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff4d4f;
  line-height: 1;
  margin-left: 8rpx;
}

.submit-btn {
  min-width: 220rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #fff !important;
  background: linear-gradient(135deg, #ef4444 0%, #f97316 100%) !important;
  border-radius: 40rpx !important;
  border: none !important;
  margin: 0;
  padding: 0 40rpx;
  text-align: center;
}

.submit-btn::after {
  border: none !important;
}

.submit-btn.disabled {
  background: #ccc !important;
  opacity: 0.7;
}
