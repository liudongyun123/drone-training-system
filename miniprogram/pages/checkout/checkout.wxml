<!--pages/checkout/checkout.wxml-->
<view class="page">
  <!-- 收货地址（仅商城实物订单显示） -->
  <view class="section address-section" wx:if="{{type === 'shop'}}">
    <view class="section-title">
      <text class="title-text">收货信息</text>
    </view>
    <view class="address-form">
      <view class="form-item">
        <text class="form-label">收货人</text>
        <input
          class="form-input"
          placeholder="请输入收货人姓名"
          value="{{address.name}}"
          bindinput="onNameInput"
        />
      </view>
      <view class="form-item">
        <text class="form-label">手机号</text>
        <input
          class="form-input"
          type="number"
          maxlength="11"
          placeholder="请输入手机号"
          value="{{address.phone}}"
          bindinput="onPhoneInput"
        />
      </view>
      <view class="form-item">
        <text class="form-label">详细地址</text>
        <textarea
          class="form-textarea"
          placeholder="请输入详细收货地址"
          value="{{address.address}}"
          bindinput="onAddressInput"
        />
      </view>
      <button class="choose-address-btn" bindtap="onChooseAddress">使用微信收货地址</button>
    </view>
  </view>

  <!-- 商品列表 -->
  <view class="section goods-section">
    <view class="section-title">
      <text class="title-text">{{type === 'course' ? '课程信息' : '商品信息'}}</text>
      <text class="goods-count">共 {{items.length}} {{type === 'course' ? '门课程' : '件商品'}}</text>
    </view>
    <view class="goods-list">
      <view 
        wx:for="{{items}}"
        wx:key="_id"
        class="goods-item"
      >
        <image
          class="goods-image"
          src="{{item.coverImage || item.cover || 'https://via.placeholder.com/200x200?text=商品'}}"
          mode="aspectFill"
        />
        <view class="goods-info">
          <text class="goods-name">{{item.name}}</text>
          <view class="goods-bottom">
            <text class="goods-price">¥{{item.price}}</text>
            <text class="goods-quantity">x{{item.quantity}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 备注 -->
  <view class="section remark-section">
    <view class="section-title">
      <text class="title-text">备注</text>
    </view>
    <textarea 
      class="remark-input" 
      placeholder="选填，可备注特殊需求"
      value="{{remark}}"
      bindinput="onRemarkInput"
    />
  </view>

  <!-- 价格明细 -->
  <view class="section price-section">
    <view class="price-row">
      <text class="price-label">{{type === 'course' ? '课程总价' : '商品总价'}}</text>
      <text class="price-value">¥{{totalAmount}}</text>
    </view>
    <view class="price-row" wx:if="{{type === 'shop'}}">
      <text class="price-label">运费</text>
      <text class="price-value">{{freight > 0 ? '¥' + freight : '包邮'}}</text>
    </view>
    <view class="price-row total-row">
      <text class="total-label">合计</text>
      <text class="total-value">¥{{finalAmount}}</text>
    </view>
  </view>

  <!-- 底部提交栏 -->
  <view class="submit-bar">
    <view class="submit-info">
      <text class="submit-label">实付款：</text>
      <text class="submit-price">¥{{finalAmount}}</text>
    </view>
    <button 
      class="submit-btn {{submitting ? 'disabled' : ''}}" 
      bindtap="onWechatPay"
      disabled="{{submitting}}"
    >
      {{submitting ? '提交中...' : '微信支付'}}
    </button>
  </view>
</view>
