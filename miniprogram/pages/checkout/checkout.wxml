<view class="page">
  <!-- 课程结算 -->
  <block wx:if="{{type === 'course' && courseInfo}}">
    <view class="section">
      <text class="section-title">课程信息</text>
      <view class="order-item">
        <image class="item-image" src="{{courseInfo.coverImage}}" mode="aspectFill" />
        <view class="item-info">
          <text class="item-title">{{courseInfo.title}}</text>
          <text class="item-desc">{{courseInfo.description}}</text>
          <text class="item-price">¥{{courseInfo.price}}</text>
        </view>
      </view>
    </view>
  </block>

  <!-- 商城结算 -->
  <block wx:if="{{type === 'shop'}}">
    <!-- 商品列表 -->
    <view class="section">
      <text class="section-title">商品清单 ({{cartItems.length}}件)</text>
      <view class="order-item" wx:for="{{cartItems}}" wx:key="index">
        <image class="item-image" src="{{item.product.images[0] || item.product.coverImage}}" mode="aspectFill" />
        <view class="item-info">
          <text class="item-title">{{item.product.title}}</text>
          <text class="item-spec" wx:if="{{item.specs}}">{{item.selectedSku ? item.selectedSku.name : ''}}</text>
          <view class="item-bottom">
            <text class="item-price">¥{{item.sku.price || item.product.price}}</text>
            <text class="item-qty">×{{item.quantity}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 自提信息 -->
    <view class="section">
      <text class="section-title">提货信息</text>
      <view class="form-group">
        <text class="form-label">联系人</text>
        <input 
          class="form-input" 
          placeholder="请输入联系人姓名" 
          value="{{contactName}}"
          bindinput="onNameInput"
        />
      </view>
      <view class="form-group">
        <text class="form-label">联系电话</text>
        <input 
          class="form-input" 
          placeholder="请输入联系电话" 
          type="number"
          value="{{contactPhone}}"
          bindinput="onPhoneInput"
        />
      </view>
      <view class="form-group">
        <text class="form-label">自提门店</text>
        <picker mode="selector" range="{{stores}}" value="{{storeIndex}}" bindchange="onStoreChange">
          <view class="form-picker">
            <text>{{stores[storeIndex]}}</text>
            <text class="picker-arrow">></text>
          </view>
        </picker>
      </view>
    </view>
  </block>

  <!-- 备注 -->
  <view class="section">
    <text class="section-title">订单备注</text>
    <textarea 
      class="remark-input" 
      placeholder="选填，请先和商家协商一致" 
      value="{{remark}}"
      bindinput="onRemarkInput"
      maxlength="200"
    />
  </view>

  <!-- 价格信息 -->
  <view class="section">
    <view class="price-row">
      <text class="price-label">商品合计</text>
      <text class="price-value">¥{{totalPrice}}</text>
    </view>
    <view class="price-row">
      <text class="price-label">运费</text>
      <text class="price-value text-success">免运费</text>
    </view>
    <view class="price-row total">
      <text class="price-label">应付金额</text>
      <text class="price-value">¥{{totalPrice}}</text>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="bottom-bar safe-area-bottom">
    <view class="total-area">
      <text class="total-text">合计: </text>
      <text class="total-price">¥{{totalPrice}}</text>
    </view>
    <button 
      class="submit-btn {{submitting ? 'disabled' : ''}}" 
      bindtap="submitOrder"
      disabled="{{submitting}}"
    >
      {{submitting ? '提交中...' : '提交订单'}}
    </button>
  </view>
</view>