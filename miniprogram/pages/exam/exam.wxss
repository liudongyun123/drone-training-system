/* pages/exam/exam.wxss */

.page {
  min-height: 100vh;
  background: #f1f5f9;
  display: flex;
  flex-direction: column;
}

/* 顶部信息栏 */
.header {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.progress-info {
  flex: 1;
}

.progress-text {
  font-size: 26rpx;
  color: #64748b;
}

.progress-bar {
  height: 8rpx;
  background: #e2e8f0;
  border-radius: 4rpx;
  margin-top: 12rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #2563eb;
  border-radius: 4rpx;
  transition: width 0.3s;
}

.time-display {
  margin: 0 32rpx;
}

.time-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
  font-variant-numeric: tabular-nums;
}

.time-text.warning {
  color: #ef4444;
}

.question-nav {
  padding: 12rpx 24rpx;
  background: #f1f5f9;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #2563eb;
}

/* 题目区域 */
.question-area {
  flex: 1;
  padding: 32rpx;
  padding-bottom: 160rpx;
}

.question-type {
  margin-bottom: 24rpx;
}

.type-tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  font-size: 24rpx;
  border-radius: 8rpx;
  color: #fff;
}

.type-tag.single {
  background: #2563eb;
}

.type-tag.multiple {
  background: #f59e0b;
}

.type-tag.judge {
  background: #10b981;
}

.question-title {
  display: block;
  font-size: 32rpx;
  color: #1e293b;
  font-weight: 500;
  line-height: 1.6;
  margin-bottom: 40rpx;
}

/* 选项 */
.options {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.option-item {
  display: flex;
  align-items: flex-start;
  padding: 28rpx 32rpx;
  background: #fff;
  border-radius: 16rpx;
  border: 1rpx solid #e2e8f0;
  transition: all 0.2s;
}

.option-item.selected {
  border-color: #2563eb;
  background: rgba(37, 99, 235, 0.05);
}

.option-radio {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 1rpx solid #e2e8f0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  font-size: 24rpx;
  color: #fff;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.option-item.selected .option-radio {
  background: #2563eb;
  border-color: #2563eb;
}

.option-label {
  font-size: 28rpx;
  color: #2563eb;
  font-weight: 600;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.option-text {
  font-size: 28rpx;
  color: #1e293b;
  line-height: 40rpx;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 24rpx;
  padding: 16rpx 32rpx;
  background: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.nav-btn {
  flex: 1;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 24rpx 0;
  border: 1rpx solid #e2e8f0;
  background: #fff;
  color: #64748b;
}

.nav-btn.next,
.nav-btn.submit {
  background: linear-gradient(135deg, #2563eb, #3b82f6);
  color: #fff;
  border-color: transparent;
}

.nav-btn[disabled] {
  opacity: 0.5;
}

/* 题号面板 */
.sheet-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  visibility: hidden;
  opacity: 0;
  transition: opacity 0.3s;
}

.sheet-overlay.show {
  visibility: visible;
  opacity: 1;
}

.question-sheet {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 48rpx 32rpx;
  max-height: 60vh;
}

.sheet-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 40rpx;
  text-align: center;
}

.sheet-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.sheet-item {
  width: 100%;
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background: #f1f5f9;
  font-size: 28rpx;
  color: #64748b;
}

.sheet-item.answered {
  background: #2563eb;
  color: #fff;
}

.sheet-item.current {
  border: 4rpx solid #2563eb;
}

.sheet-legend {
  display: flex;
  justify-content: center;
  gap: 48rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #64748b;
}

.legend-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 8rpx;
  background: #f1f5f9;
  margin-right: 12rpx;
}

.legend-dot.answered {
  background: #2563eb;
}
