/* pages/my-orders/my-orders.wxss */

.page {
  min-height: 100vh;
  background: #f5f6fa;
  display: flex;
  flex-direction: column;
}

/* Tab 栏 */
.tab-bar {
  display: flex;
  background: #fff;
  padding: 0 16rpx;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 0;
  position: relative;
  color: #64748b;
  font-size: 28rpx;
  font-weight: 500;
}

.tab-item.active {
  color: #2563eb;
}

.tab-line {
  position: absolute;
  bottom: 0;
  width: 48rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #2563eb, #3b82f6);
  border-radius: 3rpx;
}

.tab-badge {
  position: absolute;
  top: 16rpx;
  right: 24rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  background: #ef4444;
  color: #fff;
  font-size: 20rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 骨架屏 */
.skeleton-container {
  padding: 24rpx;
}

.skeleton-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.skeleton-header {
  height: 32rpx;
  width: 60%;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  border-radius: 8rpx;
  margin-bottom: 24rpx;
  animation: shimmer 1.5s infinite;
}

.skeleton-content {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.skeleton-img {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  border-radius: 16rpx;
  animation: shimmer 1.5s infinite;
}

.skeleton-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 16rpx;
}

.skeleton-title {
  height: 32rpx;
  width: 80%;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  border-radius: 8rpx;
  animation: shimmer 1.5s infinite;
}

.skeleton-meta {
  height: 24rpx;
  width: 50%;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  border-radius: 8rpx;
  animation: shimmer 1.5s infinite;
}

.skeleton-footer {
  height: 64rpx;
  width: 100%;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  border-radius: 32rpx;
  animation: shimmer 1.5s infinite;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* 订单滚动区 */
.order-scroll {
  flex: 1;
  padding: 24rpx;
}

/* 订单列表 */
.order-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.order-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 订单头部 */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.order-source {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.source-icon {
  font-size: 32rpx;
}

.source-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
}

.order-status-box {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.status-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: currentColor;
}

.order-status-box.status-pending {
  background: #fef3c7;
  color: #d97706;
}

.order-status-box.status-paid {
  background: #dbeafe;
  color: #2563eb;
}

.order-status-box.status-shipped {
  background: #e0e7ff;
  color: #6366f1;
}

.order-status-box.status-completed {
  background: #d1fae5;
  color: #059669;
}

.order-status-box.status-cancelled {
  background: #f1f5f9;
  color: #94a3b8;
}

.status-text {
  font-size: 24rpx;
  font-weight: 500;
}

/* 订单信息 */
.order-info {
  display: flex;
  padding: 12rpx 28rpx;
  background: #fafbfc;
}

.info-label {
  font-size: 24rpx;
  color: #94a3b8;
}

.info-value {
  font-size: 24rpx;
  color: #64748b;
}

/* 订单商品 */
.order-items {
  padding: 24rpx 28rpx;
}

.order-item {
  display: flex;
  gap: 20rpx;
  padding: 12rpx 0;
}

.order-item + .order-item {
  border-top: 1rpx dashed #e2e8f0;
  padding-top: 24rpx;
  margin-top: 12rpx;
}

.item-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: linear-gradient(135deg, #dbeafe, #e0e7ff);
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.item-title {
  font-size: 28rpx;
  color: #1e293b;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.item-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-price {
  font-size: 30rpx;
  font-weight: 600;
  color: #ef4444;
}

.item-qty {
  font-size: 24rpx;
  color: #94a3b8;
}

/* 订单金额 */
.order-total {
  padding: 0 28rpx 24rpx;
}

.total-info {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 24rpx;
}

.total-count {
  font-size: 24rpx;
  color: #94a3b8;
}

.total-amount {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.amount-label {
  font-size: 24rpx;
  color: #64748b;
}

.amount-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #ef4444;
}

/* 订单操作 */
.order-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  padding: 24rpx 28rpx;
  border-top: 1rpx solid #f1f5f9;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 140rpx;
  height: 64rpx;
  padding: 0 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.action-btn::after {
  border: none;
}

.action-btn.btn-primary {
  background: linear-gradient(135deg, #2563eb, #3b82f6);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.3);
}

.action-btn.btn-cancel {
  background: #f1f5f9;
  color: #94a3b8;
}

.action-btn.btn-outline {
  background: #fff;
  color: #64748b;
  border: 1rpx solid #e2e8f0;
}

.action-btn.btn-text {
  color: #94a3b8;
  min-width: auto;
  padding: 0;
}

.action-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

/* 底部提示 */
.list-footer {
  text-align: center;
  padding: 48rpx 0;
  color: #cbd5e1;
  font-size: 24rpx;
}

/* 空状态 */
.empty-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 96rpx 64rpx;
}

.empty-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #f1f5f9, #e2e8f0);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #94a3b8;
  margin-bottom: 48rpx;
}

.empty-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 64rpx;
  background: linear-gradient(135deg, #2563eb, #3b82f6);
  border-radius: 48rpx;
  box-shadow: 0 4rpx 16rpx rgba(37, 99, 235, 0.3);
}

.empty-btn text {
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
}
