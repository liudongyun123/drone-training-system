/* pages/my-orders/my-orders.wxss */

.page {
  background: var(--bg-color);
  min-height: 100vh;
}

/* Tab 栏 */
.tab-bar {
  display: flex;
  background: #fff;
  padding: 12px 16px;
  border-bottom: 1px solid var(--border-color);
}

.tab-item {
  flex: 1;
  text-align: center;
  font-size: 14px;
  color: var(--text-secondary);
  padding-bottom: 8px;
  position: relative;
}

.tab-item.active {
  color: var(--primary-color);
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 24px;
  height: 2px;
  background: var(--primary-color);
  border-radius: 1px;
}

/* 订单列表 */
.order-list {
  padding: 12px 16px;
}

.order-card {
  background: #fff;
  border-radius: 8px;
  margin-bottom: 12px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 16px;
  border-bottom: 1px solid var(--border-color);
}

.order-type {
  font-size: 14px;
  color: var(--text-color);
}

.order-status {
  font-size: 12px;
  font-weight: 500;
}

.order-status.status-pending {
  color: var(--warning-color);
}

.order-status.status-paid {
  color: var(--primary-color);
}

.order-status.status-completed {
  color: var(--success-color);
}

.order-status.status-cancelled {
  color: var(--text-placeholder);
}

/* 订单商品 */
.order-items {
  padding: 12px 16px;
}

.order-item {
  display: flex;
  padding: 8px 0;
}

.item-image {
  width: 60px;
  height: 60px;
  border-radius: 8px;
  flex-shrink: 0;
  margin-right: 12px;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.item-title {
  font-size: 14px;
  color: var(--text-color);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-price {
  font-size: 14px;
  color: var(--error-color);
}

.item-qty {
  font-size: 12px;
  color: var(--text-placeholder);
}

/* 订单金额 */
.order-total {
  text-align: right;
  padding: 8px 16px 12px;
  font-size: 12px;
  color: var(--text-secondary);
}

.total-price {
  font-size: 16px;
  font-weight: 600;
  color: var(--error-color);
}

/* 订单操作 */
.order-actions {
  display: flex;
  justify-content: flex-end;
  gap: 8px;
  padding: 12px 16px;
  border-top: 1px solid var(--border-color);
}

.action-btn {
  font-size: 12px;
  padding: 6px 12px;
  border-radius: 16px;
  background: #fff;
  color: var(--text-color);
  border: 1px solid var(--border-color);
}

.action-btn.primary {
  background: var(--primary-color);
  color: #fff;
  border-color: var(--primary-color);
}

.action-btn.cancel {
  color: var(--text-secondary);
}