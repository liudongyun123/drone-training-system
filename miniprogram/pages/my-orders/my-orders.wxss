/* pages/my-orders/my-orders.wxss */

.page {
  min-height: 100vh;
  background: #f1f5f9;
}

/* Tab 栏 */
.tab-bar {
  display: flex;
  background: #fff;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #e2e8f0;
}

.tab-item {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #64748b;
  padding-bottom: 16rpx;
  position: relative;
}

.tab-item.active {
  color: #2563eb;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #2563eb;
  border-radius: 2rpx;
}

/* 订单列表 */
.order-list {
  padding: 24rpx 32rpx;
}

.order-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #e2e8f0;
}

.order-type {
  font-size: 28rpx;
  color: #1e293b;
}

.order-status {
  font-size: 24rpx;
  font-weight: 500;
}

.order-status.status-pending {
  color: #f59e0b;
}

.order-status.status-paid {
  color: #2563eb;
}

.order-status.status-completed {
  color: #10b981;
}

.order-status.status-cancelled {
  color: #94a3b8;
}

/* 订单商品 */
.order-items {
  padding: 24rpx 32rpx;
}

.order-item {
  display: flex;
  padding: 16rpx 0;
}

.item-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  margin-right: 24rpx;
  background: linear-gradient(135deg, #dbeafe, #e0e7ff);
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.item-title {
  font-size: 28rpx;
  color: #1e293b;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-price {
  font-size: 28rpx;
  color: #ef4444;
}

.item-qty {
  font-size: 24rpx;
  color: #94a3b8;
}

/* 订单金额 */
.order-total {
  text-align: right;
  padding: 16rpx 32rpx 24rpx;
  font-size: 24rpx;
  color: #64748b;
}

.total-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #ef4444;
}

/* 订单操作 */
.order-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #e2e8f0;
}

.action-btn {
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  background: #fff;
  color: #64748b;
  border: 1rpx solid #e2e8f0;
}

.action-btn.primary {
  background: linear-gradient(135deg, #2563eb, #3b82f6);
  color: #fff;
  border-color: transparent;
}

.action-btn.cancel {
  color: #94a3b8;
}
