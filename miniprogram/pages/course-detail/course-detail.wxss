/* pages/course-detail/course-detail.wxss */

.page {
  min-height: 100vh;
  background: #f1f5f9;
}

/* ==================== 加载状态 ==================== */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.loading-spinner {
  font-size: 48rpx;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16rpx;
  color: #94a3b8;
  font-size: 24rpx;
}

/* ==================== 内容区域 ==================== */
.content {
  height: calc(100vh - 140rpx - env(safe-area-inset-bottom));
  height: calc(100vh - 140rpx - constant(safe-area-inset-bottom));
}

/* ==================== 课程封面/视频 ==================== */
.cover-section {
  position: relative;
}

.cover {
  width: 100%;
  height: 360rpx;
  background: linear-gradient(135deg, #dbeafe, #e0e7ff);
}

/* 课程预览视频 */
.preview-video {
  width: 100%;
  height: 360rpx;
  background: #000;
}

/* 视频标识徽章 */
.video-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: rgba(0, 0, 0, 0.6);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.video-badge-text {
  color: #fff;
  font-size: 22rpx;
}

/* ==================== 课程信息 ==================== */
.info-section {
  background: #fff;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.title-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.level-tag {
  padding: 6rpx 14rpx;
  background: linear-gradient(135deg, #dbeafe, #bfdbfe);
  color: #2563eb;
  font-size: 22rpx;
  border-radius: 8rpx;
}

.course-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
  line-height: 1.3;
}

.meta-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.rating {
  font-size: 24rpx;
  color: #f59e0b;
}

.divider {
  color: #cbd5e1;
}

.students {
  font-size: 24rpx;
  color: #64748b;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.price-symbol {
  font-size: 26rpx;
  color: #ef4444;
}

.price-num {
  font-size: 40rpx;
  font-weight: 800;
  color: #ef4444;
}

.original-price {
  font-size: 26rpx;
  color: #94a3b8;
  text-decoration: line-through;
}

.share-btn {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
}

.share-icon {
  font-size: 28rpx;
}

.share-text {
  font-size: 20rpx;
  color: #64748b;
}

/* ==================== 分区 ==================== */
.section {
  background: #fff;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1e293b;
  display: block;
  margin-bottom: 16rpx;
}

/* ==================== 课程亮点 ==================== */
.features-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.feature-icon {
  color: #10b981;
  font-size: 24rpx;
}

.feature-text {
  font-size: 26rpx;
  color: #475569;
}

/* ==================== 课程简介 ==================== */
.description {
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.6;
}

/* ==================== 讲师信息 ==================== */
.teacher-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.teacher-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #f1f5f9;
}

.teacher-info {
  flex: 1;
}

.teacher-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1e293b;
  display: block;
}

.teacher-title {
  font-size: 22rpx;
  color: #64748b;
}

/* ==================== 课程目录 ==================== */
.lesson-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.lesson-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #f8fafc;
  border-radius: 12rpx;
  padding: 16rpx;
}

.lesson-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.lesson-index {
  width: 36rpx;
  height: 36rpx;
  background: linear-gradient(135deg, #2563eb, #3b82f6);
  color: #fff;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
}

.lesson-info {
  flex: 1;
}

.lesson-title {
  font-size: 26rpx;
  color: #1e293b;
  display: block;
}

.lesson-duration {
  font-size: 22rpx;
  color: #94a3b8;
}

.lesson-play {
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #2563eb, #3b82f6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.play-icon {
  color: #fff;
  font-size: 20rpx;
}

.lesson-lock {
  font-size: 24rpx;
  color: #94a3b8;
}

/* ==================== 底部操作栏 ==================== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  padding-bottom: calc(16rpx + constant(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
  z-index: 999;
}

.action-left {
  display: flex;
  gap: 24rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  font-size: 28rpx;
}

.action-text {
  font-size: 20rpx;
  color: #64748b;
}

.action-right {
  flex: 1;
  display: flex;
  justify-content: flex-end;
}

.btn-start {
  background: linear-gradient(135deg, #2563eb, #3b82f6) !important;
  color: #fff !important;
  border-radius: 40rpx !important;
  padding: 22rpx 48rpx !important;
  font-size: 30rpx !important;
  font-weight: 600 !important;
  box-shadow: 0 4rpx 16rpx rgba(37, 99, 235, 0.4) !important;
  min-width: 200rpx;
  text-align: center;
}

.btn-buy {
  background: linear-gradient(135deg, #ef4444, #f97316) !important;
  color: #fff !important;
  border-radius: 40rpx !important;
  padding: 22rpx 48rpx !important;
  font-size: 30rpx !important;
  font-weight: 600 !important;
  box-shadow: 0 4rpx 16rpx rgba(239, 68, 68, 0.4) !important;
  min-width: 240rpx;
  text-align: center;
}

/* ==================== 底部间距 ==================== */
.footer-space {
  height: 160rpx;
}

/* ==================== 安全区域 ==================== */
.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}