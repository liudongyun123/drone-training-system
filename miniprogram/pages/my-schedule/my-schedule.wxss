/* pages/my-schedule/my-schedule.wxss */

.page {
  background: #f5f5f5;
  min-height: 100vh;
}

/* 日期选择栏 */
.date-bar {
  white-space: nowrap;
  background: #fff;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #eee;
}

.date-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx;
  margin-right: 16rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
}

.date-item.active {
  background: #2563eb;
}

.date-day {
  font-size: 28rpx;
  color: #333;
}

.date-item.active .date-day {
  color: #fff;
}

.date-tag {
  font-size: 20rpx;
  color: #2563eb;
  margin-top: 8rpx;
}

.date-item.active .date-tag {
  color: rgba(255, 255, 255, 0.8);
}

/* 加载状态 */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 200rpx;
  color: #999;
  font-size: 28rpx;
}

/* 日程列表 */
.schedule-list {
  padding: 32rpx;
}

.schedule-item {
  display: flex;
  margin-bottom: 32rpx;
}

.time-line {
  width: 64rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 24rpx;
}

.time-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #2563eb;
  flex-shrink: 0;
}

.time-vertical {
  width: 4rpx;
  flex: 1;
  background: #e0e0e0;
  margin-top: 8rpx;
}

.schedule-card {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.schedule-time {
  font-size: 26rpx;
  color: #2563eb;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.schedule-content {
  margin-bottom: 24rpx;
}

.schedule-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.schedule-teacher {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.schedule-location {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999;
}

.location-icon {
  margin-right: 8rpx;
}

.schedule-status {
  display: flex;
  justify-content: flex-end;
}

.status-tag {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.status-tag.status-not_started {
  background: rgba(153, 153, 153, 0.1);
  color: #999;
}

.status-tag.status-ongoing {
  background: rgba(37, 99, 235, 0.1);
  color: #2563eb;
}

.status-tag.status-ended {
  background: rgba(153, 153, 153, 0.1);
  color: #999;
}

/* 空状态 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
