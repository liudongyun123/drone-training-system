/* pages/result/result.wxss */

.page {
  min-height: 100vh;
  padding-bottom: 48rpx;
}

.page.pass-bg {
  background: linear-gradient(180deg, #dbeafe 0%, #eff6ff 30%, #f8fafc 100%);
}

.page.fail-bg {
  background: linear-gradient(180deg, #fee2e2 0%, #fef2f2 30%, #f8fafc 100%);
}

/* 结果卡片 */
.result-card {
  margin: 24rpx 24rpx 32rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 48rpx 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
}

/* 分数圆环 */
.score-ring-wrap {
  display: flex;
  justify-content: center;
  margin-bottom: 32rpx;
}

.score-ring {
  position: relative;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ring-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 12rpx solid #f1f5f9;
  box-sizing: border-box;
}

.ring-progress {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 12rpx solid transparent;
  border-top-color: #2563eb;
  border-right-color: #2563eb;
  box-sizing: border-box;
  transform: rotate(-45deg);
}

.ring-progress.progress-pass {
  border-top-color: #10b981;
  border-right-color: #10b981;
}

.ring-progress.progress-fail {
  border-top-color: #ef4444;
  border-right-color: #ef4444;
}

.score-inner {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 180rpx;
  height: 180rpx;
  background: #fff;
  border-radius: 50%;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.score-num {
  font-size: 72rpx;
  font-weight: 800;
  color: #1e293b;
  line-height: 1;
}

.score-unit {
  font-size: 28rpx;
  color: #94a3b8;
  margin-top: 4rpx;
}

/* 状态文字 */
.status-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.status-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.status-text {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.status-text.text-pass {
  color: #059669;
}

.status-text.text-fail {
  color: #dc2626;
}

.status-desc {
  font-size: 26rpx;
  color: #64748b;
}

/* 统计行 */
.stats-row {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f8fafc;
  border-radius: 20rpx;
  padding: 28rpx 16rpx;
}

.stat-box {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #1e293b;
  line-height: 1.2;
}

.stat-num.correct {
  color: #10b981;
}

.stat-num.wrong {
  color: #ef4444;
}

.stat-num.accuracy {
  color: #2563eb;
}

.stat-name {
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 8rpx;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: #e2e8f0;
}

/* 答题概览 */
.overview-section {
  margin: 0 24rpx 32rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 24rpx;
}

.question-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.q-item {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  background: #f1f5f9;
  color: #64748b;
  transition: all 0.2s;
}

.q-item.q-correct {
  background: #d1fae5;
  color: #059669;
}

.q-item.q-wrong {
  background: #fee2e2;
  color: #dc2626;
}

.q-item:active {
  transform: scale(0.92);
}

/* 操作区域 */
.action-area {
  padding: 0 48rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-main {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
}

.btn-main::after {
  border: none;
}

.btn-main:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.btn-pass {
  background: linear-gradient(135deg, #10b981, #059669);
}

.btn-fail {
  background: linear-gradient(135deg, #ef4444, #dc2626);
}

.btn-outline {
  background: #fff;
  color: #2563eb;
  border: 2rpx solid #2563eb;
  box-shadow: 0 2rpx 8rpx rgba(37, 99, 235, 0.1);
}

.btn-icon {
  font-size: 32rpx;
}

.btn-text-link {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  color: #94a3b8;
  font-size: 28rpx;
}

.btn-text-link:active {
  color: #64748b;
}

/* 答题详情弹窗 */
.analysis-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  visibility: hidden;
  opacity: 0;
  transition: opacity 0.3s;
}

.analysis-overlay.show {
  visibility: visible;
  opacity: 1;
}

.analysis-sheet {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
}

.sheet-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f1f5f9;
  position: relative;
}

.sheet-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
}

.sheet-close {
  position: absolute;
  right: 32rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #94a3b8;
  background: #f1f5f9;
  border-radius: 50%;
}

.sheet-body {
  flex: 1;
  padding: 32rpx;
  max-height: 200rpx;
}

.question-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.question-thumb {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  background: #f1f5f9;
  color: #64748b;
}

.question-thumb.correct {
  background: #d1fae5;
  color: #059669;
}

.question-thumb.error {
  background: #fee2e2;
  color: #dc2626;
}

/* 题目详情 */
.question-detail {
  padding: 32rpx;
  border-top: 1rpx solid #f1f5f9;
}

.detail-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.detail-num {
  font-size: 28rpx;
  color: #64748b;
}

.detail-type {
  font-size: 24rpx;
  color: #2563eb;
  background: #eff6ff;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.detail-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.detail-status.correct {
  background: #d1fae5;
  color: #059669;
}

.detail-status.error {
  background: #fee2e2;
  color: #dc2626;
}

.detail-title {
  display: block;
  font-size: 30rpx;
  color: #1e293b;
  line-height: 1.6;
  margin-bottom: 32rpx;
  font-weight: 500;
}

.detail-options {
  margin-bottom: 32rpx;
}

.detail-option {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  border: 2rpx solid transparent;
}

.detail-option.user-select {
  border-color: #ef4444;
  background: #fef2f2;
}

.detail-option.correct-select {
  border-color: #10b981;
  background: #ecfdf5;
}

.option-key {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #e2e8f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #64748b;
  margin-right: 20rpx;
  flex-shrink: 0;
  font-weight: 600;
}

.detail-option.correct-select .option-key {
  background: #10b981;
  color: #fff;
}

.detail-option.user-select .option-key {
  background: #ef4444;
  color: #fff;
}

.option-value {
  font-size: 28rpx;
  color: #1e293b;
  line-height: 44rpx;
}

.detail-analysis {
  padding: 24rpx;
  background: #eff6ff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.analysis-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #2563eb;
  margin-bottom: 12rpx;
}

.analysis-content {
  font-size: 26rpx;
  color: #475569;
  line-height: 1.6;
}

.detail-nav {
  display: flex;
  gap: 24rpx;
}

.nav-btn {
  flex: 1;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 20rpx 0;
  background: #f1f5f9;
  border: none;
  color: #475569;
  font-weight: 500;
}

.nav-btn::after {
  border: none;
}

.nav-btn[disabled] {
  opacity: 0.4;
}
