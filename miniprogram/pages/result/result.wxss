/* pages/result/result.wxss */

.page {
  background: linear-gradient(180deg, #2563eb 0%, #f1f5f9 40%);
  min-height: 100vh;
  padding-top: 96rpx;
}

/* 结果概览 */
.result-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx 96rpx;
}

.score-circle {
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fff;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.15);
  margin-bottom: 32rpx;
}

.score-circle.pass {
  border: 8rpx solid #10b981;
}

.score-circle.fail {
  border: 8rpx solid #ef4444;
}

.score-num {
  font-size: 112rpx;
  font-weight: 700;
  color: #1e293b;
}

.score-label {
  font-size: 32rpx;
  color: #64748b;
}

.result-status {
  margin-bottom: 48rpx;
}

.status-text {
  font-size: 48rpx;
  font-weight: 600;
}

.status-text.pass {
  color: #fff;
}

.status-text.fail {
  color: rgba(255, 255, 255, 0.8);
}

.result-stats {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
  padding: 32rpx 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 48rpx;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 600;
  color: #1e293b;
}

.stat-value.correct {
  color: #10b981;
}

.stat-value.error {
  color: #ef4444;
}

.stat-label {
  font-size: 24rpx;
  color: #64748b;
  margin-top: 8rpx;
}

.stat-divider {
  width: 2rpx;
  height: 80rpx;
  background: #e2e8f0;
}

/* 操作按钮 */
.action-buttons {
  padding: 0 64rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #2563eb, #3b82f6);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  padding: 28rpx 0;
  border: none;
}

.btn-secondary {
  background: #fff;
  color: #2563eb;
  border: 1rpx solid #2563eb;
  border-radius: 48rpx;
  font-size: 32rpx;
  padding: 28rpx 0;
}

.btn-text {
  background: transparent;
  color: #64748b;
  font-size: 28rpx;
  padding: 16rpx 0;
}

/* 答题详情弹窗 */
.analysis-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  visibility: hidden;
  opacity: 0;
  transition: opacity 0.3s;
}

.analysis-overlay.show {
  visibility: visible;
  opacity: 1;
}

.analysis-sheet {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.sheet-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #e2e8f0;
  position: relative;
}

.sheet-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
}

.sheet-close {
  position: absolute;
  right: 32rpx;
  font-size: 48rpx;
  color: #94a3b8;
}

.sheet-body {
  flex: 1;
  padding: 32rpx;
  max-height: 240rpx;
}

.question-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.question-thumb {
  width: 72rpx;
  height: 72rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  background: #f1f5f9;
  color: #64748b;
}

.question-thumb.correct {
  background: #10b981;
  color: #fff;
}

.question-thumb.error {
  background: #ef4444;
  color: #fff;
}

/* 题目详情 */
.question-detail {
  padding: 32rpx;
  border-top: 1rpx solid #e2e8f0;
}

.detail-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.detail-num {
  font-size: 28rpx;
  color: #64748b;
}

.detail-type {
  font-size: 24rpx;
  color: #2563eb;
  background: rgba(37, 99, 235, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.detail-status {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.detail-status.correct {
  background: rgba(16, 185, 129, 0.1);
  color: #10b981;
}

.detail-status.error {
  background: rgba(239, 68, 68, 0.1);
  color: #ef4444;
}

.detail-title {
  display: block;
  font-size: 30rpx;
  color: #1e293b;
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.detail-options {
  margin-bottom: 32rpx;
}

.detail-option {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  border-radius: 12rpx;
  background: #f1f5f9;
  border: 1rpx solid transparent;
}

.detail-option.user-select {
  border-color: #ef4444;
}

.detail-option.correct-select {
  border-color: #10b981;
  background: rgba(16, 185, 129, 0.05);
}

.option-key {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #e2e8f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #64748b;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.detail-option.correct-select .option-key {
  background: #10b981;
  color: #fff;
}

.option-value {
  font-size: 28rpx;
  color: #1e293b;
  line-height: 40rpx;
}

.detail-analysis {
  padding: 24rpx;
  background: rgba(37, 99, 235, 0.05);
  border-radius: 16rpx;
}

.analysis-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #2563eb;
  margin-bottom: 16rpx;
}

.analysis-content {
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.6;
}

.detail-nav {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
}

.nav-btn {
  flex: 1;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 20rpx 0;
  background: #fff;
  border: 1rpx solid #e2e8f0;
  color: #64748b;
}

.nav-btn[disabled] {
  opacity: 0.5;
}
