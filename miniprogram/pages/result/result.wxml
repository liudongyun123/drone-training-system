<view class="page {{score >= 60 ? 'pass-bg' : 'fail-bg'}}">
  <!-- 顶部结果区 -->
  <view class="result-card">
    <!-- 分数圆环 -->
    <view class="score-ring-wrap">
      <view class="score-ring {{score >= 60 ? 'ring-pass' : 'ring-fail'}}">
        <view class="score-inner">
          <text class="score-num">{{score}}</text>
          <text class="score-unit">分</text>
        </view>
        <!-- 环形进度背景 -->
        <view class="ring-bg"></view>
        <view class="ring-progress {{score >= 60 ? 'progress-pass' : 'progress-fail'}}" style="--score: {{score}};"></view>
      </view>
    </view>

    <!-- 结果状态 -->
    <view class="status-wrap">
      <text class="status-icon">{{score >= 60 ? '🎉' : '💪'}}</text>
      <text class="status-text {{score >= 60 ? 'text-pass' : 'text-fail'}}">
        {{score >= 60 ? '恭喜通过！' : '未能通过'}}
      </text>
      <text class="status-desc">
        {{score >= 60 ? '表现不错，继续保持！' : '别气馁，再接再厉！'}}
      </text>
    </view>

    <!-- 统计信息 -->
    <view class="stats-row">
      <view class="stat-box">
        <text class="stat-num">{{totalQuestions}}</text>
        <text class="stat-name">总题数</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-box">
        <text class="stat-num correct">{{correctCount}}</text>
        <text class="stat-name">答对</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-box">
        <text class="stat-num wrong">{{totalQuestions - correctCount}}</text>
        <text class="stat-name">答错</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-box">
        <text class="stat-num accuracy">{{totalQuestions > 0 ? Math.round(correctCount / totalQuestions * 100) : 0}}%</text>
        <text class="stat-name">正确率</text>
      </view>
    </view>
  </view>

  <!-- 答题概览 -->
  <view class="overview-section" wx:if="{{questionResults.length > 0}}">
    <view class="section-title">答题概览</view>
    <view class="question-grid">
      <view 
        class="q-item {{item.isCorrect ? 'q-correct' : 'q-wrong'}}"
        wx:for="{{questionResults}}"
        wx:key="index"
        bindtap="showQuestionDetail"
        data-index="{{index}}"
      >
        {{index + 1}}
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-area">
    <button class="btn-main {{score >= 60 ? 'btn-pass' : 'btn-fail'}}" bindtap="retry">
      <text class="btn-icon">🔄</text>
      <text>重新做题</text>
    </button>
    <button class="btn-main btn-outline" bindtap="showAnalysis">
      <text class="btn-icon">📖</text>
      <text>查看解析</text>
    </button>
    <view class="btn-text-link" bindtap="goBack">
      <text>↩ 返回练习中心</text>
    </view>
  </view>

  <!-- 答题详情弹窗 -->
  <view class="analysis-overlay {{showAnalysis ? 'show' : ''}}" bindtap="hideAnalysis">
    <view class="analysis-sheet" catchtap="">
      <view class="sheet-header">
        <text class="sheet-title">答题详情</text>
        <text class="sheet-close" bindtap="hideAnalysis">✕</text>
      </view>

      <!-- 题目列表 -->
      <scroll-view scroll-y class="sheet-body">
        <view class="question-list">
          <view 
            class="question-thumb {{item.isCorrect ? 'correct' : 'error'}}"
            wx:for="{{questionResults}}"
            wx:key="index"
            bindtap="showQuestionDetail"
            data-index="{{index}}"
          >
            {{index + 1}}
          </view>
        </view>
      </scroll-view>

      <!-- 单题详情 -->
      <view class="question-detail" wx:if="{{questionResults[currentAnalysisIndex]}}">
        <view class="detail-header">
          <text class="detail-num">第 {{currentAnalysisIndex + 1}} 题</text>
          <text class="detail-type">
            {{questionResults[currentAnalysisIndex].question.type === 'single' ? '单选' : questionResults[currentAnalysisIndex].question.type === 'multiple' ? '多选' : '判断'}}
          </text>
          <text class="detail-status {{questionResults[currentAnalysisIndex].isCorrect ? 'correct' : 'error'}}">
            {{questionResults[currentAnalysisIndex].isCorrect ? '正确' : '错误'}}
          </text>
        </view>

        <text class="detail-title">{{questionResults[currentAnalysisIndex].question.title}}</text>

        <view class="detail-options">
          <view class="detail-option {{item.isUserAnswer ? 'user-select' : ''}} {{item.isCorrectAnswer ? 'correct-select' : ''}}"
            wx:for="{{questionResults[currentAnalysisIndex].question.options}}"
            wx:for-index="optIndex"
            wx:key="optIndex"
          >
            <text class="option-key">{{String.fromCharCode(65 + optIndex)}}</text>
            <text class="option-value">{{item}}</text>
          </view>
        </view>

        <view class="detail-analysis">
          <text class="analysis-title">💡 解析</text>
          <text class="analysis-content">{{questionResults[currentAnalysisIndex].question.analysis || '暂无解析'}}</text>
        </view>

        <view class="detail-nav">
          <button class="nav-btn" bindtap="prevQuestion" disabled="{{currentAnalysisIndex === 0}}">上一题</button>
          <button class="nav-btn" bindtap="nextQuestion" disabled="{{currentAnalysisIndex === questionResults.length - 1}}">下一题</button>
        </view>
      </view>
    </view>
  </view>
</view>
