<view class="page">
  <!-- 结果概览 -->
  <view class="result-header">
    <view class="score-circle {{score >= 60 ? 'pass' : 'fail'}}">
      <text class="score-num">{{score}}</text>
      <text class="score-label">分</text>
    </view>
    <view class="result-status">
      <text wx:if="{{score >= 60}}" class="status-text pass">恭喜通过！</text>
      <text wx:else class="status-text fail">未能通过</text>
    </view>
    <view class="result-stats">
      <view class="stat-item">
        <text class="stat-value">{{totalQuestions}}</text>
        <text class="stat-label">总题数</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value correct">{{correctCount}}</text>
        <text class="stat-label">答对</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value error">{{totalQuestions - correctCount}}</text>
        <text class="stat-label">答错</text>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-buttons">
    <button class="btn-primary" bindtap="retry">重新做题</button>
    <button class="btn-secondary" bindtap="showAnalysis">查看解析</button>
    <button class="btn-text" bindtap="goBack">返回练习中心</button>
  </view>

  <!-- 答题详情弹窗 -->
  <view class="analysis-overlay {{showAnalysis ? 'show' : ''}}" bindtap="hideAnalysis">
    <view class="analysis-sheet" catchtap="">
      <view class="sheet-header">
        <text class="sheet-title">答题详情</text>
        <text class="sheet-close" bindtap="hideAnalysis">×</text>
      </view>

      <!-- 题目列表 -->
      <scroll-view scroll-y class="sheet-body">
        <view class="question-list">
          <view 
            class="question-thumb {{item.isCorrect ? 'correct' : 'error'}}"
            wx:for="{{questionResults}}"
            wx:key="index"
            bindtap="showQuestionDetail"
            data-index="{{index}}"
          >
            {{index + 1}}
          </view>
        </view>
      </scroll-view>

      <!-- 单题详情 -->
      <view class="question-detail" wx:if="{{questionResults[currentAnalysisIndex]}}">
        <view class="detail-header">
          <text class="detail-num">第 {{currentAnalysisIndex + 1}} 题</text>
          <text class="detail-type">
            {{questionResults[currentAnalysisIndex].question.type === 'single' ? '单选' : 
              questionResults[currentAnalysisIndex].question.type === 'multiple' ? '多选' : '判断'}}
          </text>
          <text class="detail-status {{questionResults[currentAnalysisIndex].isCorrect ? 'correct' : 'error'}}">
            {{questionResults[currentAnalysisIndex].isCorrect ? '正确' : '错误'}}
          </text>
        </view>

        <text class="detail-title">{{questionResults[currentAnalysisIndex].question.title}}</text>

        <view class="detail-options">
          <view 
            class="detail-option 
              {{questionResults[currentAnalysisIndex].userAnswer.includes(String.fromCharCode(65 + index)) ? 'user-select' : ''}}
              {{questionResults[currentAnalysisIndex].correctAnswer.includes(String.fromCharCode(65 + index)) || 
                (questionResults[currentAnalysisIndex].correctAnswer.includes(String.fromCharCode(65 + index).toLowerCase())) ? 'correct-select' : ''}}"
            wx:for="{{questionResults[currentAnalysisIndex].question.options}}"
            wx:key="index"
          >
            <text class="option-key">{{String.fromCharCode(65 + index)}}</text>
            <text class="option-value">{{item}}</text>
          </view>
        </view>

        <view class="detail-analysis">
          <text class="analysis-title">解析</text>
          <text class="analysis-content">{{questionResults[currentAnalysisIndex].question.analysis || '暂无解析'}}</text>
        </view>

        <view class="detail-nav">
          <button class="nav-btn" bindtap="prevQuestion" disabled="{{currentAnalysisIndex === 0}}">上一题</button>
          <button class="nav-btn" bindtap="nextQuestion" disabled="{{currentAnalysisIndex === questionResults.length - 1}}">下一题</button>
        </view>
      </view>
    </view>
  </view>
</view>