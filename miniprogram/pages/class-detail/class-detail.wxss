/* pages/class-detail/class-detail.wxss */
.page { background: #f6f6f6; min-height: 100vh; padding-bottom: 70px; }
.loading-container { display: flex; justify-content: center; padding: 48px; color: #999; }

.info-card { background: #fff; margin: 12px; border-radius: 8px; padding: 16px; }
.class-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
.class-name { font-size: 20px; font-weight: 600; color: #333; }
.status-tag { font-size: 12px; padding: 4px 12px; border-radius: 12px; background: #f0f0f0; color: #999; }
.status-tag.active { background: #e6f7ff; color: #1890ff; }

.info-row { display: flex; padding: 8px 0; border-bottom: 1px solid #f5f5f5; }
.info-row:last-child { border-bottom: none; }
.label { width: 80px; color: #999; font-size: 14px; flex-shrink: 0; }
.value { flex: 1; color: #333; font-size: 14px; }

.price-section { text-align: right; margin-top: 16px; padding-top: 12px; border-top: 1px solid #f0f0f0; }
.price { color: #ff4d4f; }
.price-symbol { font-size: 14px; }
.price-num { font-size: 28px; font-weight: 600; }
.price-label { font-size: 14px; color: #999; margin-left: 4px; }

.section { background: #fff; margin: 12px; border-radius: 8px; padding: 16px; }
.section-title { font-size: 16px; font-weight: 600; color: #333; display: block; margin-bottom: 12px; }
.description { font-size: 14px; color: #666; line-height: 1.8; }

.schedule-list { max-height: 300px; overflow-y: auto; }
.schedule-item { padding: 12px 0; border-bottom: 1px solid #f5f5f5; }
.schedule-item:last-child { border-bottom: none; }
.schedule-date { font-size: 14px; font-weight: 600; color: #333; display: block; }
.schedule-time { font-size: 12px; color: #999; display: block; margin: 4px 0; }
.schedule-topic { font-size: 13px; color: #666; display: block; }

.included-courses { display: flex; flex-wrap: wrap; gap: 8px; }
.course-tag { background: #e6f7ff; color: #1890ff; font-size: 12px; padding: 6px 12px; border-radius: 4px; }

.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; border-top: 1px solid #e8e8e8; }
.btn-enroll { margin: 8px 16px; height: 44px; background: #1890ff; color: #fff; border-radius: 22px; display: flex; align-items: center; justify-content: center; font-size: 16px; font-weight: 600; }
.btn-enroll.disabled { background: #d9d9d9; }