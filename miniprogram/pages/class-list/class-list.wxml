<view class="page">
  <!-- 培训班列表 -->
  <view class="class-list">
    <view 
      class="class-card" 
      wx:for="{{classList}}" 
      wx:key="_id"
      bindtap="goToDetail"
      data-id="{{item._id}}"
    >
      <image class="class-cover" src="{{item.coverImage || '/assets/images/default-cover.png'}}" mode="aspectFill" />
      <view class="class-info">
        <text class="class-title">{{item.title}}</text>
        <text class="class-desc">{{item.description}}</text>
        <view class="class-meta">
          <text class="meta-item">📅 {{item.startDate}}</text>
          <text class="meta-item">📍 {{item.location}}</text>
        </view>
        <view class="class-footer">
          <view class="price">
            <text class="price-symbol">¥</text>
            <text class="price-num">{{item.price}}</text>
          </view>
          <view class="status-tag">
            <text wx:if="{{item.status === 'enrolling'}}" class="tag enrolling">报名中</text>
            <text wx:elif="{{item.status === 'ongoing'}}" class="tag ongoing">进行中</text>
            <text wx:elif="{{item.status === 'ended'}}" class="tag ended">已结束</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="load-more">
    <text wx:if="{{loading}}">加载中...</text>
    <text wx:elif="{{!hasMore && classList.length > 0}}">— 没有更多了 —</text>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{!loading && classList.length === 0}}" class="empty-container">
    <text>暂无报名中的培训班</text>
  </view>
</view>