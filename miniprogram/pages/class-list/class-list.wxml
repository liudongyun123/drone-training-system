<!--pages/class-list/class-list.wxml-->

<view class="page">
  <!-- 搜索框 -->
  <view class="search-box">
    <view class="search-input" bindtap="goToSearch">
      <text class="search-icon">🔍</text>
      <text class="search-placeholder">{{searchKeyword || '搜索培训班...'}}</text>
    </view>
  </view>

  <!-- 体系切换 Tab（动态渲染） -->
  <view class="source-tabs">
    <view 
      class="source-tab {{currentSource === item.key ? 'active' : ''}}"
      wx:for="{{sourceList}}"
      wx:key="key"
      bindtap="switchSource"
      data-source="{{item.key}}"
    >
      <text class="source-icon">{{item.icon}}</text>
      <text class="source-name">{{item.name}}</text>
    </view>
  </view>

  <!-- 分类筛选 -->
  <scroll-view class="category-bar" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="category-scroll">
      <view 
        class="category-item {{currentCategory === '' ? 'active' : ''}}"
        bindtap="switchCategory"
        data-category=""
      >
        全部
      </view>
      <view 
        class="category-item {{currentCategory === item ? 'active' : ''}}"
        wx:for="{{categories}}"
        wx:key="*this"
        bindtap="switchCategory"
        data-category="{{item}}"
      >
        {{item}}
      </view>
    </view>
  </scroll-view>

  <!-- 状态筛选（选中分类后显示） -->
  <view class="status-bar" wx:if="{{currentCategory !== ''}}">
    <view 
      class="status-item {{currentStatus === '' ? 'active' : ''}}"
      bindtap="switchStatus"
      data-status=""
    >
      <text>全部</text>
    </view>
    <view 
      class="status-item {{currentStatus === 'enrolling' ? 'active' : ''}}"
      bindtap="switchStatus"
      data-status="enrolling"
    >
      <text>招生中</text>
    </view>
    <view 
      class="status-item {{currentStatus === 'ongoing' ? 'active' : ''}}"
      bindtap="switchStatus"
      data-status="ongoing"
    >
      <text>进行中</text>
    </view>
    <view 
      class="status-item {{currentStatus === 'ended' ? 'active' : ''}}"
      bindtap="switchStatus"
      data-status="ended"
    >
      <text>已结束</text>
    </view>
  </view>

  <!-- 培训班列表 -->
  <scroll-view class="class-scroll" scroll-y enhanced>
    <view class="class-list">
      <view 
        class="class-card" 
        wx:for="{{classList}}" 
        wx:key="_id"
        bindtap="goToDetail"
        data-id="{{item._id}}"
      >
        <image class="class-cover" src="{{item.coverImage || item.cover}}" mode="aspectFill" />
        <view class="class-info">
          <view class="class-header">
            <text class="class-level" wx:if="{{item.levelText}}">{{item.levelText}}</text>
            <text class="class-name">{{item.name}}</text>
          </view>
          <view class="class-meta">
            <view class="meta-row">
              <text class="meta-icon">📅</text>
              <text class="meta-text">{{item.startDate}} - {{item.endDate}}</text>
            </view>
            <view class="meta-row" wx:if="{{item.location}}">
              <text class="meta-icon">📍</text>
              <text class="meta-text">{{item.location}}</text>
            </view>
          </view>
          <view class="class-footer">
            <view class="price">
              <text class="price-symbol">¥</text>
              <text class="price-num">{{item.price || '待定'}}</text>
            </view>
            <view class="status-tag {{item.status}}">
              <text wx:if="{{item.status === 'enrolling'}}">招生中</text>
              <text wx:elif="{{item.status === 'ongoing'}}">进行中</text>
              <text wx:else>已结束</text>
            </view>
          </view>
          <view class="class-count" wx:if="{{item.status === 'enrolling'}}">
            <text>{{item.enrolledStudents || 0}}/{{item.maxStudents}}人</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 加载状态 -->
    <view class="load-more">
      <text wx:if="{{loading}}" class="loading-text">加载中...</text>
      <text wx:elif="{{!hasMore && classList.length > 0}}" class="end-text">— 没有更多了 —</text>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{!loading && classList.length === 0}}" class="empty-container">
      <text class="empty-icon">📭</text>
      <text class="empty-text">暂无相关培训班</text>
    </view>

    <!-- 底部间距 -->
    <view class="footer-space"></view>
  </scroll-view>
</view>