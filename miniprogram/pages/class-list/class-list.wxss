/* pages/class-list/class-list.wxss */

.page {
  background: var(--bg-color);
  min-height: 100vh;
}

/* 培训班列表 */
.class-list {
  padding: 12px 16px;
}

.class-card {
  display: flex;
  background: #fff;
  border-radius: 8px;
  margin-bottom: 12px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.class-cover {
  width: 140px;
  height: 130px;
  flex-shrink: 0;
}

.class-info {
  flex: 1;
  padding: 12px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.class-title {
  font-size: 15px;
  font-weight: 600;
  color: var(--text-color);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.class-desc {
  font-size: 12px;
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.class-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.meta-item {
  font-size: 12px;
  color: var(--text-placeholder);
}

.class-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.price {
  color: var(--error-color);
}

.price-symbol {
  font-size: 12px;
}

.price-num {
  font-size: 18px;
  font-weight: 600;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 2px 8px;
  font-size: 12px;
  border-radius: 4px;
}

.tag.enrolling {
  background: rgba(82, 196, 26, 0.1);
  color: var(--success-color);
}

.tag.ongoing {
  background: rgba(24, 144, 255, 0.1);
  color: var(--primary-color);
}

.tag.ended {
  background: rgba(153, 153, 153, 0.1);
  color: var(--text-placeholder);
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 16px;
  color: #999;
  font-size: 14px;
}