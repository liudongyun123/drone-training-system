<!--pages/profile/profile.wxml - 个人中心-->

<view class="page">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <view class="loading-ring"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:else>
    <!-- ==================== 用户头部 ==================== -->
    <view class="user-header">
      <view class="user-header-bg"></view>
      
      <!-- 用户信息 -->
      <view class="user-info">
        <view class="avatar-wrap" bindtap="chooseAvatar">
          <image 
            class="avatar" 
            src="{{userInfo.avatarUrl || '/assets/icons/profile.png'}}" 
            mode="aspectFill" 
          />
          <view class="avatar-edit">
            <text>编辑</text>
          </view>
        </view>
        
        <view class="user-detail">
          <view class="user-name-row">
            <text class="user-name">{{userInfo.nickName || '未登录'}}</text>
            <view class="member-badge" wx:if="{{memberLevel !== 'free'}}">
              <text class="badge-icon">⭐</text>
              <text class="badge-text">{{memberLevel === 'gold' ? '金牌' : '银牌'}}</text>
            </view>
          </view>
          <text class="user-phone" wx:if="{{userInfo.phone}}">{{userInfo.phone}}</text>
          <text class="user-phone bind-hint" wx:else bindtap="bindPhone">点击绑定手机号</text>
        </view>
      </view>

      <!-- 学习统计 -->
      <view class="stats-bar" wx:if="{{stats}}">
        <view class="stat-item">
          <text class="stat-num">{{stats.courseCount || 0}}</text>
          <text class="stat-label">在学课程</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-num">{{stats.learningHours || 0}}</text>
          <text class="stat-label">学习时长</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-num">{{stats.certificateCount || 0}}</text>
          <text class="stat-label">获得证书</text>
        </view>
      </view>
    </view>

    <!-- ==================== 会员卡片（可升级） ==================== -->
    <view class="member-card" wx:if="{{memberLevel === 'free'}}" bindtap="upgradeMember">
      <view class="member-left">
        <text class="member-icon">👑</text>
        <view class="member-info">
          <text class="member-title">开通金牌会员</text>
          <text class="member-desc">享受更多特权与服务</text>
        </view>
      </view>
      <view class="member-action">
        <text>立即开通</text>
        <text class="action-arrow">›</text>
      </view>
    </view>

    <!-- ==================== 学习服务 ==================== -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">学习服务</text>
      </view>
      
      <view class="grid-menu">
        <view class="grid-item" bindtap="goToMyLearning">
          <view class="grid-icon blue">
            <text>📚</text>
          </view>
          <text class="grid-label">我的学习</text>
          <text class="grid-badge" wx:if="{{stats?.courseCount > 0}}">{{stats.courseCount}}</text>
        </view>
        
        <view class="grid-item" bindtap="goToMyClasses">
          <view class="grid-icon amber">
            <text>🎓</text>
          </view>
          <text class="grid-label">我的培训班</text>
        </view>
        
        <view class="grid-item" bindtap="goToMySchedule">
          <view class="grid-icon green">
            <text>📅</text>
          </view>
          <text class="grid-label">我的日程</text>
        </view>
        
        <view class="grid-item" bindtap="goToPractice">
          <view class="grid-icon purple">
            <text>✏️</text>
          </view>
          <text class="grid-label">练习中心</text>
        </view>
      </view>
    </view>

    <!-- ==================== 订单服务 ==================== -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">订单服务</text>
        <text class="section-more" bindtap="goToMyOrders">全部订单 ›</text>
      </view>
      
      <view class="order-cards">
        <view class="order-card" bindtap="goToCart">
          <view class="order-icon-wrap orange">
            <text class="order-icon">🛒</text>
            <view class="order-badge" wx:if="{{cartCount > 0}}">{{cartCount}}</view>
          </view>
          <text class="order-label">购物车</text>
        </view>
        
        <view class="order-card" bindtap="goToMyOrders" data-status="pending">
          <view class="order-icon-wrap blue">
            <text class="order-icon">⏰</text>
          </view>
          <text class="order-label">待支付</text>
        </view>
        
        <view class="order-card" bindtap="goToMyOrders" data-status="shipped">
          <view class="order-icon-wrap green">
            <text class="order-icon">🚚</text>
          </view>
          <text class="order-label">待收货</text>
        </view>
        
        <view class="order-card" bindtap="goToMyCertificates">
          <view class="order-icon-wrap gold">
            <text class="order-icon">🏆</text>
          </view>
          <text class="order-label">我的证书</text>
        </view>
      </view>
    </view>

    <!-- ==================== 快捷工具 ==================== -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">快捷工具</text>
      </view>
      
      <view class="tool-grid">
        <view class="tool-item" bindtap="contactService">
          <view class="tool-icon">
            <text>📞</text>
          </view>
          <text class="tool-label">联系客服</text>
        </view>
        
        <view class="tool-item" bindtap="showAbout">
          <view class="tool-icon">
            <text>ℹ️</text>
          </view>
          <text class="tool-label">关于我们</text>
        </view>
        
        <view class="tool-item" bindtap="showHelp">
          <view class="tool-icon">
            <text>❓</text>
          </view>
          <text class="tool-label">帮助中心</text>
        </view>
        
        <view class="tool-item" bindtap="showSettings">
          <view class="tool-icon">
            <text>⚙️</text>
          </view>
          <text class="tool-label">设置</text>
        </view>
      </view>
    </view>

    <!-- ==================== 退出登录 ==================== -->
    <view class="logout-section">
      <view class="logout-btn" bindtap="logout">
        <text>退出登录</text>
      </view>
    </view>

    <!-- 底部间距 -->
    <view class="footer-space"></view>
  </block>
</view>
