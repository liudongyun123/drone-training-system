<!--pages/profile/profile.wxml - 个人中心-->

<view class="page">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <text class="loading-spinner">⏳</text>
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:else>
    <!-- ==================== 用户头部 ==================== -->
    <view class="user-header">
      <view class="user-header-bg"></view>
      <view class="user-info">
        <view class="avatar-box" bindtap="chooseAvatar">
          <image 
            class="avatar" 
            src="{{userInfo.avatarUrl || 'https://via.placeholder.com/100?text=头像'}}" 
            mode="aspectFill" 
          />
        </view>
        <view class="user-detail">
          <text class="user-name">{{userInfo.nickName || '未登录'}}</text>
          <view class="user-phone-row">
            <text class="user-phone">{{userInfo.phone || '未绑定手机'}}</text>
            <text wx:if="{{!userInfo.phone}}" class="bind-btn" bindtap="bindPhone">去绑定</text>
          </view>
        </view>
      </view>
    </view>

    <!-- ==================== 学习相关 ==================== -->
    <view class="section">
      <view class="menu-card" bindtap="goToMyLearning">
        <view class="menu-icon-box blue">
          <text class="menu-icon">📚</text>
        </view>
        <text class="menu-title">我的学习</text>
        <text class="menu-desc">在线课程进度</text>
        <text class="menu-arrow">›</text>
      </view>
      
      <view class="menu-card" bindtap="goToMyClasses">
        <view class="menu-icon-box amber">
          <text class="menu-icon">🎓</text>
        </view>
        <text class="menu-title">我的培训班</text>
        <text class="menu-desc">线下培训报名</text>
        <text class="menu-arrow">›</text>
      </view>
      
      <view class="menu-card" bindtap="goToMySchedule">
        <view class="menu-icon-box green">
          <text class="menu-icon">📅</text>
        </view>
        <text class="menu-title">我的日程</text>
        <text class="menu-desc">上课时间安排</text>
        <text class="menu-arrow">›</text>
      </view>
      
      <view class="menu-card" bindtap="goToPractice">
        <view class="menu-icon-box purple">
          <text class="menu-icon">✏️</text>
        </view>
        <text class="menu-title">练习记录</text>
        <text class="menu-desc">模拟考试备考</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <!-- ==================== 购物相关 ==================== -->
    <view class="section">
      <view class="menu-card" bindtap="goToCart">
        <view class="menu-icon-box orange">
          <text class="menu-icon">🛒</text>
        </view>
        <text class="menu-title">购物车</text>
        <text class="menu-desc" wx:if="{{cartCount > 0}}">{{cartCount}}件商品</text>
        <text class="menu-arrow">›</text>
      </view>
      
      <view class="menu-card" bindtap="goToMyOrders">
        <view class="menu-icon-box cyan">
          <text class="menu-icon">📦</text>
        </view>
        <text class="menu-title">我的订单</text>
        <text class="menu-desc">配件购买记录</text>
        <text class="menu-arrow">›</text>
      </view>
      
      <view class="menu-card" bindtap="goToMyCertificates">
        <view class="menu-icon-box gold">
          <text class="menu-icon">📜</text>
        </view>
        <text class="menu-title">我的证书</text>
        <text class="menu-desc">培训结业证明</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <!-- ==================== 其他 ==================== -->
    <view class="section">
      <view class="menu-card" bindtap="contactService">
        <view class="menu-icon-box gray">
          <text class="menu-icon">📞</text>
        </view>
        <text class="menu-title">联系客服</text>
        <text class="menu-desc">咨询答疑</text>
        <text class="menu-arrow">›</text>
      </view>
      
      <view class="menu-card" bindtap="showAbout">
        <view class="menu-icon-box gray">
          <text class="menu-icon">ℹ️</text>
        </view>
        <text class="menu-title">关于我们</text>
        <text class="menu-desc">无人机培训中心</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <!-- ==================== 退出登录 ==================== -->
    <view class="logout-section">
      <button class="btn-logout" bindtap="logout">退出登录</button>
    </view>

    <!-- 底部间距 -->
    <view class="footer-space"></view>
  </block>
</view>