<view class="page">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <text>加载中...</text>
  </view>

  <block wx:if="{{!loading && userInfo}}">
    <!-- 头像区域 -->
    <view class="avatar-section">
      <view class="avatar-wrapper" bindtap="chooseAvatar">
        <image 
          class="avatar" 
          src="{{userInfo.avatar || '/assets/images/default-avatar.png'}}" 
          mode="aspectFill" 
        />
        <view class="avatar-edit">
          <text>编辑</text>
        </view>
      </view>
    </view>

    <!-- 基本信息 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">基本信息</text>
        <text wx:if="{{!editing}}" class="edit-btn" bindtap="startEdit">编辑</text>
      </view>

      <!-- 昵称 -->
      <view class="info-item">
        <text class="info-label">昵称</text>
        <input 
          wx:if="{{editing}}"
          class="info-input" 
          value="{{tempNickname}}" 
          bindinput="onNicknameInput"
          placeholder="请输入昵称"
        />
        <text wx:else class="info-value">{{userInfo.nickname || '未设置'}}</text>
      </view>

      <!-- 手机号 -->
      <view class="info-item">
        <text class="info-label">手机号</text>
        <input 
          wx:if="{{editing}}"
          class="info-input" 
          value="{{tempPhone}}" 
          bindinput="onPhoneInput"
          placeholder="请输入手机号"
          type="number"
          maxlength="11"
        />
        <block wx:else>
          <text class="info-value">{{userInfo.phone || '未绑定'}}</text>
          <text wx:if="{{!userInfo.phone}}" class="bind-btn" bindtap="bindPhone">去绑定</text>
        </block>
      </view>

      <!-- 注册时间 -->
      <view class="info-item">
        <text class="info-label">注册时间</text>
        <text class="info-value">{{userInfo.createdAt}}</text>
      </view>
    </view>

    <!-- 编辑操作 -->
    <view wx:if="{{editing}}" class="edit-actions">
      <button class="btn-cancel" bindtap="cancelEdit">取消</button>
      <button class="btn-save" bindtap="saveEdit">保存</button>
    </view>

    <!-- 账号安全 -->
    <view class="section" wx:if="{{!editing}}">
      <text class="section-title">账号安全</text>
      <view class="info-item" bindtap="bindPhone">
        <text class="info-label">修改密码</text>
        <text class="arrow">></text>
      </view>
    </view>

    <!-- 退出登录 -->
    <view class="logout-section" wx:if="{{!editing}}">
      <button class="btn-logout" bindtap="logout">退出登录</button>
    </view>
  </block>
</view>