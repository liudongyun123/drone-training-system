/* pages/profile/profile.wxss - 个人中心样式 */

.page {
  min-height: 100vh;
  background: #f1f5f9;
}

/* ==================== 用户头部 ==================== */
.user-header {
  position: relative;
  padding: 48rpx 24rpx 32rpx;
  margin-bottom: 16rpx;
}

.user-header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: -16rpx;
  background: linear-gradient(135deg, #2563eb 0%, #4f46e5 100%);
  border-radius: 0 0 32rpx 32rpx;
}

.user-info {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar-box {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.avatar {
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.2);
}

.user-detail {
  flex: 1;
}

.user-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}

.user-phone-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.user-phone {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.bind-btn {
  font-size: 22rpx;
  color: #fff;
  padding: 4rpx 12rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
}

/* ==================== 分区 ==================== */
.section {
  margin: 0 24rpx 16rpx;
}

/* ==================== 菜单卡片 ==================== */
.menu-card {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.menu-card:last-child {
  margin-bottom: 0;
}

.menu-icon-box {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.menu-icon-box.blue {
  background: linear-gradient(135deg, #dbeafe, #bfdbfe);
}

.menu-icon-box.amber {
  background: linear-gradient(135deg, #fef3c7, #fde68a);
}

.menu-icon-box.green {
  background: linear-gradient(135deg, #d1fae5, #a7f3d0);
}

.menu-icon-box.purple {
  background: linear-gradient(135deg, #e9d5ff, #d8b4fe);
}

.menu-icon-box.orange {
  background: linear-gradient(135deg, #ffedd5, #fed7aa);
}

.menu-icon-box.cyan {
  background: linear-gradient(135deg, #cffafe, #a5f3fc);
}

.menu-icon-box.gold {
  background: linear-gradient(135deg, #fef3c7, #fde68a);
}

.menu-icon-box.gray {
  background: linear-gradient(135deg, #f1f5f9, #e2e8f0);
}

.menu-icon {
  font-size: 24rpx;
}

.menu-title {
  flex: 0 0 auto;
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  margin-right: 16rpx;
}

.menu-desc {
  flex: 1;
  font-size: 22rpx;
  color: #94a3b8;
  text-align: right;
}

.menu-arrow {
  font-size: 32rpx;
  color: #cbd5e1;
  margin-left: 8rpx;
}

/* ==================== 退出登录 ==================== */
.logout-section {
  margin: 32rpx 24rpx;
}

.btn-logout {
  width: 100%;
  height: 88rpx;
  background: #fff;
  border: 1rpx solid #e2e8f0;
  border-radius: 16rpx;
  color: #ef4444;
  font-size: 28rpx;
  font-weight: 500;
}

.btn-logout:active {
  background: #fef2f2;
}

/* ==================== 加载状态 ==================== */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.loading-spinner {
  font-size: 48rpx;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16rpx;
  color: #94a3b8;
  font-size: 24rpx;
}

/* ==================== 底部间距 ==================== */
.footer-space {
  height: 32rpx;
}