/* pages/profile/profile.wxss - 个人中心样式 */

.page {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ==================== 加载状态 ==================== */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-ring {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid #e2e8f0;
  border-top-color: #2563eb;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  color: #94a3b8;
  font-size: 28rpx;
}

/* ==================== 用户头部 ==================== */
.user-header {
  position: relative;
  padding: 64rpx 32rpx 32rpx;
  margin-bottom: 24rpx;
}

.user-header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #2563eb 0%, #4f46e5 100%);
  border-radius: 0 0 48rpx 48rpx;
}

.user-info {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

/* 头像 */
.avatar-wrap {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  flex-shrink: 0;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.4);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  background: rgba(255, 255, 255, 0.2);
}

.avatar-edit {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 18rpx;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  white-space: nowrap;
}

/* 用户信息 */
.user-detail {
  flex: 1;
}

.user-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.user-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.member-badge {
  display: flex;
  align-items: center;
  gap: 4rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 6rpx 12rpx;
  border-radius: 16rpx;
}

.badge-icon {
  font-size: 20rpx;
}

.badge-text {
  font-size: 20rpx;
  color: #fef3c7;
  font-weight: 500;
}

.user-phone {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.bind-hint {
  color: #fef3c7;
  background: rgba(255, 255, 255, 0.15);
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}

/* 学习统计 */
.stats-bar {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10px);
  border-radius: 20rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.2;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 4rpx;
}

.stat-divider {
  width: 2rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.2);
}

/* ==================== 会员卡片 ==================== */
.member-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 0 24rpx 24rpx;
  padding: 28rpx 32rpx;
  background: linear-gradient(135deg, #fef3c7, #fde68a);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(251, 191, 36, 0.2);
}

.member-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.member-icon {
  font-size: 48rpx;
}

.member-info {
  display: flex;
  flex-direction: column;
}

.member-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #92400e;
}

.member-desc {
  font-size: 22rpx;
  color: #a16207;
  margin-top: 4rpx;
}

.member-action {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 26rpx;
  color: #92400e;
  font-weight: 500;
}

.action-arrow {
  font-size: 32rpx;
}

/* ==================== 分区 ==================== */
.section {
  margin: 0 24rpx 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 4rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
}

.section-more {
  font-size: 26rpx;
  color: #94a3b8;
}

/* ==================== 网格菜单 ==================== */
.grid-menu {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.grid-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.grid-icon text {
  font-size: 36rpx;
}

.grid-icon.blue {
  background: linear-gradient(135deg, #dbeafe, #bfdbfe);
}

.grid-icon.amber {
  background: linear-gradient(135deg, #fef3c7, #fde68a);
}

.grid-icon.green {
  background: linear-gradient(135deg, #d1fae5, #a7f3d0);
}

.grid-icon.purple {
  background: linear-gradient(135deg, #e9d5ff, #d8b4fe);
}

.grid-label {
  font-size: 24rpx;
  color: #475569;
  font-weight: 500;
}

.grid-badge {
  position: absolute;
  top: -4rpx;
  right: 8rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: #ef4444;
  color: #fff;
  font-size: 20rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

/* ==================== 订单卡片 ==================== */
.order-cards {
  display: flex;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.order-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.order-icon-wrap {
  position: relative;
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.order-icon {
  font-size: 32rpx;
}

.order-icon-wrap.orange {
  background: linear-gradient(135deg, #ffedd5, #fed7aa);
}

.order-icon-wrap.blue {
  background: linear-gradient(135deg, #dbeafe, #bfdbfe);
}

.order-icon-wrap.green {
  background: linear-gradient(135deg, #d1fae5, #a7f3d0);
}

.order-icon-wrap.gold {
  background: linear-gradient(135deg, #fef3c7, #fde68a);
}

.order-badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: #ef4444;
  color: #fff;
  font-size: 20rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.order-label {
  font-size: 24rpx;
  color: #475569;
  font-weight: 500;
}

/* ==================== 快捷工具 ==================== */
.tool-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.tool-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tool-icon {
  width: 64rpx;
  height: 64rpx;
  background: #f1f5f9;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  position: relative;
}

.tool-icon text {
  font-size: 32rpx;
}

/* 消息通知图标 */
.notification-icon {
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
}

.notification-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
  color: #fff;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tool-label {
  font-size: 24rpx;
  color: #475569;
}

/* ==================== 退出登录 ==================== */
.logout-section {
  margin: 32rpx 24rpx;
}

.logout-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 88rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.logout-btn text {
  color: #ef4444;
  font-size: 30rpx;
  font-weight: 500;
}

.logout-btn:active {
  background: #fef2f2;
}

/* ==================== 底部间距 ==================== */
.footer-space {
  height: 48rpx;
}
