/* pages/profile/profile.wxss */

.page {
  background: var(--bg-color);
  min-height: 100vh;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  justify-content: center;
  padding: 32px 16px;
  background: #fff;
}

.avatar-wrapper {
  position: relative;
}

.avatar {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  border: 2px solid var(--border-color);
}

.avatar-edit {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 0 0 40px 40px;
  padding: 2px 0;
  text-align: center;
}

.avatar-edit text {
  font-size: 12px;
  color: #fff;
}

/* 分区 */
.section {
  background: #fff;
  padding: 16px;
  margin-top: 12px;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--text-color);
}

.edit-btn {
  font-size: 14px;
  color: var(--primary-color);
}

/* 信息项 */
.info-item {
  display: flex;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid var(--border-color);
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  width: 80px;
  font-size: 14px;
  color: var(--text-secondary);
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  font-size: 14px;
  color: var(--text-color);
}

.info-input {
  flex: 1;
  font-size: 14px;
  color: var(--text-color);
  text-align: right;
}

.bind-btn {
  font-size: 13px;
  color: var(--primary-color);
  margin-left: 8px;
}

.arrow {
  color: var(--text-placeholder);
}

/* 编辑操作 */
.edit-actions {
  display: flex;
  gap: 16px;
  padding: 24px 16px;
}

.edit-actions button {
  flex: 1;
  border-radius: 24px;
  font-size: 16px;
  padding: 12px 0;
}

.btn-cancel {
  background: #fff;
  color: var(--text-secondary);
  border: 1px solid var(--border-color);
}

.btn-save {
  background: var(--primary-color);
  color: #fff;
  border: none;
}

/* 退出登录 */
.logout-section {
  padding: 32px 16px;
}

.btn-logout {
  width: 100%;
  background: #fff;
  color: var(--error-color);
  border: 1px solid var(--error-color);
  border-radius: 24px;
  font-size: 16px;
  padding: 12px 0;
}