<!--pages/notifications/notifications.wxml-->
<!-- 消息通知页面 -->

<view class="page">
  <!-- 未登录状态 -->
  <view wx:if="{{!isLoggedIn}}" class="login-prompt">
    <view class="prompt-icon-wrap">
      <text class="prompt-icon">🔔</text>
    </view>
    <text class="prompt-title">登录后查看消息</text>
    <text class="prompt-desc">第一时间获取重要通知</text>
    <view class="prompt-btn" bindtap="goToLogin">
      <text>立即登录</text>
    </view>
  </view>

  <block wx:else>
    <!-- 头部 -->
    <view class="header-bar">
      <view class="header-left">
        <text class="header-title">消息通知</text>
        <view class="unread-badge" wx:if="{{stats.unread > 0}}">
          <text>{{stats.unread > 99 ? '99+' : stats.unread}}</text>
        </view>
      </view>
      <view class="header-right" bindtap="markAllAsRead" wx:if="{{stats.unread > 0}}">
        <text>全部已读</text>
      </view>
    </view>

    <!-- Tab 切换 -->
    <view class="tab-bar">
      <scroll-view class="tab-scroll" scroll-x>
        <view class="tab-container">
          <view 
            class="tab-item {{currentTab === item.key ? 'active' : ''}}"
            wx:for="{{tabs}}"
            wx:key="key"
            bindtap="switchTab"
            data-tab="{{item.key}}"
          >
            <text class="tab-name">{{item.label}}</text>
            <view class="tab-badge" wx:if="{{item.count > 0}}">{{item.count > 99 ? '99+' : item.count}}</view>
            <view class="tab-line" wx:if="{{currentTab === item.key}}"></view>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 加载中 -->
    <view wx:if="{{loading}}" class="loading-container">
      <text class="loading-spinner">⏳</text>
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 消息列表 -->
    <scroll-view wx:if="{{!loading}}" class="message-scroll" scroll-y enhanced refresher-enabled bindrefresherrefresh="onPullDownRefresh" refresher-triggered="{{refreshing}}">
      <view class="message-list" wx:if="{{messages.length > 0}}">
        <view 
          class="message-card {{item.isUnread ? 'unread' : ''}}"
          wx:for="{{messages}}"
          wx:key="_id"
          bindtap="viewMessage"
          data-index="{{index}}"
        >
          <!-- 未读指示器 -->
          <view class="unread-dot" wx:if="{{item.isUnread}}"></view>
          
          <!-- 类型图标 -->
          <view class="message-icon" style="background: {{item.typeConfig.color}}15;">
            <text style="color: {{item.typeConfig.color}}">{{item.typeConfig.icon}}</text>
          </view>
          
          <!-- 消息内容 -->
          <view class="message-content">
            <view class="message-header">
              <text class="message-title">{{item.title}}</text>
              <text class="message-time">{{formatTime(item.createdAt)}}</text>
            </view>
            <text class="message-desc">{{item.content}}</text>
            <view class="message-footer" wx:if="{{item.link}}">
              <view class="link-tag" bindtap="navigateToLink" data-link="{{item.link}}" catchtap="navigateToLink">
                <text>{{item.linkText || '查看详情'}}</text>
                <text class="arrow">›</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- 空状态 -->
      <view wx:if="{{!loading && messages.length === 0}}" class="empty-container">
        <view class="empty-icon-wrap">
          <text class="empty-icon">🔕</text>
        </view>
        <text class="empty-title">暂无消息</text>
        <text class="empty-desc">您还没有收到任何通知</text>
      </view>

      <!-- 底部提示 -->
      <view class="list-footer" wx:if="{{messages.length > 0}}">
        <text>— 没有更多了 —</text>
      </view>
    </scroll-view>
  </block>

  <!-- 详情弹窗 -->
  <view wx:if="{{showDetail && selectedMessage}}" class="detail-modal">
    <view class="modal-mask" bindtap="closeDetail"></view>
    <view class="modal-content">
      <view class="modal-header">
        <view class="modal-header-left">
          <view class="modal-icon" style="background: {{selectedMessage.typeConfig.color}}15;">
            <text style="color: {{selectedMessage.typeConfig.color}}">{{selectedMessage.typeConfig.icon}}</text>
          </view>
          <view class="modal-title-wrap">
            <text class="modal-title">{{selectedMessage.title}}</text>
            <text class="modal-time">{{formatTime(selectedMessage.createdAt)}}</text>
          </view>
        </view>
        <view class="modal-close" bindtap="closeDetail">×</view>
      </view>

      <scroll-view class="modal-body" scroll-y>
        <!-- 优先级标签 -->
        <view class="priority-tag" wx:if="{{selectedMessage.priority === 'high'}}">
          <text>🔥 紧急</text>
        </view>

        <!-- 消息内容 -->
        <view class="detail-content">
          <text>{{selectedMessage.content}}</text>
        </view>

        <!-- 跳转链接 -->
        <view class="detail-link" wx:if="{{selectedMessage.link}}" bindtap="navigateToLink" data-link="{{selectedMessage.link}}">
          <text>{{selectedMessage.linkText || '查看详情'}}</text>
          <text class="arrow">›</text>
        </view>
      </scroll-view>

      <view class="modal-footer">
        <view class="btn-modal-close" bindtap="closeDetail">
          <text>关闭</text>
        </view>
      </view>
    </view>
  </view>
</view>
