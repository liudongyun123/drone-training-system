/* pages/notifications/notifications.wxss */
/* 消息通知页面样式 */

.page {
  min-height: 100vh;
  background: #f5f6fa;
}

/* 未登录状态 */
.login-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 60rpx;
}

.prompt-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.prompt-icon {
  font-size: 80rpx;
}

.prompt-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 16rpx;
}

.prompt-desc {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  margin-bottom: 60rpx;
}

.prompt-btn {
  padding: 24rpx 80rpx;
  background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
  color: #fff;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 500;
}

/* 头部 */
.header-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: #fff;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.unread-badge {
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 12rpx;
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
  color: #fff;
  border-radius: 18rpx;
  font-size: 22rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-right {
  padding: 12rpx 28rpx;
  background: #f3f4f6;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
}

/* Tab 栏 */
.tab-bar {
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab-scroll {
  width: 100%;
  white-space: nowrap;
}

.tab-container {
  display: inline-flex;
  padding: 0 16rpx;
}

.tab-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 32rpx;
  gap: 8rpx;
}

.tab-name {
  font-size: 28rpx;
  color: #999;
  font-weight: 500;
}

.tab-item.active .tab-name {
  color: #2563eb;
  font-weight: 600;
}

.tab-badge {
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 10rpx;
  background: #ef4444;
  color: #fff;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-item.active .tab-badge {
  background: #2563eb;
}

.tab-line {
  position: absolute;
  bottom: 0;
  width: 48rpx;
  height: 6rpx;
  background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
  border-radius: 3rpx;
}

/* 消息滚动区域 */
.message-scroll {
  height: calc(100vh - 200rpx);
  padding: 24rpx;
}

/* 消息列表 */
.message-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 消息卡片 */
.message-card {
  display: flex;
  position: relative;
  padding: 28rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.message-card.unread {
  background: linear-gradient(135deg, #eff6ff 0%, #fff 100%);
  border-left: 6rpx solid #2563eb;
}

/* 未读指示器 */
.unread-dot {
  position: absolute;
  top: 28rpx;
  left: 16rpx;
  width: 12rpx;
  height: 12rpx;
  background: #ef4444;
  border-radius: 50%;
}

/* 消息图标 */
.message-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

/* 消息内容 */
.message-content {
  flex: 1;
  margin-left: 24rpx;
  min-width: 0;
}

.message-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.message-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.message-card.unread .message-title {
  font-weight: 700;
}

.message-time {
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.message-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.message-footer {
  margin-top: 16rpx;
}

.link-tag {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  padding: 8rpx 20rpx;
  background: #f3f4f6;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #2563eb;
}

.link-tag .arrow {
  font-size: 28rpx;
  font-weight: bold;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  font-size: 64rpx;
  animation: spin 1s linear infinite;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
  margin-top: 20rpx;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 空状态 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  background: #f3f4f6;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #999;
}

/* 底部提示 */
.list-footer {
  text-align: center;
  padding: 40rpx 0;
  font-size: 26rpx;
  color: #999;
}

/* 详情弹窗 */
.detail-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  width: 100%;
  max-height: 85vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-header-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
  min-width: 0;
}

.modal-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.modal-title-wrap {
  flex: 1;
  min-width: 0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.modal-time {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
  display: block;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  background: #f3f4f6;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #666;
  flex-shrink: 0;
}

.modal-body {
  flex: 1;
  padding: 32rpx;
  overflow-y: auto;
}

.priority-tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  background: #fef2f2;
  color: #ef4444;
  border-radius: 30rpx;
  font-size: 24rpx;
  margin-bottom: 24rpx;
}

.detail-content {
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
}

.detail-link {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 40rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #2563eb;
  font-weight: 500;
}

.detail-link .arrow {
  font-size: 36rpx;
  font-weight: bold;
}

.modal-footer {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f0f0f0;
}

.btn-modal-close {
  width: 100%;
  padding: 28rpx;
  text-align: center;
  background: #f3f4f6;
  color: #333;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 500;
}
