/* pages/my-learning/my-learning.wxss */

.page {
  background: #f6f6f6;
  min-height: 100vh;
}

/* 未登录提示 */
.login-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48px 24px;
  background: linear-gradient(135deg, #1890ff 0%, #40a9ff 100%);
  height: 300px;
}

.avatar-placeholder {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  border: 3px solid #fff;
  margin-bottom: 16px;
}

.prompt-text {
  color: #fff;
  font-size: 14px;
  margin-bottom: 24px;
}

.btn-login {
  background: #fff;
  color: #1890ff;
  border-radius: 24px;
  padding: 12px 32px;
  font-size: 16px;
}

/* 用户信息 */
.user-header {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #1890ff 0%, #40a9ff 100%);
  padding: 32px 24px;
}

.avatar {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  border: 3px solid #fff;
}

.user-info {
  flex: 1;
  margin-left: 16px;
}

.nickname {
  font-size: 18px;
  font-weight: 600;
  color: #fff;
  display: block;
}

.phone {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.8);
}

.arrow {
  color: #fff;
  font-size: 18px;
}

/* 功能入口 */
.menu-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
  padding: 24px 16px;
  background: #fff;
}

.menu-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.menu-icon {
  font-size: 32px;
  margin-bottom: 8px;
}

.menu-text {
  font-size: 12px;
  color: #333;
}

/* 课程网格 */
.section {
  margin: 12px 16px;
  background: #fff;
  border-radius: 8px;
  padding: 16px;
}

.section-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: #333;
}

.section-more {
  font-size: 14px;
  color: #1890ff;
}

.course-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
}

.course-card {
  text-align: center;
}

.course-cover {
  width: 100%;
  height: 80px;
  border-radius: 4px;
}

.course-title {
  font-size: 12px;
  color: #333;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}