/* pages/my-learning/my-learning.wxss */

.page {
  min-height: 100vh;
  background: #f5f6fa;
}

/* ==================== 登录提示 ==================== */
.login-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 64rpx;
}

.prompt-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #dbeafe, #bfdbfe);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.prompt-icon {
  font-size: 80rpx;
}

.prompt-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 16rpx;
}

.prompt-desc {
  font-size: 28rpx;
  color: #94a3b8;
  text-align: center;
  margin-bottom: 48rpx;
}

.prompt-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 64rpx;
  background: linear-gradient(135deg, #2563eb, #3b82f6);
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.3);
}

.prompt-btn text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
}

/* ==================== 统计卡片 ==================== */
.stats-card {
  margin: 24rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, #2563eb, #4f46e5);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.2);
}

.stats-header {
  margin-bottom: 28rpx;
}

.stats-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.stats-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.stats-grid {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.2;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 6rpx;
}

.stat-divider {
  width: 2rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.2);
}

/* ==================== Tab 切换 ==================== */
.tab-bar {
  display: flex;
  background: #fff;
  padding: 0 16rpx;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  position: relative;
}

.tab-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #64748b;
}

.tab-item.active .tab-name {
  color: #2563eb;
  font-weight: 600;
}

.tab-line {
  position: absolute;
  bottom: 0;
  width: 48rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #2563eb, #3b82f6);
  border-radius: 3rpx;
}

.tab-badge {
  position: absolute;
  top: 12rpx;
  right: 24rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  background: #ef4444;
  color: #fff;
  font-size: 20rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ==================== 内容区域 ==================== */
.content {
  flex: 1;
  padding: 24rpx;
}

/* 骨架屏 */
.skeleton-container {
  padding: 24rpx;
}

.skeleton-card {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}

.skeleton-left {
  margin-right: 20rpx;
}

.skeleton-cover {
  width: 200rpx;
  height: 150rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  border-radius: 16rpx;
  animation: shimmer 1.5s infinite;
}

.skeleton-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 16rpx;
}

.skeleton-title {
  height: 32rpx;
  width: 80%;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  border-radius: 8rpx;
  animation: shimmer 1.5s infinite;
}

.skeleton-progress {
  height: 16rpx;
  width: 100%;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  border-radius: 8rpx;
  animation: shimmer 1.5s infinite;
}

.skeleton-meta {
  height: 24rpx;
  width: 60%;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  border-radius: 8rpx;
  animation: shimmer 1.5s infinite;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ==================== 课程列表 ==================== */
.course-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* ==================== 课程卡片 ==================== */
.course-card {
  position: relative;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.course-cover {
  width: 100%;
  height: 280rpx;
  background: linear-gradient(135deg, #dbeafe, #e0e7ff);
}

.course-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.course-badge.not-started {
  background: rgba(100, 116, 139, 0.9);
  color: #fff;
}

.course-badge.learning {
  background: rgba(37, 99, 235, 0.9);
  color: #fff;
}

.course-badge.completed {
  background: rgba(16, 185, 129, 0.9);
  color: #fff;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.badge-icon {
  font-size: 20rpx;
}

.course-info {
  padding: 24rpx;
}

.course-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.course-desc {
  font-size: 24rpx;
  color: #94a3b8;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 16rpx;
}

/* 进度条 */
.progress-section {
  margin-bottom: 16rpx;
}

.progress-bar {
  height: 12rpx;
  background: #e2e8f0;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 10rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #2563eb, #3b82f6);
  border-radius: 6rpx;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.progress-text {
  font-size: 22rpx;
  color: #64748b;
}

.progress-percent {
  font-size: 24rpx;
  font-weight: 600;
  color: #2563eb;
}

/* 课程元信息 */
.course-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 20rpx;
}

.meta-icon {
  font-size: 24rpx;
}

.meta-text {
  font-size: 24rpx;
  color: #94a3b8;
}

/* 完成信息 */
.complete-info {
  margin-bottom: 16rpx;
}

.complete-time {
  font-size: 24rpx;
  color: #10b981;
}

/* 底部按钮 */
.course-footer {
  display: flex;
  justify-content: flex-end;
}

.btn-start,
.btn-continue {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 32rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.btn-start {
  background: linear-gradient(135deg, #2563eb, #3b82f6);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.3);
}

.btn-continue {
  background: linear-gradient(135deg, #2563eb, #3b82f6);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.3);
}

/* 课程操作按钮 */
.course-actions {
  display: flex;
  gap: 16rpx;
}

.btn-action {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.btn-action.review {
  background: #f1f5f9;
  color: #64748b;
}

.btn-action.certificate {
  background: linear-gradient(135deg, #f59e0b, #d97706);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(245, 158, 11, 0.3);
}

/* 已完成卡片 */
.course-card.completed .course-cover {
  background: linear-gradient(135deg, #d1fae5, #a7f3d0);
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 96rpx 64rpx;
}

.empty-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #f1f5f9, #e2e8f0);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #94a3b8;
  margin-bottom: 48rpx;
}

.empty-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 48rpx;
  background: linear-gradient(135deg, #2563eb, #3b82f6);
  border-radius: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(37, 99, 235, 0.3);
}

.empty-btn text {
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
}
