/* pages/my-learning/my-learning.wxss */

.page {
  min-height: 100vh;
  background: #f1f5f9;
}

/* ==================== Tab 切换 ==================== */
.tab-bar {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #e2e8f0;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #64748b;
}

.tab-item.active {
  color: #2563eb;
  font-weight: 600;
  border-bottom: 4rpx solid #2563eb;
}

.tab-count {
  background: #ef4444;
  color: #fff;
  font-size: 18rpx;
  padding: 2rpx 8rpx;
  border-radius: 10rpx;
}

/* ==================== 内容区域 ==================== */
.content {
  height: calc(100vh - 80rpx);
}

.course-list {
  padding: 16rpx 24rpx;
}

/* ==================== 课程卡片 ==================== */
.course-card {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.course-cover {
  width: 180rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #dbeafe, #e0e7ff);
}

.course-info {
  flex: 1;
  padding: 12rpx 16rpx;
}

.course-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1e293b;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 进度条 */
.progress-bar {
  height: 8rpx;
  background: #e2e8f0;
  border-radius: 4rpx;
  margin-top: 12rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(135deg, #2563eb, #3b82f6);
  border-radius: 4rpx;
}

.progress-text {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #64748b;
}

.progress-percent {
  color: #2563eb;
  font-weight: 600;
}

.last-time {
  font-size: 20rpx;
  color: #94a3b8;
  margin-top: 8rpx;
}

/* 已完成卡片 */
.course-card.completed .title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.complete-badge {
  font-size: 22rpx;
  color: #10b981;
  background: rgba(16, 185, 129, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}

.complete-time {
  font-size: 22rpx;
  color: #94a3b8;
}

.course-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}

.btn-review,
.btn-certificate {
  font-size: 22rpx;
  padding: 10rpx 20rpx;
  border-radius: 12rpx;
}

.btn-review {
  background: #f1f5f9;
  color: #64748b;
}

.btn-certificate {
  background: linear-gradient(135deg, #2563eb, #3b82f6);
  color: #fff;
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 26rpx;
  color: #94a3b8;
  margin-bottom: 24rpx;
}

.btn-login {
  background: linear-gradient(135deg, #2563eb, #3b82f6);
  color: #fff;
  font-size: 28rpx;
  padding: 20rpx 48rpx;
  border-radius: 32rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #2563eb, #3b82f6);
  color: #fff;
  font-size: 24rpx;
  padding: 16rpx 36rpx;
  border-radius: 24rpx;
}

/* ==================== 加载状态 ==================== */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  font-size: 48rpx;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16rpx;
  color: #94a3b8;
  font-size: 24rpx;
}