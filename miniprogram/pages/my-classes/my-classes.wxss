/* pages/my-classes/my-classes.wxss */

.page {
  min-height: 100vh;
  background: #f5f6fa;
}

/* ==================== 登录提示 ==================== */
.login-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 64rpx;
}

.prompt-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #dbeafe, #bfdbfe);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.prompt-icon {
  font-size: 80rpx;
}

.prompt-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 16rpx;
}

.prompt-desc {
  font-size: 28rpx;
  color: #94a3b8;
  text-align: center;
  margin-bottom: 48rpx;
}

.prompt-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 64rpx;
  background: linear-gradient(135deg, #2563eb, #3b82f6);
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.3);
}

.prompt-btn text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
}

/* ==================== 统计卡片 ==================== */
.stats-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 24rpx;
  padding: 28rpx 32rpx;
  background: linear-gradient(135deg, #2563eb, #4f46e5);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.2);
}

.stats-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.stats-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stats-icon {
  font-size: 40rpx;
}

.stats-info {
  display: flex;
  flex-direction: column;
}

.stats-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 6rpx;
}

.stats-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stats-right {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 16rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
}

.stats-count-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.count-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.2;
}

.count-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

.count-divider {
  width: 2rpx;
  height: 40rpx;
  background: rgba(255, 255, 255, 0.3);
}

/* ==================== Tab 栏 ==================== */
.tab-bar {
  display: flex;
  background: #fff;
  padding: 0 16rpx;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  position: relative;
}

.tab-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #64748b;
}

.tab-item.active .tab-name {
  color: #2563eb;
  font-weight: 600;
}

.tab-line {
  position: absolute;
  bottom: 0;
  width: 48rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #2563eb, #3b82f6);
  border-radius: 3rpx;
}

.tab-badge {
  position: absolute;
  top: 12rpx;
  right: 20rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  background: #ef4444;
  color: #fff;
  font-size: 20rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ==================== 内容区域 ==================== */
.content {
  flex: 1;
  padding: 24rpx;
}

/* 骨架屏 */
.skeleton-container {
  padding: 24rpx;
}

.skeleton-card {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.skeleton-header {
  height: 200rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}

.skeleton-body {
  padding: 24rpx;
}

.skeleton-row {
  height: 24rpx;
  width: 70%;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
  animation: shimmer 1.5s infinite;
}

.skeleton-row.short {
  width: 40%;
}

.skeleton-footer {
  height: 80rpx;
  border-top: 1rpx solid #f1f5f9;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 0 24rpx;
  gap: 16rpx;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ==================== 培训班列表 ==================== */
.class-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* ==================== 培训班卡片 ==================== */
.class-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.card-cover {
  position: relative;
  height: 200rpx;
}

.cover-img {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #dbeafe, #e0e7ff);
}

.cover-status {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.cover-status.status-ongoing {
  background: rgba(37, 99, 235, 0.9);
  color: #fff;
}

.cover-status.status-ended {
  background: rgba(100, 116, 139, 0.9);
  color: #fff;
}

.cover-status.status-upcoming {
  background: rgba(37, 99, 235, 0.9);
  color: #fff;
}

.card-content {
  padding: 24rpx;
}

.card-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 16rpx;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.tag {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  background: #f1f5f9;
  border-radius: 16rpx;
  font-size: 22rpx;
  color: #64748b;
}

.tag-icon {
  font-size: 20rpx;
}

.card-info {
  display: flex;
  gap: 32rpx;
  margin-bottom: 20rpx;
  padding: 16rpx;
  background: #f8fafc;
  border-radius: 12rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.info-label {
  font-size: 22rpx;
  color: #94a3b8;
}

.info-value {
  font-size: 26rpx;
  color: #1e293b;
  font-weight: 500;
}

.info-value.enrollment-confirmed {
  color: #10b981;
}

.info-value.enrollment-pending {
  color: #f59e0b;
}

.info-value.enrollment-completed {
  color: #2563eb;
}

.card-footer {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

.btn-outline,
.btn-primary,
.btn-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.btn-outline {
  background: #fff;
  color: #64748b;
  border: 1rpx solid #e2e8f0;
}

.btn-primary {
  background: linear-gradient(135deg, #2563eb, #3b82f6);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.3);
}

.btn-secondary {
  background: #f1f5f9;
  color: #64748b;
}

/* 底部提示 */
.list-footer {
  text-align: center;
  padding: 48rpx 0;
  color: #cbd5e1;
  font-size: 24rpx;
}

/* ==================== 空状态 ==================== */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 96rpx 64rpx;
}

.empty-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #f1f5f9, #e2e8f0);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #94a3b8;
  text-align: center;
  margin-bottom: 48rpx;
}

.empty-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 48rpx;
  background: linear-gradient(135deg, #2563eb, #3b82f6);
  border-radius: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(37, 99, 235, 0.3);
}

.empty-btn text {
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
}
