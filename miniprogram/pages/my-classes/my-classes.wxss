/* pages/my-classes/my-classes.wxss */

.page {
  min-height: 100vh;
  background: #f1f5f9;
}

/* Tab 栏 */
.tab-bar {
  display: flex;
  background: #fff;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #e2e8f0;
}

.tab-item {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #64748b;
  padding-bottom: 16rpx;
  position: relative;
}

.tab-item.active {
  color: #2563eb;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #2563eb;
  border-radius: 2rpx;
}

/* 培训班列表 */
.class-list {
  padding: 24rpx 32rpx;
}

.class-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #e2e8f0;
}

.class-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
}

.class-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.class-status.status-ongoing {
  background: rgba(37, 99, 235, 0.1);
  color: #2563eb;
}

.class-status.status-ended {
  background: rgba(153, 153, 153, 0.1);
  color: #94a3b8;
}

.card-body {
  padding: 24rpx 32rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.info-label {
  font-size: 26rpx;
  color: #64748b;
}

.info-value {
  font-size: 26rpx;
  color: #1e293b;
}

.info-value.status-confirmed {
  color: #10b981;
}

.info-value.status-pending {
  color: #f59e0b;
}

.card-footer {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #e2e8f0;
}

.action-btn {
  font-size: 24rpx;
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  background: #fff;
  color: #64748b;
  border: 1rpx solid #e2e8f0;
}

.action-btn.primary {
  background: linear-gradient(135deg, #2563eb, #3b82f6);
  color: #fff;
  border-color: transparent;
}

/* 空状态 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  opacity: 0.4;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #64748b;
  margin-bottom: 48rpx;
}

.go-btn {
  margin-top: 32rpx;
  background: linear-gradient(135deg, #2563eb, #3b82f6);
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 20rpx 48rpx;
  border: none;
}
