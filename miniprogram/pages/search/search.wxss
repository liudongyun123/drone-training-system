/* pages/search/search.wxss */

.page {
  min-height: 100vh;
  background: #f1f5f9;
}

/* ==================== 搜索框 ==================== */
.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
  gap: 16rpx;
}

.search-input-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f1f5f9;
  border-radius: 32rpx;
  padding: 12rpx 20rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  opacity: 0.5;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #1e293b;
  background: transparent;
}

.search-input::placeholder {
  color: #94a3b8;
}

.clear-btn {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #cbd5e1;
  border-radius: 50%;
  font-size: 20rpx;
  color: #fff;
}

.cancel-btn {
  font-size: 26rpx;
  color: #2563eb;
  padding: 12rpx 8rpx;
}

/* ==================== 搜索结果 ==================== */
.result-container {
  height: calc(100vh - 100rpx);
}

.result-scroll {
  height: 100%;
}

.result-list {
  padding: 16rpx 24rpx;
}

.result-item {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.result-cover {
  width: 200rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #dbeafe, #e0e7ff);
}

.result-info {
  flex: 1;
  padding: 12rpx 16rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.result-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1e293b;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.result-desc {
  font-size: 22rpx;
  color: #64748b;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.result-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.result-price {
  font-size: 28rpx;
  font-weight: 700;
  color: #ef4444;
}

.result-sales {
  font-size: 20rpx;
  color: #94a3b8;
}

/* ==================== 建议内容 ==================== */
.suggest-container {
  padding: 24rpx;
}

.section {
  margin-bottom: 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
}

.section-action {
  font-size: 24rpx;
  color: #94a3b8;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: #fff;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #64748b;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.tag-item.hot {
  background: linear-gradient(135deg, #fef2f2, #fee2e2);
  color: #dc2626;
}

.hot-icon {
  margin-right: 8rpx;
}

/* ==================== 推荐课程 ==================== */
.recommend-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.recommend-item {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.recommend-cover {
  width: 100%;
  height: 180rpx;
  background: linear-gradient(135deg, #dbeafe, #e0e7ff);
}

.recommend-info {
  padding: 12rpx;
}

.recommend-title {
  font-size: 24rpx;
  font-weight: 500;
  color: #1e293b;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.recommend-price {
  font-size: 24rpx;
  font-weight: 700;
  color: #ef4444;
  margin-top: 8rpx;
}

/* ==================== 空状态 ==================== */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  opacity: 0.5;
}

.empty-text {
  color: #64748b;
  font-size: 28rpx;
  font-weight: 500;
}

.empty-hint {
  color: #94a3b8;
  font-size: 24rpx;
  margin-top: 8rpx;
}

/* ==================== 加载状态 ==================== */
.load-more {
  text-align: center;
  padding: 24rpx;
}

.loading-text {
  color: #94a3b8;
  font-size: 24rpx;
}

.end-text {
  color: #94a3b8;
  font-size: 22rpx;
}
