<!--pages/search/search.wxml-->
<view class="page">
  <!-- 搜索框 -->
  <view class="search-bar">
    <view class="search-input-wrapper">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        type="text"
        value="{{keyword}}"
        placeholder="搜索课程名称"
        focus="{{true}}"
        bindinput="onInput"
        bindconfirm="onSearch"
        confirm-type="search"
      />
      <view class="clear-btn" bindtap="clearKeyword" wx:if="{{keyword}}">
        <text>✕</text>
      </view>
    </view>
    <view class="cancel-btn" bindtap="cancel">取消</view>
  </view>

  <!-- 搜索结果 -->
  <view wx:if="{{keyword && hasSearched}}" class="result-container">
    <scroll-view class="result-scroll" scroll-y enhanced>
      <view class="result-list">
        <view 
          class="result-item" 
          wx:for="{{results}}" 
          wx:key="_id"
          bindtap="goToDetail"
          data-id="{{item._id}}"
        >
          <image class="result-cover" src="{{item.coverImage || item.cover}}" mode="aspectFill" binderror="onImageError" data-index="{{index}}" />
          <view class="result-info">
            <text class="result-title">{{item.title}}</text>
            <text class="result-desc">{{item.description}}</text>
            <view class="result-footer">
              <text class="result-price">¥{{item.price}}</text>
              <text class="result-sales">{{item.salesCount || 0}}人已学</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 无结果 -->
      <view wx:if="{{results.length === 0 && !loading}}" class="empty-container">
        <text class="empty-icon">🔍</text>
        <text class="empty-text">未找到相关课程</text>
        <text class="empty-hint">试试其他关键词</text>
      </view>

      <!-- 加载状态 -->
      <view class="load-more">
        <text wx:if="{{loading}}" class="loading-text">搜索中...</text>
        <text wx:elif="{{!hasMore && results.length > 0}}" class="end-text">— 没有更多了 —</text>
      </view>
    </scroll-view>
  </view>

  <!-- 未搜索状态 - 热门搜索 -->
  <view wx:if="{{!keyword || !hasSearched}}" class="suggest-container">
    <!-- 搜索历史 -->
    <view wx:if="{{history.length > 0}}" class="section">
      <view class="section-header">
        <text class="section-title">搜索历史</text>
        <text class="section-action" bindtap="clearHistory">清除</text>
      </view>
      <view class="tag-list">
        <view 
          class="tag-item" 
          wx:for="{{history}}" 
          wx:key="index"
          bindtap="searchFromHistory"
          data-keyword="{{item}}"
        >
          {{item}}
        </view>
      </view>
    </view>

    <!-- 热门搜索 -->
    <view class="section" wx:if="{{hotKeywords.length > 0}}">
      <view class="section-header">
        <text class="section-title">热门搜索</text>
      </view>
      <view class="tag-list">
        <view 
          class="tag-item hot" 
          wx:for="{{hotKeywords}}" 
          wx:key="index"
          bindtap="searchFromHistory"
          data-keyword="{{item}}"
        >
          <text class="hot-icon">🔥</text>
          {{item}}
        </view>
      </view>
    </view>

    <!-- 推荐课程 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">推荐课程</text>
      </view>
      <view class="recommend-list">
        <view 
          class="recommend-item" 
          wx:for="{{recommendations}}" 
          wx:key="_id"
          bindtap="goToDetail"
          data-id="{{item._id}}"
        >
          <image class="recommend-cover" src="{{item.coverImage || item.cover}}" mode="aspectFill" binderror="onImageError" data-index="{{index}}" />
          <view class="recommend-info">
            <text class="recommend-title">{{item.title}}</text>
            <text class="recommend-price">¥{{item.price}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
