/* pages/lesson-player/lesson-player.wxss */

.lesson-player {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #f5f5f5;
}

/* 视频容器 */
.video-container {
  width: 100%;
  background: #000;
}

.video-player {
  width: 100%;
  height: 422rpx; /* 16:9 比例 */
}

/* 课程信息 */
.lesson-info {
  padding: 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.lesson-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.lesson-meta {
  display: flex;
  margin-bottom: 16rpx;
}

.meta-item {
  font-size: 26rpx;
  color: #666;
  margin-right: 24rpx;
}

/* 进度条 */
.progress-bar {
  width: 100%;
  height: 8rpx;
  background: #e5e5e5;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #2563eb, #3b82f6);
  border-radius: 4rpx;
  transition: width 0.3s;
}

/* 课时列表 */
.lessons-section {
  flex: 1;
  padding: 24rpx;
  background: #fff;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.lessons-list {
  max-height: 400rpx;
}

.lesson-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
  background: #f9f9f9;
}

.lesson-item.active {
  background: #e0f2fe;
  border: 1rpx solid #2563eb;
}

.lesson-item-order {
  width: 48rpx;
  height: 48rpx;
  background: #2563eb;
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.lesson-item.active .lesson-item-order {
  background: #1d4ed8;
}

.lesson-item-content {
  flex: 1;
}

.lesson-item-title {
  font-size: 28rpx;
  color: #333;
}

.lesson-item-duration {
  font-size: 24rpx;
  color: #999;
  margin-left: 16rpx;
}

.lesson-item-status {
  width: 32rpx;
}

.status-completed {
  color: #22c55e;
  font-size: 28rpx;
}

/* 底部操作栏 */
.bottom-bar {
  display: flex;
  padding: 24rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
}

.btn-back {
  flex: 1;
  height: 80rpx;
  background: #f5f5f5;
  color: #666;
  font-size: 28rpx;
  border-radius: 40rpx;
  margin-right: 16rpx;
}

.btn-next {
  flex: 1;
  height: 80rpx;
  background: #2563eb;
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
}

/* 加载状态 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.loading-content {
  display: flex;
  align-items: center;
}

.loading-text {
  font-size: 32rpx;
  color: #666;
}