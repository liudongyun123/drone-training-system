<view class="page">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <text>加载中...</text>
  </view>

  <!-- 商品详情 -->
  <block wx:if="{{product && !loading}}">
    <!-- 商品图片轮播 -->
    <swiper class="product-swiper" indicator-dots autoplay circular>
      <swiper-item wx:for="{{product.images}}" wx:key="*this">
        <image 
          class="product-image" 
          src="{{item}}" 
          mode="aspectFill"
          bindtap="previewImage"
          data-src="{{item}}"
        />
      </swiper-item>
    </swiper>

    <!-- 商品信息 -->
    <view class="product-info">
      <view class="price-row">
        <text class="price-symbol">¥</text>
        <text class="price-num">{{selectedSku.price || product.price}}</text>
        <text wx:if="{{product.originalPrice}}" class="original-price">¥{{product.originalPrice}}</text>
      </view>
      <text class="product-title">{{product.title}}</text>
      <text class="product-subtitle">{{product.subtitle}}</text>
      <view class="product-tags">
        <text class="tag" wx:for="{{product.tags}}" wx:key="*this">{{item}}</text>
      </view>
    </view>

    <!-- 规格选择入口 -->
    <view class="spec-entry" bindtap="openSkuPicker" data-type="cart">
      <text class="spec-label">规格</text>
      <view class="spec-value">
        <text wx:if="{{selectedSku}}">{{selectedSku.name}}</text>
        <text wx:else class="placeholder">请选择规格</text>
      </view>
      <text class="arrow">></text>
    </view>

    <!-- 商品详情 -->
    <view class="detail-section">
      <text class="section-title">商品详情</text>
      <view class="detail-content">
        <rich-text nodes="{{product.description}}"></rich-text>
      </view>
    </view>
  </block>

  <!-- 空状态 -->
  <view wx:if="{{!loading && !product}}" class="empty-container">
    <text>商品不存在</text>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar safe-area-bottom" wx:if="{{product}}">
    <view class="action-icons">
      <view class="action-item" bindtap="goToCart">
        <text class="icon">🛒</text>
        <text class="text">购物车</text>
      </view>
    </view>
    <view class="action-btns">
      <button class="btn-cart" bindtap="openSkuPicker" data-type="cart">加入购物车</button>
      <button class="btn-buy" bindtap="openSkuPicker" data-type="buy">立即购买</button>
    </view>
  </view>

  <!-- SKU 选择弹窗 -->
  <view class="sku-modal {{showSkuPicker ? 'show' : ''}}" bindtap="closeSkuPicker">
    <view class="sku-picker" catchtap="">
      <!-- SKU 头部 -->
      <view class="sku-header">
        <image class="sku-image" src="{{product.images[0]}}" mode="aspectFill" />
        <view class="sku-info">
          <view class="price-row">
            <text class="price-symbol">¥</text>
            <text class="price-num">{{selectedSku.price || product.price}}</text>
          </view>
          <text class="stock">库存: {{selectedSku.stock || product.stock}}件</text>
          <text wx:if="{{selectedSku}}" class="selected-specs">已选: {{selectedSku.name}}</text>
        </view>
        <text class="close-btn" bindtap="closeSkuPicker">×</text>
      </view>

      <!-- 规格列表 -->
      <view class="spec-list">
        <view class="spec-group" wx:for="{{product.specs}}" wx:key="name" wx:for-item="specGroup">
          <text class="spec-name">{{specGroup.name}}</text>
          <view class="spec-options">
            <view 
              class="spec-option {{selectedSpecs[specGroup.name] === option ? 'active' : ''}}"
              wx:for="{{specGroup.values}}"
              wx:key="*this"
              wx:for-item="option"
              bindtap="selectSpec"
              data-spec-name="{{specGroup.name}}"
              data-spec-value="{{option}}"
            >
              {{option}}
            </view>
          </view>
        </view>
      </view>

      <!-- 数量选择 -->
      <view class="quantity-row">
        <text class="quantity-label">数量</text>
        <view class="quantity-control">
          <button class="qty-btn" bindtap="decreaseQty">-</button>
          <text class="qty-num">{{quantity}}</text>
          <button class="qty-btn" bindtap="increaseQty">+</button>
        </view>
      </view>

      <!-- 确认按钮 -->
      <button class="confirm-btn" bindtap="confirmAction">
        {{buyType === 'cart' ? '加入购物车' : '立即购买'}}
      </button>
    </view>
  </view>
</view>