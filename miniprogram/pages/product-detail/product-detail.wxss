/* pages/product-detail/product-detail.wxss */

.page {
  min-height: 100vh;
  background: #f1f5f9;
  padding-bottom: 140rpx;
}

/* 商品图片轮播 */
.product-swiper {
  width: 100%;
  height: 750rpx;
  background: #fff;
}

.product-image {
  width: 100%;
  height: 100%;
}

/* 商品信息 */
.product-info {
  background: #fff;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 16rpx;
}

.price-symbol {
  color: #ef4444;
  font-size: 28rpx;
}

.price-num {
  color: #ef4444;
  font-size: 48rpx;
  font-weight: 700;
}

.original-price {
  color: #94a3b8;
  font-size: 28rpx;
  text-decoration: line-through;
  margin-left: 16rpx;
}

.product-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 8rpx;
}

.product-subtitle {
  display: block;
  font-size: 26rpx;
  color: #64748b;
  margin-bottom: 16rpx;
}

.product-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag {
  padding: 4rpx 16rpx;
  font-size: 24rpx;
  color: #2563eb;
  background: rgba(37, 99, 235, 0.1);
  border-radius: 8rpx;
}

/* 规格选择入口 */
.spec-entry {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.spec-label {
  color: #64748b;
  margin-right: 32rpx;
  font-size: 28rpx;
}

.spec-value {
  flex: 1;
  font-size: 28rpx;
  color: #1e293b;
}

.spec-value .placeholder {
  color: #94a3b8;
}

.arrow {
  color: #94a3b8;
  font-size: 28rpx;
}

/* 商品详情 */
.detail-section {
  background: #fff;
  padding: 32rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #e2e8f0;
}

.detail-content {
  font-size: 28rpx;
  color: #64748b;
  line-height: 1.8;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  background: #fff;
  padding: 16rpx 32rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.action-icons {
  display: flex;
  margin-right: 32rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 24rpx;
}

.action-item .icon {
  font-size: 40rpx;
}

.action-item .text {
  font-size: 20rpx;
  color: #64748b;
  margin-top: 4rpx;
}

.action-btns {
  flex: 1;
  display: flex;
  gap: 24rpx;
}

.action-btns button {
  flex: 1;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 20rpx 0;
  height: auto;
}

.btn-cart {
  background: #fff;
  color: #2563eb;
  border: 1rpx solid #2563eb;
}

.btn-buy {
  background: linear-gradient(135deg, #2563eb, #3b82f6);
  color: #fff;
  border: none;
}

/* SKU 选择弹窗 */
.sku-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  visibility: hidden;
  opacity: 0;
  transition: opacity 0.3s;
}

.sku-modal.show {
  visibility: visible;
  opacity: 1;
}

.sku-picker {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  max-height: 80vh;
  overflow-y: auto;
}

.sku-header {
  display: flex;
  padding-bottom: 32rpx;
  border-bottom: 1rpx solid #e2e8f0;
  position: relative;
}

.sku-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  margin-right: 24rpx;
  background: linear-gradient(135deg, #dbeafe, #e0e7ff);
}

.sku-info {
  flex: 1;
}

.sku-info .price-row {
  margin-bottom: 8rpx;
}

.stock {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 8rpx;
}

.selected-specs {
  display: block;
  font-size: 24rpx;
  color: #64748b;
}

.close-btn {
  position: absolute;
  right: 0;
  top: 0;
  font-size: 48rpx;
  color: #94a3b8;
  width: 64rpx;
  height: 64rpx;
  text-align: center;
  line-height: 64rpx;
}

/* 规格列表 */
.spec-list {
  padding: 32rpx 0;
}

.spec-group {
  margin-bottom: 32rpx;
}

.spec-name {
  display: block;
  font-size: 28rpx;
  color: #1e293b;
  margin-bottom: 24rpx;
}

.spec-options {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.spec-option {
  padding: 16rpx 32rpx;
  font-size: 26rpx;
  color: #1e293b;
  background: #f1f5f9;
  border-radius: 8rpx;
  border: 1rpx solid #e2e8f0;
}

.spec-option.active {
  color: #2563eb;
  border-color: #2563eb;
  background: rgba(37, 99, 235, 0.1);
}

/* 数量选择 */
.quantity-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-top: 1rpx solid #e2e8f0;
}

.quantity-label {
  font-size: 28rpx;
  color: #1e293b;
}

.quantity-control {
  display: flex;
  align-items: center;
}

.qty-btn {
  width: 56rpx;
  height: 56rpx;
  font-size: 32rpx;
  line-height: 56rpx;
  padding: 0;
  margin: 0;
  border: 1rpx solid #e2e8f0;
  background: #fff;
  border-radius: 8rpx;
  color: #64748b;
}

.qty-num {
  width: 96rpx;
  text-align: center;
  font-size: 28rpx;
  color: #1e293b;
}

/* 确认按钮 */
.confirm-btn {
  width: 100%;
  background: linear-gradient(135deg, #2563eb, #3b82f6);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  padding: 24rpx 0;
  margin-top: 32rpx;
  border: none;
}
