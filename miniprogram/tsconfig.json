{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": false,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "experimentalDecorators": true,
    "lib": ["ES2020"],
    "skipLibCheck": true,
    "typeRoots": ["./typings", "node_modules/@types", "node_modules/miniprogram-api-typings"],
    "ignoreDeprecations": "5.0"
  },
  "include": [
    "./**/*.ts",
    "./typings/**/*.d.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
