/* components/class-card/class-card.wxss */
.class-card {
  background: #fff;
  border-radius: 8px;
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.name {
  font-size: 16px;
  font-weight: 600;
  color: #333;
}

.status {
  font-size: 12px;
  padding: 4px 8px;
  border-radius: 4px;
  background: #e6f7ff;
  color: #1890ff;
}

.status.enrolling {
  background: #e6f7ff;
  color: #1890ff;
}

.status.ongoing {
  background: #f6ffed;
  color: #52c41a;
}

.status.completed {
  background: #f5f5f5;
  color: #999;
}

.info {
  margin-bottom: 12px;
}

.row {
  display: flex;
  padding: 4px 0;
}

.label {
  width: 48px;
  color: #999;
  font-size: 13px;
}

.value {
  flex: 1;
  color: #333;
  font-size: 13px;
}

.footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.price {
  color: #ff4d4f;
}

.symbol {
  font-size: 12px;
}

.num {
  font-size: 18px;
  font-weight: 600;
}

.btn-schedule {
  padding: 8px 16px;
  background: #1890ff;
  color: #fff;
  border-radius: 4px;
  font-size: 13px;
}