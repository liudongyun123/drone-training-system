/* components/course-card/course-card.wxss */
.course-card {
  background: #fff;
  border-radius: 8px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.cover {
  width: 100%;
  height: 120px;
}

.info {
  padding: 12px;
}

.title {
  font-size: 15px;
  font-weight: 600;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

.desc {
  font-size: 12px;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
  margin-top: 4px;
}

.bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8px;
}

.price {
  color: #ff4d4f;
}

.symbol {
  font-size: 12px;
}

.num {
  font-size: 18px;
  font-weight: 600;
}

.sales {
  font-size: 12px;
  color: #999;
}

.progress {
  margin-top: 8px;
}

.progress-bar {
  height: 4px;
  background: #e8e8e8;
  border-radius: 2px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #52c41a;
  border-radius: 2px;
}

.progress-text {
  font-size: 12px;
  color: #52c41a;
  margin-top: 4px;
}