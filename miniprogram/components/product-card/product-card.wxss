/* components/product-card/product-card.wxss */
.product-card {
  background: #fff;
  border-radius: 8px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.card-main {
  display: flex;
  flex-direction: column;
}

.cover {
  width: 100%;
  height: 100px;
}

.info {
  padding: 8px;
}

.name {
  font-size: 13px;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

.price-row {
  margin-top: 4px;
}

.price {
  color: #ff4d4f;
}

.symbol {
  font-size: 12px;
}

.num {
  font-size: 16px;
  font-weight: 600;
}

.card-actions {
  display: flex;
  justify-content: flex-end;
  padding: 8px;
  border-top: 1px solid #f0f0f0;
}

.btn-cart {
  padding: 6px 12px;
  background: #1890ff;
  color: #fff;
  border-radius: 4px;
  display: flex;
  align-items: center;
}

.cart-icon {
  font-size: 16px;
}