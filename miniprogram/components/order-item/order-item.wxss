/* components/order-item/order-item.wxss */
.order-item {
  background: #fff;
  border-radius: 8px;
  margin-bottom: 12px;
  overflow: hidden;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 16px;
  border-bottom: 1px solid #f0f0f0;
}

.order-no {
  font-size: 12px;
  color: #999;
}

.status {
  font-size: 12px;
  padding: 2px 8px;
  border-radius: 4px;
}

.status.warning { background: #fff7e6; color: #fa8c16; }
.status.success { background: #f6ffed; color: #52c41a; }
.status.info { background: #e6f7ff; color: #1890ff; }
.status.default { background: #f5f5f5; color: #999; }
.status.error { background: #fff2f0; color: #ff4d4f; }

.body {
  padding: 12px 16px;
}

.item {
  display: flex;
  margin-bottom: 12px;
}

.item:last-child {
  margin-bottom: 0;
}

.item-cover {
  width: 80px;
  height: 60px;
  border-radius: 4px;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  margin-left: 12px;
}

.item-title {
  font-size: 14px;
  color: #333;
  display: block;
}

.item-price {
  font-size: 14px;
  color: #ff4d4f;
  margin-top: 8px;
  display: block;
}

.footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 16px;
  border-top: 1px solid #f0f0f0;
}

.total {
  font-size: 14px;
}

.label {
  color: #666;
}

.price {
  color: #ff4d4f;
  font-weight: 600;
}

.actions {
  display: flex;
  gap: 8px;
}

.btn {
  padding: 6px 16px;
  font-size: 13px;
  border-radius: 4px;
  border: 1px solid #d9d9d9;
  color: #666;
}

.btn.primary {
  background: #1890ff;
  border-color: #1890ff;
  color: #fff;
}