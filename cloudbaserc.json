              "handler": "index.main",
              "envVariables": {},
              "ignore": ["node_modules/**", "node_modules", ".git/**", ".git"],
              "triggers": []
            },
            {
              "name": "addUser",
              "timeout": 30,
              "memorySize": 256,
              "runtime": "Nodejs18.15",
              "handler": "index.main",
              "envVariables": {},
              "ignore": ["node_modules/**", "node_modules", ".git/**", ".git"],
              "triggers": []
            }
          ]
        }
      }
    }
  }
}
