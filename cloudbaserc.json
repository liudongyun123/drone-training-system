{
  "version": "2.0",
  "envId": "rcwljy-5ghmq2ex26764978",
  "$schema": "https://framework-1258016615.tcloudbaseapp.com/schema/latest.json",
  "framework": {
    "name": "cloudbase-react-template",
    "plugins": {
      "client": {
        "use": "@cloudbase/framework-plugin-website",
        "inputs": {
          "outputPath": "dist",
          "buildCommand": "npm run build",
          "cloudPath": "/",
          "websiteConfig": {
            "index": "index.html",
            "error": "index.html",
            "routes": [
              { "path": "/admin/*", "target": "admin/index.html" },
              { "path": "/admin", "target": "admin/index.html" },
              { "path": "/admin/login", "target": "admin/index.html" },
              { "path": "/admin/dashboard", "target": "admin/index.html" },
              { "path": "/courses/*", "target": "index.html" },
              { "path": "/course/*", "target": "index.html" },
              { "path": "/lesson/*", "target": "index.html" },
              { "path": "/exam/*", "target": "index.html" },
              { "path": "/my-learning", "target": "index.html" },
              { "path": "/checkout", "target": "index.html" },
              { "path": "/*", "target": "index.html" }
            ]
          }
        }
      },
      "functions": {
        "use": "@cloudbase/framework-plugin-function",
        "inputs": {
          "functions": [
            {
              "name": "api-user",
              "timeout": 60,
              "memorySize": 256,
              "runtime": "Nodejs18.15",
              "handler": "index.main",
              "envVariables": {},
              "ignore": ["node_modules/**", "node_modules", ".git/**", ".git"],
              "triggers": [
                {
                  "name": "http-trigger",
                  "type": "http"
                }
              ]
            },
            {
              "name": "admin-http",
              "timeout": 60,
              "memorySize": 256,
              "runtime": "Nodejs18.15",
              "handler": "index.main",
              "envVariables": {},
              "ignore": ["node_modules/**", "node_modules", ".git/**", ".git"],
              "triggers": [
                {
                  "name": "http-trigger",
                  "type": "http"
                }
              ]
            },
            {
              "name": "admin",
              "timeout": 60,
              "memorySize": 256,
              "runtime": "Nodejs18.15",
              "handler": "index.main",
              "envVariables": {},
              "ignore": ["node_modules/**", "node_modules", ".git/**", ".git"],
              "triggers": []
            },
            {
              "name": "mobile-auth",
              "timeout": 60,
              "memorySize": 256,
              "runtime": "Nodejs18.15",
              "handler": "index.main",
              "envVariables": {},
              "ignore": ["node_modules/**", "node_modules", ".git/**", ".git", "scf_bootstrap"],
              "triggers": []
            },
            {
              "name": "migrate-permissions",
              "timeout": 60,
              "memorySize": 256,
              "runtime": "Nodejs18.15",
              "handler": "index.main",
              "envVariables": {},
              "ignore": ["node_modules/**", "node_modules", ".git/**", ".git"],
              "triggers": []
            },
            {
              "name": "wechat-pay",
              "timeout": 15,
              "memorySize": 256,
              "runtime": "Nodejs18.15",
              "handler": "index.main",
              "envVariables": {
                "WX_APPID": "wx25aaf895ab86181a",
                "WX_MCH_ID": "",
                "WX_API_KEY": "",
                "WX_NOTIFY_URL": ""
              },
              "ignore": ["node_modules/**", "node_modules", ".git/**", ".git"],
              "triggers": [
                {
                  "name": "http-trigger",
                  "type": "http"
                }
              ]
            },
            {
              "name": "db-init",
              "timeout": 60,
              "memorySize": 256,
              "runtime": "Nodejs18.15",
              "handler": "index.main",
              "envVariables": {},
              "ignore": ["node_modules/**", "node_modules", ".git/**", ".git"],
              "triggers": [
                {
                  "name": "http-trigger",
                  "type": "http"
                }
              ]
            },
            {
              "name": "login-http",
              "timeout": 60,
              "memorySize": 256,
              "runtime": "Nodejs18.15",
              "handler": "index.main",
              "envVariables": {},
              "ignore": ["node_modules/**", "node_modules", ".git/**", ".git"],
              "triggers": [
                {
                  "name": "http-trigger",
                  "type": "http"
                }
              ]
            },
            {
              "name": "init-dictionaries",
              "timeout": 60,
              "memorySize": 256,
              "runtime": "Nodejs18.15",
              "handler": "index.main",
              "envVariables": {},
              "ignore": ["node_modules/**", "node_modules", ".git/**", ".git"],
              "triggers": []
            },
            {
              "name": "db-optimize",
              "timeout": 120,
              "memorySize": 512,
              "runtime": "Nodejs18.15",
              "handler": "index.main",
              "envVariables": {},
              "ignore": ["node_modules/**", "node_modules", ".git/**", ".git"],
