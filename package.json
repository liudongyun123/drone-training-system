{
  "name": "drone-training-system",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:check": "tsc -b && vite build",
    "lint": "eslint src/ --fix",
    "preview": "vite preview",
    "format": "prettier --write src",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "type-check": "tsc --noEmit",
    "quality": "bash scripts/quality-check.sh",
    "quality:strict": "tsc --noEmit && eslint src --ext .ts,.tsx --max-warnings=50 && vitest run --passWithNoTests && vite build"
  },
  "dependencies": {
    "@cloudbase/js-sdk": "latest",
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@mui/icons-material": "^5.15.20",
    "@mui/material": "^5.15.20",
    "@sentry/browser": "^10.48.0",
    "@sentry/react": "^10.48.0",
    "@sentry/vite-plugin": "^5.2.0",
    "@types/qrcode": "^1.5.6",
    "@types/video.js": "^7.3.58",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "dayjs": "^1.11.10",
    "framer-motion": "^10.16.0",
    "lucide-react": "^0.454.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.4.0",
    "recharts": "^2.10.0",
    "video.js": "^8.23.7",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.4.21",
    "daisyui": "^4.12.24",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.5.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.2",
    "postcss": "^8.4.47",
    "prettier": "3.6.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.4"
  }
}
