# CloudBase 静态托管 SPA 路由重定向规则
# 所有路由重定向到 index.html，支持 React Router

# 前台页面
/courses /index.html 200
/course/* /index.html 200
/my-learning /index.html 200
/lesson/* /index.html 200
/exam/* /index.html 200
/checkout /index.html 200
/messages /index.html 200

# 管理后台 - 每个子路由
/admin/dashboard /admin/index.html 200
/admin/courses /admin/index.html 200
/admin/students /admin/index.html 200
/admin/teachers /admin/index.html 200
/admin/schedules /admin/index.html 200
/admin/attendance /admin/index.html 200
/admin/orders /admin/index.html 200
/admin/finance /admin/index.html 200
/admin/exams /admin/index.html 200
/admin/question-banks /admin/index.html 200
/admin/certificates /admin/index.html 200
/admin/coupons /admin/index.html 200
/admin/group-buys /admin/index.html 200
/admin/live-streams /admin/index.html 200
/admin/banners /admin/index.html 200
/admin/page-config /admin/index.html 200
/admin/auth-config /admin/index.html 200
/admin/logs /admin/index.html 200
/admin/settings /admin/index.html 200

# 管理后台根路径
/admin/* /admin/index.html 200

# 默认重定向 - 所有其他路由也指向 index.html
/* /index.html 200
